    <!-- ================= ADD / EDIT RELIGION FORM ================= -->
    <div class="as-card as-wizard-card" id="relFormWrap" style="display:none;">
        <div class="as-back-row">
            <button class="as-back-link" onclick="relShowList()">
                <i class="fas fa-arrow-left"></i> Back to Religion List
            </button>
        </div>

        <div class="as-body">
            <div class="as-page active">
                <div class="as-head">
                    <div class="as-icon"><i class="fas fa-praying-hands"></i></div>
                    <div>
                        <h2 id="relFormTitle">Add Religion</h2>
                        <p>Define a new religion option used in profile forms.</p>
                    </div>
                </div>

                <div class="as-section-title">
                    <i class="fas fa-info-circle"></i> Religion Details
                </div>
                <div class="as-grid">
                    <div class="as-field">
                        <label>Religion Code <span class="req">*</span></label>
                        <input type="text" id="religionCode" placeholder="e.g. HIN, MUS, CHR">
                    </div>

                    <div class="as-field">
                        <label>Religion Name <span class="req">*</span></label>
                        <input type="text" id="religionName" placeholder="e.g. Hindu, Muslim, Christian">
                    </div>

                    <div class="as-field as-full">
                        <label>Description</label>
                        <input type="text" id="religionDescription" placeholder="e.g. Hindu Religion">
                    </div>

                    <div class="as-field">
                        <label>Display Order</label>
                        <input type="number" id="religionDisplayOrder" placeholder="e.g. 1" min="1">
                    </div>

                    <div class="as-field">
                        <label>Status</label>
                        <select id="religionStatus">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="relShowList()">Cancel</button>
                    <span></span>
                    <button class="as-btn as-btn-primary" onclick="relSaveReligion()">
                        <i class="fas fa-save"></i> Save Religion
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="as-toast" id="relToast">
    <i class="fas fa-check-circle"></i>
    <span id="relToastMessage">Success!</span>
</div>

<script>function relShowForm(btn) {
        document.getElementById('relListWrap').style.display = 'none';
        document.getElementById('relFormWrap').style.display = 'block';
        document.getElementById('relFormTitle').textContent = btn ? 'Edit Religion' : 'Add Religion';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function relShowList() {
        document.getElementById('relFormWrap').style.display = 'none';
        document.getElementById('relListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function relShowToast(msg, type) {
        const toast = document.getElementById('relToast');
        const messageEl = document.getElementById('relToastMessage');
        const icon = toast.querySelector('i');
        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' : 'fas fa-info-circle';
        toast.className = 'as-toast show ' + (type || '');
        setTimeout(() => toast.classList.remove('show'), 3000);
    }

    function relSaveReligion() {
        const code = document.getElementById('religionCode').value.trim();
        if (!code) { relShowToast('Religion Code is required', 'error'); return; }

        const name = document.getElementById('religionName').value.trim();
        if (!name) { relShowToast('Religion Name is required', 'error'); return; }

        relShowToast('Religion "' + name + '" saved successfully!', 'success');
        relShowList();
    }</script>


