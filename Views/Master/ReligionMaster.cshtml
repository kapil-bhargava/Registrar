                            <button class="as-mini-btn" title="Edit" onclick="relShowForm(this)"><i class="fas fa-edit"></i></button>
                            <button class="as-mini-btn" title="Delete"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>4</td>
                        <td><strong>SIK</strong></td>
                        <td>Sikh</td>
                        <td>Sikh Religion</td>
                        <td>4</td>
                        <td><span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td>15-Jul-2026</td>
                        <td>
                            <button class="as-mini-btn" title="Edit" onclick="relShowForm(this)"><i class="fas fa-edit"></i></button>
                            <button class="as-mini-btn" title="Delete"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>5</td>
                        <td><strong>JAI</strong></td>
                        <td>Jain</td>
