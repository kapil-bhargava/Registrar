@model List<Regis.Models.CategoryModel>

@{
    ViewBag.Title = "CategoryMaster";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="catListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-tag"></i> Category Master</h2>
                <p>Manage student categories used across admission &amp; fee modules (General, OBC, SC, ST, EWS...).</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="catShowForm()">
                <i class="fas fa-plus-circle"></i> Add New Category
            </button>
        </div>

        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-tags"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count</span>
                    <span class="as-stat-label">Total Categories</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(c => c.IsActive)</span>
                    <span class="as-stat-label">Active</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-percent"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(c => c.FeeConcession.HasValue && c.FeeConcession > 0)</span>
                    <span class="as-stat-label">With Fee Concession</span>
                </div>
            </div>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>S.No</th>
                        <th>Category Code</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Fee Concession (%)</th>
                        <th>Display Order</th>
                        <th>Status</th>
                        <th>Created On</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="catTableBody">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CategoryId</td>
                            <td><strong>@item.CategoryCode</strong></td>
                            <td>@item.CategoryName</td>
                            <td>@item.Description</td>
                            <td>@(item.FeeConcession.HasValue ? item.FeeConcession.Value.ToString("0.##") : "-")</td>
                            <td>@item.DisplayOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="as-pill as-pill-active">
                                        <i class="fas fa-circle"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-inactive">
                                        <i class="fas fa-circle"></i> Inactive
                                    </span>
                                }
                            </td>
                            <td>@item.CreatedDate?.ToString("dd-MM-yyyy")</td>
                            <td>
                                <button type="button"
                                        class="as-mini-btn"
                                        title="Edit"
                                        onclick="catShowForm(this)"
                                        data-id="@item.CategoryId"
                                        data-code="@item.CategoryCode"
                                        data-name="@item.CategoryName"
                                        data-desc="@item.Description"
                                        data-concession="@item.FeeConcession"
                                        data-order="@item.DisplayOrder"
                                        data-active="@item.IsActive.ToString().ToLower()">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a class="as-mini-btn"
                                   title="Delete"
                                   href="@Url.Action("DeleteCategory", "Master", new { id = item.CategoryId })"
                                   onclick="return confirm('Are you sure you want to delete this category?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot archived"></span> Inactive</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT CATEGORY FORM ================= -->
    @using (Html.BeginForm("CategoryMaster", "Master", FormMethod.Post))
    {
        <div class="as-card as-wizard-card" id="catFormWrap" style="display:none;">

            <div class="as-back-row">
                <button type="button" class="as-back-link" onclick="catShowList()">
                    <i class="fas fa-arrow-left"></i> Back to Category List
                </button>
            </div>

            <div class="as-body">
                <div class="as-page active">
                    <div class="as-head">
                        <div class="as-icon"><i class="fas fa-tag"></i></div>
                        <div>
                            <h2 id="catFormTitle">Add Category</h2>
                            <p>Define a new student category used in admission &amp; fee modules.</p>
                        </div>
                    </div>

                    <div class="as-section-title">
                        <i class="fas fa-info-circle"></i> Category Details
                    </div>

                    <input type="hidden" id="categoryId" name="CategoryId" value="0" />

                    <div class="as-grid">
                        <div class="as-field">
                            <label>Category Code <span class="req">*</span></label>
                            <input type="text" id="categoryCode" name="CategoryCode" class="form-control" placeholder="e.g. GEN, OBC, SC" required />
                            <span class="as-hint">Short unique code used in reports &amp; forms</span>
                        </div>

                        <div class="as-field">
                            <label>Category Name <span class="req">*</span></label>
                            <input type="text" id="categoryName" name="CategoryName" class="form-control" placeholder="e.g. General, OBC, SC, ST, EWS" required />
                        </div>

                        <div class="as-field as-full">
                            <label>Description</label>
                            <textarea id="categoryDescription" name="Description" class="form-control" rows="3" placeholder="e.g. General Category"></textarea>
                        </div>

                        <div class="as-field">
                            <label>Fee Concession (%)</label>
                            <input type="number" id="categoryConcession" name="FeeConcession" class="form-control" min="0" max="100" placeholder="e.g. 10" />
                            <span class="as-hint">Automatic fee discount applied for this category (0 if none)</span>
                        </div>

                        <div class="as-field">
                            <label>Display Order</label>
                            <input type="number" id="categoryDisplayOrder" name="DisplayOrder" class="form-control" min="1" placeholder="e.g. 1" />
                            <span class="as-hint">Controls the order this category appears in dropdowns</span>
                        </div>

                        <div class="as-field">
                            <label>Status</label>
                            <select id="categoryStatus" name="IsActive" class="form-control">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="as-bar">
                        <button type="button" class="as-btn as-btn-ghost" onclick="catShowList()">Cancel</button>
                        <span></span>
                        <button type="submit" class="as-btn as-btn-primary">
                            <i class="fas fa-save"></i>
                            <span id="catSubmitText">Save Category</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<div class="as-toast" id="catToast">
    <i class="fas fa-check-circle"></i>
    <span id="catToastMessage">Success!</span>
</div>

<script>
    function catShowForm(btn) {
        document.getElementById('catListWrap').style.display = 'none';
        document.getElementById('catFormWrap').style.display = 'block';

        if (btn) {
            // EDIT MODE — fill form from data attributes
            document.getElementById('catFormTitle').textContent = 'Edit Category';
            document.getElementById('catSubmitText').textContent = 'Update Category';

            document.getElementById('categoryId').value = btn.dataset.id;
            document.getElementById('categoryCode').value = btn.dataset.code;
            document.getElementById('categoryName').value = btn.dataset.name;
            document.getElementById('categoryDescription').value = btn.dataset.desc;
            document.getElementById('categoryConcession').value = btn.dataset.concession;
            document.getElementById('categoryDisplayOrder').value = btn.dataset.order;
            document.getElementById('categoryStatus').value = btn.dataset.active;
        } else {
            // ADD MODE — reset form
            document.getElementById('catFormTitle').textContent = 'Add Category';
            document.getElementById('catSubmitText').textContent = 'Save Category';

            document.getElementById('categoryId').value = 0;
            document.getElementById('categoryCode').value = '';
            document.getElementById('categoryName').value = '';
            document.getElementById('categoryDescription').value = '';
            document.getElementById('categoryConcession').value = '';
            document.getElementById('categoryDisplayOrder').value = '';
            document.getElementById('categoryStatus').value = 'true';
        }

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function catShowList() {
        document.getElementById('catFormWrap').style.display = 'none';
        document.getElementById('catListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>
