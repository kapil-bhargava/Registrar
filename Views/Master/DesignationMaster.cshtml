@model List<Regis.Models.DesignationModel>

@{
    ViewBag.Title = "DesignationMaster";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <div class="as-card" id="desListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-id-badge"></i> Designation Master</h2>
                <p>Manage staff &amp; faculty designations used across HR and access-control modules.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="desShowForm()">
                <i class="fas fa-plus-circle"></i> Add New Designation
            </button>
        </div>

        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-id-badge"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count</span>
                    <span class="as-stat-label">Total Designations</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(d => d.IsActive)</span>
                    <span class="as-stat-label">Active</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-chalkboard-teacher"></i></div>
                <div class="as-stat-info">j
                    <span class="as-stat-number">@Model.Count(d => d.Level == "Teaching")</span>
                    <span class="as-stat-label">Teaching</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-briefcase"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(d => d.Level == "Non-Teaching")</span>
                    <span class="as-stat-label">Non-Teaching</span>
                </div>
            </div>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Designation Name</th>
                        <th>Code</th>
                        <th>Level</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="desTableBody">
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td><strong>@d.DesignationName</strong></td>
                            <td>@d.DesignationCode</td>
                            <td><span class="as-type-badge">@d.Level</span></td>
                            <td>
                                @if (d.IsActive)
                                {
                                    <span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-inactive"><i class="fas fa-circle"></i> Inactive</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="as-mini-btn" title="Edit" onclick="desShowForm(this)"
                                        data-id="@d.DesignationId" data-name="@d.DesignationName" data-code="@d.DesignationCode"
                                        data-level="@d.Level" data-active="@d.IsActive.ToString().ToLower()">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a class="as-mini-btn" title="Delete"
                                   href="@Url.Action("DeleteDesignation", "Master", new { id = d.DesignationId })"
                                   onclick="return confirm('Delete this designation?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot archived"></span> Inactive</span>
        </div>
    </div>

    @using (Html.BeginForm("DesignationMaster", "Master", FormMethod.Post))
    {
        <div class="as-card as-wizard-card" id="desFormWrap" style="display:none;">
            <div class="as-back-row">
                <button type="button" class="as-back-link" onclick="desShowList()">
                    <i class="fas fa-arrow-left"></i> Back to Designation List
                </button>
            </div>

            <div class="as-body">
                <div class="as-page active">
                    <div class="as-head">
                        <div class="as-icon"><i class="fas fa-id-badge"></i></div>
                        <div>
                            <h2 id="desFormTitle">Add Designation</h2>
                            <p>Define a new staff/faculty designation.</p>
                        </div>
                    </div>

                    <div class="as-section-title">
                        <i class="fas fa-info-circle"></i> Designation Details
                    </div>

                    <input type="hidden" id="designationId" name="DesignationId" value="0" />

                    <div class="as-grid">
                        <div class="as-field as-full">
                            <label>Designation Name <span class="req">*</span></label>
                            <input type="text" id="designationName" name="DesignationName" placeholder="e.g. Professor, Assistant Professor, HOD, Registrar, Clerk">
                        </div>

                        <div class="as-field">
                            <label>Designation Code <span class="req">*</span></label>
                            <input type="text" id="designationCode" name="DesignationCode" placeholder="e.g. PROF, AP, HOD">
                        </div>

                        <div class="as-field">
                            <label>Level <span class="req">*</span></label>
                            <select id="designationLevel" name="Level">
                                <option value="">-- Select Level --</option>
                                <option value="Teaching">Teaching</option>
                                <option value="Non-Teaching">Non-Teaching</option>
                            </select>
                        </div>

                        <div class="as-field">
                            <label>Status</label>
                            <select id="designationStatus" name="IsActive">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="as-bar">
                        <button type="button" class="as-btn as-btn-ghost" onclick="desShowList()">Cancel</button>
                        <span></span>
                        <button type="submit" class="as-btn as-btn-primary">
                            <i class="fas fa-save"></i> <span id="desSubmitText">Save Designation</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<div class="as-toast" id="desToast">
    <i class="fas fa-check-circle"></i>
    <span id="desToastMessage">Success!</span>
</div>

<script>
    function desShowForm(btn) {
        document.getElementById('desListWrap').style.display = 'none';
        document.getElementById('desFormWrap').style.display = 'block';

        if (btn) {
            document.getElementById('desFormTitle').textContent = 'Edit Designation';
            document.getElementById('desSubmitText').textContent = 'Update Designation';

            document.getElementById('designationId').value = btn.dataset.id;
            document.getElementById('designationName').value = btn.dataset.name;
            document.getElementById('designationCode').value = btn.dataset.code;
            document.getElementById('designationLevel').value = btn.dataset.level || '';
            document.getElementById('designationStatus').value = btn.dataset.active;
        } else {
            document.getElementById('desFormTitle').textContent = 'Add Designation';
            document.getElementById('desSubmitText').textContent = 'Save Designation';
            document.getElementById('designationId').value = 0;
            document.getElementById('designationName').value = '';
            document.getElementById('designationCode').value = '';
            document.getElementById('designationLevel').value = '';
            document.getElementById('designationStatus').value = 'true';
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function desShowList() {
        document.getElementById('desFormWrap').style.display = 'none';
        document.getElementById('desListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>
