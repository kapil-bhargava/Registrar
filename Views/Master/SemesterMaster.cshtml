@model List<Regis.Models.SemesterMasterModel>
@using Regis.Models

@{
    ViewBag.Title = "SemesterMaster";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    var courses = ViewBag.Courses as List<CourseMasterModel> ?? new List<CourseMasterModel>();
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />
@if (TempData["Error"] != null)
{
    <div style="background:#fee; color:#900; padding:10px; margin:10px 0; border:1px solid #900;">
        @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div style="background:#efe; color:#060; padding:10px; margin:10px 0; border:1px solid #060;">
        @TempData["Success"]
    </div>
}
<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="semListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-stream"></i> Semester Master</h2>
                <p>Manage semesters / sections and map them to courses.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="semShowForm()">
                <i class="fas fa-plus-circle"></i> Add New Semester
            </button>
        </div>

        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-stream"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count</span>
                    <span class="as-stat-label">Total Semesters</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-play-circle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(s => s.Status == "Active")</span>
                    <span class="as-stat-label">Active Semesters</span>
                </div>
            </div>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Semester</th>
                        <th>Course</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Credit Limit</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="semTableBody">
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><strong>@(s.SemesterName ?? ("Semester " + s.SemesterNumber))</strong></td>
                            <td>@s.CourseName</td>
                            <td>@(s.StartDate?.ToString("dd/MM/yyyy"))</td>
                            <td>@(s.EndDate?.ToString("dd/MM/yyyy"))</td>
                            <td>@s.CreditLimit</td>
                            <td>
                                @if (s.Status == "Active")
                                {
                                    <span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span>
                                }
                                else if (s.Status == "Completed")
                                {
                                    <span class="as-pill as-pill-closed"><i class="fas fa-check-circle"></i> Completed</span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-draft"><i class="fas fa-clock"></i> Upcoming</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="as-mini-btn" title="Edit" onclick="semShowForm(this)"
                                        data-id="@s.SemesterId" data-number="@s.SemesterNumber" data-name="@s.SemesterName"
                                        data-courseid="@s.CourseId"
                                        data-start="@(s.StartDate?.ToString("yyyy-MM-dd"))" data-end="@(s.EndDate?.ToString("yyyy-MM-dd"))"
                                        data-credit="@s.CreditLimit" data-status="@s.Status">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a class="as-mini-btn" title="Delete"
                                   href="@Url.Action("DeleteSemesterMaster", "Master", new { id = s.SemesterId })"
                                   onclick="return confirm('Delete this semester?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot closed"></span> Completed</span>
            <span><span class="as-legend-dot draft"></span> Upcoming</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT SEMESTER FORM ================= -->
    @using (Html.BeginForm("SemesterMaster", "Master", FormMethod.Post, new { id = "semesterForm" }))
    {
        <div class="as-card as-wizard-card" id="semFormWrap" style="display:none;">

            <div class="as-back-row">
                <button type="button" class="as-back-link" onclick="semShowList()">
                    <i class="fas fa-arrow-left"></i> Back to Semesters List
                </button>
            </div>

            <div class="as-body">
                <div class="as-page active">
                    <div class="as-head">
                        <div class="as-icon"><i class="fas fa-calendar-plus"></i></div>
                        <div>
                            <h2 id="semFormTitle">Add Semester</h2>
                            <p>Create a semester / section and map it to a course.</p>
                        </div>
                    </div>

                    <div class="as-section-title"><i class="fas fa-info-circle"></i> Semester Details</div>

                    <input type="hidden" id="semesterId" name="SemesterId" value="0" />

                    <div class="as-grid">
                        <div class="as-field">
                            <label>Semester Number <span class="req">*</span></label>
                            <input type="number" id="semesterNumber" name="SemesterNumber" min="1" max="12" placeholder="e.g. 3" required>
                        </div>

                        <div class="as-field">
                            <label>Semester Name <span class="req">*</span></label>
                            <input type="text" id="semesterName" name="SemesterName" placeholder="e.g. Semester 3" required>
                        </div>

                        <div class="as-field">
                            <label>Course <span class="req">*</span></label>
                            <select id="semesterCourse" name="CourseId" required>
                                <option value="">-- Select Course --</option>
                                @foreach (var c in courses)
                                {
                                    <option value="@c.CourseId">@c.CourseName</option>
                                }
                            </select>
                            <span class="as-hint">Managed from Course Master</span>
                        </div>

                        <div class="as-field">
                            <label>Start Date <span class="req">*</span></label>
                            <input type="date" id="semesterStartDate" name="StartDate" required>
                        </div>

                        <div class="as-field">
                            <label>End Date <span class="req">*</span></label>
                            <input type="date" id="semesterEndDate" name="EndDate" required>
                        </div>

                        <div class="as-field">
                            <label>Credit Limit</label>
                            <input type="number" id="semesterCreditLimit" name="CreditLimit" placeholder="e.g. 24" min="1">
                        </div>

                        <div class="as-field">
                            <label>Status</label>
                            <select id="semesterStatus" name="Status">
                                <option value="Upcoming">Upcoming</option>
                                <option value="Active">Active</option>
                                <option value="Completed">Completed</option>
                            </select>
                        </div>
                    </div>

                    <div class="as-bar">
                        <button type="button" class="as-btn as-btn-ghost" onclick="semShowList()">Cancel</button>
                        <span></span>
                        <button type="submit" class="as-btn as-btn-primary">
                            <i class="fas fa-save"></i> <span id="semSubmitText">Save Semester</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<div class="as-toast" id="semToast">
    <i class="fas fa-check-circle"></i>
    <span id="semToastMessage">Success!</span>
</div>

<script>
    function semShowForm(btn) {
        document.getElementById('semListWrap').style.display = 'none';
        document.getElementById('semFormWrap').style.display = 'block';

        if (btn) {
            document.getElementById('semFormTitle').textContent = 'Edit Semester';
            document.getElementById('semSubmitText').textContent = 'Update Semester';

            document.getElementById('semesterId').value = btn.dataset.id;
            document.getElementById('semesterNumber').value = btn.dataset.number;
            document.getElementById('semesterName').value = btn.dataset.name || '';
            document.getElementById('semesterCourse').value = btn.dataset.courseid || '';
            document.getElementById('semesterStartDate').value = btn.dataset.start || '';
            document.getElementById('semesterEndDate').value = btn.dataset.end || '';
            document.getElementById('semesterCreditLimit').value = btn.dataset.credit || '';
            document.getElementById('semesterStatus').value = btn.dataset.status || 'Upcoming';
        } else {
            document.getElementById('semFormTitle').textContent = 'Add Semester';
            document.getElementById('semSubmitText').textContent = 'Save Semester';
            document.getElementById('semesterId').value = 0;
            document.getElementById('semesterNumber').value = '';
            document.getElementById('semesterName').value = '';
            document.getElementById('semesterCourse').value = '';
            document.getElementById('semesterStartDate').value = '';
            document.getElementById('semesterEndDate').value = '';
            document.getElementById('semesterCreditLimit').value = '';
            document.getElementById('semesterStatus').value = 'Upcoming';
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function semShowList() {
        document.getElementById('semFormWrap').style.display = 'none';
        document.getElementById('semListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>
