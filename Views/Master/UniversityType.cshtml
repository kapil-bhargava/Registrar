@model List<Regis.Models.UniversityTypeModel>

@{
    ViewBag.Title = "UniversityType";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="utListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-landmark"></i> University Type Master</h2>
                <p>Manage the types of universities (Private, Central, State...) used across the system.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="utShowForm()">
                <i class="fas fa-plus-circle"></i> Add New University Type
            </button>
        </div>

        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-landmark"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count</span>
                    <span class="as-stat-label">Total Types</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(x => x.IsActive)</span>
                    <span class="as-stat-label">Active</span>
                </div>
            </div>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>S.No</th>
                        <th>University Type Code</th>
                        <th>University Type Name</th>
                        <th>Description</th>
                        <th>Display Order</th>
                        <th>Status</th>
                        <th>Created On</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="utTableBody">
                    @{ int sno = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@sno</td>
                            <td><strong>@item.UniversityTypeCode</strong></td>
                            <td>@item.UniversityTypeName</td>
                            <td>@item.Description</td>
                            <td>@item.DisplayOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="as-pill as-pill-active">
                                        <i class="fas fa-circle"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-inactive">
                                        <i class="fas fa-circle"></i> Inactive
                                    </span>
                                }
                            </td>
                            <td>@(item.CreatedDate.HasValue ? item.CreatedDate.Value.ToString("dd-MMM-yyyy") : "-")</td>
                            <td>
                                <button class="as-mini-btn"
                                        title="Edit"
                                        onclick="utShowForm(this)"
                                        data-id="@item.UniversityTypeId"
                                        data-code="@item.UniversityTypeCode"
                                        data-name="@item.UniversityTypeName"
                                        data-description="@item.Description"
                                        data-displayorder="@item.DisplayOrder"
                                        data-active="@item.IsActive.ToString().ToLower()">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a class="as-mini-btn"
                                   title="Delete"
                                   href="@Url.Action("DeleteUniversityType", "Master", new { id = item.UniversityTypeId })"
                                   onclick="return confirm('Are you sure you want to delete this University Type?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                        sno++;
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div style="text-align:center; padding:2rem; color:#94a3b8;">
                    No University Types added yet.
                </div>
            }
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot archived"></span> Inactive</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT UNIVERSITY TYPE FORM ================= -->
    @using (Html.BeginForm("UniversityType", "Master", FormMethod.Post, new { id = "utForm" }))
    {
        <div class="as-card as-wizard-card" id="utFormWrap" style="display:none;">

            <div class="as-back-row">
                <button type="button" class="as-back-link" onclick="utShowList()">
                    <i class="fas fa-arrow-left"></i>
                    Back to University Type List
                </button>
            </div>

            <div class="as-body">
                <div class="as-page active">

                    <div class="as-head">
                        <div class="as-icon">
                            <i class="fas fa-landmark"></i>
                        </div>
                        <div>
                            <h2 id="utFormTitle">Add University Type</h2>
                            <p>Define a new university type used across the system.</p>
                        </div>
                    </div>

                    <div class="as-section-title">
                        <i class="fas fa-info-circle"></i>
                        University Type Details
                    </div>

                    <input type="hidden" id="utId" name="UniversityTypeId" value="0" />

                    <div class="as-grid">

                        <div class="as-field">
                            <label>
                                University Type Code
                                <span class="req">*</span>
                            </label>
                            <input type="text"
                                   id="utCode"
                                   name="UniversityTypeCode"
                                   class="form-control"
                                   placeholder="e.g. PU, CU, SU"
                                   required />
                        </div>

                        <div class="as-field">
                            <label>
                                University Type Name
                                <span class="req">*</span>
                            </label>
                            <input type="text"
                                   id="utName"
                                   name="UniversityTypeName"
                                   class="form-control"
                                   placeholder="e.g. Private University"
                                   required />
                        </div>

                        <div class="as-field as-full">
                            <label>Description</label>
                            <textarea id="utDescription"
                                      name="Description"
                                      class="form-control"
                                      rows="3"
                                      placeholder="e.g. Private Universities"></textarea>
                        </div>

                        <div class="as-field">
                            <label>Display Order</label>
                            <input type="number"
                                   id="utDisplayOrder"
                                   name="DisplayOrder"
                                   class="form-control"
                                   min="1"
                                   placeholder="e.g. 1" />
                            <span class="as-hint">
                                Controls the order this type appears in dropdowns.
                            </span>
                        </div>

                        <div class="as-field">
                            <label>Status</label>
                            <select id="utStatus"
                                    name="IsActive"
                                    class="form-control">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>

                    </div>

                    <div class="as-bar">
                        <button type="button"
                                class="as-btn as-btn-ghost"
                                onclick="utShowList()">
                            Cancel
                        </button>
                        <span></span>
                        <button type="submit" class="as-btn as-btn-primary">
                            <i class="fas fa-save"></i>
                            <span id="utSubmitText">Save University Type</span>
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }

</div>

<div class="as-toast" id="utToast">
    <i class="fas fa-check-circle"></i>
    <span id="utToastMessage">Success!</span>
</div>

<script>
    function utShowForm(btn) {
        document.getElementById('utListWrap').style.display = 'none';
        document.getElementById('utFormWrap').style.display = 'block';

        if (btn) {
            // EDIT MODE
            document.getElementById('utFormTitle').textContent = 'Edit University Type';
            document.getElementById('utSubmitText').textContent = 'Update University Type';

            document.getElementById('utId').value = btn.dataset.id;
            document.getElementById('utCode').value = btn.dataset.code;
            document.getElementById('utName').value = btn.dataset.name;
            document.getElementById('utDescription').value = btn.dataset.description;
            document.getElementById('utDisplayOrder').value = btn.dataset.displayorder;
            document.getElementById('utStatus').value = btn.dataset.active;
        } else {
            // ADD MODE
            document.getElementById('utFormTitle').textContent = 'Add University Type';
            document.getElementById('utSubmitText').textContent = 'Save University Type';
            utClearForm();
        }

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function utShowList() {
        document.getElementById('utFormWrap').style.display = 'none';
        document.getElementById('utListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function utClearForm() {
        document.getElementById('utId').value = 0;
        document.getElementById('utCode').value = '';
        document.getElementById('utName').value = '';
        document.getElementById('utDescription').value = '';
        document.getElementById('utDisplayOrder').value = '';
        document.getElementById('utStatus').value = 'true';
    }

    // Blank save rokne ke liye basic client-side validation
    document.getElementById('utForm').addEventListener('submit', function (e) {
        const code = document.getElementById('utCode').value.trim();
        const name = document.getElementById('utName').value.trim();

        if (!code || !name) {
            e.preventDefault();
            alert('University Type Code and Name are required.');
        }
    });
</script>