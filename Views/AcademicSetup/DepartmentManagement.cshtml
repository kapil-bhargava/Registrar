                        <td><span class="dm-code-badge">MATH</span></td>
                        <td>Faculty of Science</td>
                        <td>Main Campus</td>
                        <td>Dr. Sarah Wilson</td>
                        <td>22</td>
                        <td><span class="dm-pill dm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td class="dm-actions">
                            <button class="dm-mini-btn dm-mini-view" onclick="showView(this)" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="dm-mini-btn" onclick="showForm(this)" title="Edit"><i class="fas fa-edit"></i></button>
                            <button class="dm-mini-btn dm-mini-delete" onclick="deleteDepartment(this)" title="Delete"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
