                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-circle"></i> Status</span>
                    <strong id="dmViewStatus">-</strong>
                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-users"></i> Faculty Count</span>
                    <strong id="dmViewFacultyCount">-</strong>
                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-envelope"></i> Contact Email</span>
                    <strong id="dmViewEmail">-</strong>
                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-phone"></i> Office Number</span>
                    <strong id="dmViewOffice">-</strong>
                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-phone-alt"></i> Alternative Phone</span>
                    <strong id="dmViewAltPhone">-</strong>
                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-fax"></i> Fax Number</span>
                    <strong id="dmViewFax">-</strong>
                </div>
                <div class="dm-view-item">
                    <span><i class="fas fa-calendar-alt"></i> Establishment Year</span>
                    <strong id="dmViewEstYear">-</strong>
                </div>
                <div class="dm-view-item dm-full">
                    <span><i class="fas fa-align-left"></i> Description</span>
                    <strong id="dmViewDesc">-</strong>
                </div>
                <div class="dm-view-item dm-full">
                    <span><i class="fas fa-graduation-cap"></i> Programs Offered</span>
                    <strong id="dmViewPrograms">-</strong>
                </div>
            </div>

            <!-- Related Information -->
            <div class="dm-section-lbl">
                <i class="fas fa-link"></i> Related Information
            </div>
            <div class="dm-related-grid">
                <div class="dm-related-item">
                    <span class="dm-related-label">Faculty Members</span>
                    <span class="dm-related-value" id="dmRelatedFaculty">45</span>
                </div>
                <div class="dm-related-item">
                    <span class="dm-related-label">Programs</span>
                    <span class="dm-related-value" id="dmRelatedPrograms">5</span>
                </div>
                <div class="dm-related-item">
                    <span class="dm-related-label">Courses</span>
                    <span class="dm-related-value" id="dmRelatedCourses">28</span>
                </div>
                <div class="dm-related-item">
                    <span class="dm-related-label">Students</span>
                    <span class="dm-related-value" id="dmRelatedStudents">1,245</span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="dm-bar">
                <span></span>
                <div class="dm-view-actions">
                    <button class="dm-btn dm-btn-outline" onclick="showList()">
                        <i class="fas fa-arrow-left"></i> Back
                    </button>
                    <button class="dm-btn dm-btn-primary" onclick="editFromView()">
                        <i class="fas fa-edit"></i> Edit Department
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Toast Notification -->
<div class="dm-toast" id="dmToast">
    <i class="fas fa-check-circle"></i>
    <span id="dmToastMessage">Success!</span>
</div>

<script>
    let currentViewRow = null;

    // ----- Toast Notification -----
    function showToast(msg, type) {
        const toast = document.getElementById('dmToast');
        const messageEl = document.getElementById('dmToastMessage');
        const icon = toast.querySelector('i');

        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' :
                'fas fa-info-circle';
        toast.className = 'dm-toast show ' + (type || '');

        setTimeout(() => {
            toast.classList.remove('show');
        }, 3000);
    }

    // ----- Status Toggle -----
    document.getElementById('deptStatus').addEventListener('change', function () {
        const t = document.getElementById('dmStatusText');
        if (this.checked) {
            t.textContent = 'Active';
            t.className = 'dm-status-text dm-active';
        } else {
            t.textContent = 'Inactive';
            t.className = 'dm-status-text dm-inactive';
        }
    });

    // ----- Hide All Views -----
    function hideAll() {
        document.getElementById('dmListWrap').style.display = 'none';
        document.getElementById('dmFormWrap').style.display = 'none';
        document.getElementById('dmViewWrap').style.display = 'none';
    }

    // ----- Show List -----
    function showList() {
        hideAll();
        document.getElementById('dmListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ----- Show Form (Add/Edit) -----
    function showForm(rowBtn) {
        hideAll();
        document.getElementById('dmFormWrap').style.display = 'block';

        if (rowBtn && rowBtn.closest) {
            const row = rowBtn.closest('tr');
            document.getElementById('dmFormTitle').textContent = 'Edit Department';

            // Extract data from row
            const nameCell = row.children[0];
            const codeCell = row.children[1];
            const facultyCell = row.children[2];
            const campusCell = row.children[3];
            const hodCell = row.children[4];

            document.getElementById('deptName').value = nameCell.textContent.trim().replace(/^[^\s]+\s/, '');
            document.getElementById('deptCode').value = codeCell.textContent.trim();
            document.getElementById('deptFaculty').value = facultyCell.textContent.trim();
            document.getElementById('deptCampus').value = campusCell.textContent.trim();
            document.getElementById('deptHOD').value = hodCell.textContent.trim();

            const statusPill = row.querySelector('.dm-pill');
            if (statusPill) {
                const isActive = statusPill.classList.contains('dm-pill-active');
                document.getElementById('deptStatus').checked = isActive;
                document.getElementById('dmStatusText').textContent = isActive ? 'Active' : 'Inactive';
                document.getElementById('dmStatusText').className = 'dm-status-text ' + (isActive ? 'dm-active' : 'dm-inactive');
            }
        } else {
            document.getElementById('dmFormTitle').textContent = 'Add Department';
            clearForm();
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ----- Show View -----
    function showView(rowBtn) {
        hideAll();
        document.getElementById('dmViewWrap').style.display = 'block';
        currentViewRow = rowBtn;

        const row = rowBtn.closest('tr');
        const nameCell = row.children[0];
        const codeCell = row.children[1];
        const facultyCell = row.children[2];
        const campusCell = row.children[3];
        const hodCell = row.children[4];
        const facultyCountCell = row.children[5];
        const statusCell = row.children[6];

        document.getElementById('dmViewName').textContent = nameCell.textContent.trim().replace(/^[^\s]+\s/, '');
        document.getElementById('dmViewCode').textContent = codeCell.textContent.trim();
        document.getElementById('dmViewFaculty').textContent = facultyCell.textContent.trim();
        document.getElementById('dmViewCampus').textContent = campusCell.textContent.trim();
        document.getElementById('dmViewHOD').textContent = hodCell.textContent.trim();
        document.getElementById('dmViewFacultyCount').textContent = facultyCountCell.textContent.trim();
        document.getElementById('dmViewStatus').textContent = statusCell.textContent.trim();
        document.getElementById('dmViewStatus').className = 'dm-view-status ' +
            (statusCell.textContent.includes('Active') ? 'dm-active' :
                statusCell.textContent.includes('Inactive') ? 'dm-inactive' : 'dm-pending');

        // Set additional fields (demo data)
        document.getElementById('dmViewEmail').textContent = 'department@university.edu';
        document.getElementById('dmViewOffice').textContent = '+1 234 567 890';
        document.getElementById('dmViewAltPhone').textContent = '+1 234 567 891';
        document.getElementById('dmViewFax').textContent = '+1 234 567 892';
        document.getElementById('dmViewEstYear').textContent = '2005';
        document.getElementById('dmViewDesc').textContent = 'A premier department dedicated to academic excellence and research.';
        document.getElementById('dmViewPrograms').textContent = 'B.Tech, M.Tech, Ph.D.';

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ----- Edit From View -----
    function editFromView() {
        if (currentViewRow) {
            showForm(currentViewRow);
        }
    }

    // ----- Clear Form -----
    function clearForm() {
        document.querySelectorAll('#dmFormWrap input[type=text], #dmFormWrap input[type=tel], #dmFormWrap input[type=email], #dmFormWrap input[type=number], #dmFormWrap select, #dmFormWrap textarea').forEach(el => el.value = '');
        document.getElementById('deptStatus').checked = true;
        document.getElementById('dmStatusText').textContent = 'Active';
        document.getElementById('dmStatusText').className = 'dm-status-text dm-active';
    }

    // ----- Save Department -----
    function saveDepartment() {
        const name = document.getElementById('deptName').value.trim();
        const code = document.getElementById('deptCode').value.trim();
        const faculty = document.getElementById('deptFaculty').value;
        const campus = document.getElementById('deptCampus').value;
        const hod = document.getElementById('deptHOD').value;
        const email = document.getElementById('deptEmail').value.trim();
        const office = document.getElementById('deptOffice').value.trim();

        if (!name) { showToast('Department Name is required', 'error'); return; }
        if (!code) { showToast('Department Code is required', 'error'); return; }
        if (!faculty) { showToast('Please select a Faculty', 'error'); return; }
        if (!campus) { showToast('Please select a Campus', 'error'); return; }
        if (!hod) { showToast('Please select the Head of Department', 'error'); return; }
        if (!email) { showToast('Contact Email is required', 'error'); return; }
        if (!office) { showToast('Office Number is required', 'error'); return; }

        const isActive = document.getElementById('deptStatus').checked;
        const statusClass = isActive ? 'dm-pill-active' : 'dm-pill-inactive';
        const statusText = isActive ? 'Active' : 'Inactive';
        const icon = isActive ? 'fas fa-circle' : 'fas fa-circle';

        const tbody = document.getElementById('departmentTableBody');

        // Check if editing (find row with matching code)
        let existingRow = null;
        const rows = tbody.querySelectorAll('tr');
        for (const row of rows) {
            const codeCell = row.children[1];
            if (codeCell && codeCell.textContent.trim() === code) {
                existingRow = row;
                break;
            }
        }

        if (existingRow) {
            // Update existing row
            existingRow.children[0].textContent = name;
            existingRow.children[2].textContent = faculty;
            existingRow.children[3].textContent = campus;
            existingRow.children[4].textContent = hod;
            existingRow.children[6].innerHTML = `<span class="dm-pill ${statusClass}"><i class="${icon}"></i> ${statusText}</span>`;
            showToast('Department updated successfully!', 'success');
        } else {
            // Add new row
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="dm-name"><i class="fas fa-building"></i> ${name}</td>
                <td><span class="dm-code-badge">${code}</span></td>
                <td>${faculty}</td>
                <td>${campus}</td>
                <td>${hod}</td>
                <td>0</td>
                <td><span class="dm-pill ${statusClass}"><i class="${icon}"></i> ${statusText}</span></td>
                <td class="dm-actions">
                    <button class="dm-mini-btn dm-mini-view" onclick="showView(this)" title="View Details"><i class="fas fa-eye"></i></button>
                    <button class="dm-mini-btn" onclick="showForm(this)" title="Edit"><i class="fas fa-edit"></i></button>
                    <button class="dm-mini-btn dm-mini-delete" onclick="deleteDepartment(this)" title="Delete"><i class="fas fa-trash"></i></button>
                </td>
            `;
            tbody.appendChild(row);
            showToast('Department added successfully!', 'success');
        }

        // Update stats
        updateStats();
        showList();
    }

    // ----- Delete Department -----
    function deleteDepartment(btn) {
        const row = btn.closest('tr');
        const name = row.children[0].textContent.trim().replace(/^[^\s]+\s/, '');

        if (confirm(`Are you sure you want to delete "${name}"?`)) {
            row.remove();
            updateStats();
            showToast('Department deleted successfully!', 'info');
        }
    }

    // ----- Update Stats -----
    function updateStats() {
        const rows = document.querySelectorAll('#departmentTableBody tr');
        const total = rows.length;
        let active = 0;

        rows.forEach(row => {
            const statusCell = row.children[6];
            if (statusCell) {
                const statusText = statusCell.textContent.trim();
                if (statusText.includes('Active')) active++;
            }
        });

        document.getElementById('totalDepartments').textContent = total;
        document.getElementById('activeDepartments').textContent = active;
    }

    // ----- Search Functionality -----
    document.getElementById('departmentSearch')?.addEventListener('input', function (e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#departmentTableBody tr');

        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    // ----- Filter Functionality -----
    document.getElementById('filterFaculty')?.addEventListener('change', applyFilters);
    document.getElementById('filterCampus')?.addEventListener('change', applyFilters);
    document.getElementById('filterStatus')?.addEventListener('change', applyFilters);

    function applyFilters() {
        const facultyFilter = document.getElementById('filterFaculty').value;
        const campusFilter = document.getElementById('filterCampus').value;
        const statusFilter = document.getElementById('filterStatus').value;

        const rows = document.querySelectorAll('#departmentTableBody tr');

        rows.forEach(row => {
            const faculty = row.children[2]?.textContent.trim() || '';
            const campus = row.children[3]?.textContent.trim() || '';
            const status = row.children[6]?.textContent.trim() || '';

            let show = true;
            if (facultyFilter && faculty !== facultyFilter) show = false;
            if (campusFilter && campus !== campusFilter) show = false;
            if (statusFilter && !status.includes(statusFilter)) show = false;

            row.style.display = show ? '' : 'none';
        });
    }

    // ----- Initialize -----
    updateStats();
</script>