@{
    ViewBag.Title = "Department Management";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    ViewBag.ActiveMenu = "Academic";
    ViewData["ActiveSubMenu"] = "Department";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/departmentManagement.css" rel="stylesheet" />

<div class="dm-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="dm-card" id="dmListWrap">
        <!-- Header -->
        <div class="dm-list-head">
            <div>
                <h2><i class="fas fa-building"></i> Department Management</h2>
                <p>Manage all departments, faculty associations, and campus locations.</p>
            </div>
            <div class="dm-header-actions">
                <button class="dm-btn dm-btn-outline" onclick="showForm()">
                    <i class="fas fa-file-import"></i> Import
                </button>
                <button class="dm-btn dm-btn-primary" onclick="showForm()">
                    <i class="fas fa-plus-circle"></i> Add Department
                </button>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="dm-quick-stats">
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-building"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number" id="totalDepartments">12</span>
                    <span class="dm-stat-label">Total Departments</span>
                </div>
            </div>
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number" id="activeDepartments">10</span>
                    <span class="dm-stat-label">Active</span>
                </div>
            </div>
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-user-tie"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number" id="hodCount">12</span>
                    <span class="dm-stat-label">Heads of Department</span>
                </div>
            </div>
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-users"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number" id="facultyCount">348</span>
                    <span class="dm-stat-label">Total Faculty</span>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="dm-table-toolbar">
            <div class="dm-search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search by department name, code, or faculty..." id="departmentSearch">
            </div>
            <div class="dm-filter-group">
                <select id="filterFaculty">
                    <option value="">All Faculties</option>
                    <option value="Engineering">Faculty of Engineering</option>
                    <option value="Science">Faculty of Science</option>
                    <option value="Commerce">Faculty of Commerce</option>
                    <option value="Arts">Faculty of Arts</option>
                    <option value="Medicine">Faculty of Medicine</option>
                </select>
                <select id="filterCampus">
                    <option value="">All Campuses</option>
                    <option value="Main">Main Campus</option>
                    <option value="Gomti">Gomti Nagar Campus</option>
                    <option value="City">City Study Centre</option>
                    <option value="Satellite">Satellite Campus</option>
                </select>
                <select id="filterStatus">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                    <option value="Pending">Pending</option>
                </select>
            </div>
        </div>

        <!-- Department List -->
        <div class="dm-table-scroll">
            <table class="dm-table dm-list-table">
