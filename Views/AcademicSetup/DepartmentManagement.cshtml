                        <td>Dr. Emily Chen</td>
                        <td>15</td>
                        <td><span class="dm-pill dm-pill-pending"><i class="fas fa-clock"></i> Pending</span></td>
                        <td class="dm-actions">
                            <button class="dm-mini-btn dm-mini-view" onclick="showView(this)" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="dm-mini-btn" onclick="showForm(this)" title="Edit"><i class="fas fa-edit"></i></button>
                            <button class="dm-mini-btn dm-mini-delete" onclick="deleteDepartment(this)" title="Delete"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td class="dm-name"><i class="fas fa-heartbeat"></i> Medicine</td>
                        <td><span class="dm-code-badge">MED</span></td>
                        <td>Faculty of Medicine</td>
                        <td>Main Campus</td>
                        <td>Dr. Robert Brown</td>
                        <td>52</td>
                        <td><span class="dm-pill dm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td class="dm-actions">
                            <button class="dm-mini-btn dm-mini-view" onclick="showView(this)" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="dm-mini-btn" onclick="showForm(this)" title="Edit"><i class="fas fa-edit"></i></button>
                            <button class="dm-mini-btn dm-mini-delete" onclick="deleteDepartment(this)" title="Delete"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td class="dm-name"><i class="fas fa-paint-brush"></i> Fine Arts</td>
                        <td><span class="dm-code-badge">ART</span></td>
                        <td>Faculty of Arts</td>
                        <td>City Study Centre</td>
                        <td>Prof. Lisa Taylor</td>
                        <td>8</td>
                        <td><span class="dm-pill dm-pill-inactive"><i class="fas fa-circle"></i> Inactive</span></td>
                        <td class="dm-actions">
                            <button class="dm-mini-btn dm-mini-view" onclick="showView(this)" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="dm-mini-btn" onclick="showForm(this)" title="Edit"><i class="fas fa-edit"></i></button>
                            <button class="dm-mini-btn dm-mini-delete" onclick="deleteDepartment(this)" title="Delete"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="dm-pagination">
            <span>Showing 1-7 of 12 departments</span>
            <div class="dm-pagination-btns">
                <button class="dm-mini-btn"><i class="fas fa-chevron-left"></i></button>
                <button class="dm-mini-btn active">1</button>
                <button class="dm-mini-btn">2</button>
                <button class="dm-mini-btn"><i class="fas fa-chevron-right"></i></button>
            </div>
        </div>

        <!-- Legend -->
        <div class="dm-legend">
            <span><span class="dm-legend-dot active"></span> Active</span>
            <span><span class="dm-legend-dot inactive"></span> Inactive</span>
            <span><span class="dm-legend-dot pending"></span> Pending</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT DEPARTMENT FORM ================= -->
    <div class="dm-card dm-form-card" id="dmFormWrap" style="display:none;">

        <div class="dm-back-row">
            <button class="dm-back-link" onclick="showList()">
                <i class="fas fa-arrow-left"></i> Back to Department List
            </button>
        </div>

        <div class="dm-body">
            <div class="dm-head">
                <div class="dm-icon"><i class="fas fa-building"></i></div>
                <div>
                    <h2 id="dmFormTitle">Add Department</h2>
                    <p>Enter department details, faculty association, and campus location.</p>
                </div>
            </div>

            <!-- Basic Information -->
            <div class="dm-section-lbl">
                <i class="fas fa-info-circle"></i> Basic Information
            </div>
            <div class="dm-grid">
                <div class="dm-field dm-full">
                    <label>Department Name <span class="req">*</span></label>
                    <input type="text" id="deptName" placeholder="e.g. Computer Science & Engineering">
                    <span class="dm-hint">Full name of the department</span>
                </div>
                <div class="dm-field">
                    <label>Department Code <span class="req">*</span></label>
                    <input type="text" id="deptCode" placeholder="e.g. CSE" maxlength="10">
                    <span class="dm-hint">Short, unique identifier</span>
                </div>
                <div class="dm-field">
                    <label>Faculty <span class="req">*</span></label>
                    <select id="deptFaculty">
                        <option value="">-- Select Faculty --</option>
                        <option>Faculty of Engineering</option>
                        <option>Faculty of Science</option>
                        <option>Faculty of Commerce</option>
                        <option>Faculty of Arts</option>
                        <option>Faculty of Medicine</option>
                        <option>Faculty of Law</option>
                        <option>Faculty of Education</option>
                    </select>
                </div>
                <div class="dm-field">
                    <label>Campus <span class="req">*</span></label>
                    <select id="deptCampus">
                        <option value="">-- Select Campus --</option>
                        <option>Main Campus</option>
                        <option>Gomti Nagar Campus</option>
                        <option>City Study Centre</option>
                        <option>Satellite Campus</option>
                        <option>Online Campus</option>
                    </select>
                </div>
                <div class="dm-field">
                    <label>Head of Department <span class="req">*</span></label>
                    <select id="deptHOD">
                        <option value="">-- Select HOD --</option>
                        <option>Dr. John Doe</option>
                        <option>Dr. Jane Smith</option>
                        <option>Dr. Sarah Wilson</option>
                        <option>Prof. Mike Ross</option>
                        <option>Dr. Emily Chen</option>
                        <option>Dr. Robert Brown</option>
                        <option>Prof. Lisa Taylor</option>
                    </select>
                </div>
                <div class="dm-field">
                    <label>Status</label>
                    <div class="dm-status-row">
                        <label class="dm-switch">
                            <input type="checkbox" id="deptStatus" checked>
                            <span class="dm-slider"></span>
                        </label>
                        <span class="dm-status-text dm-active" id="dmStatusText">Active</span>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="dm-section-lbl">
                <i class="fas fa-align-left"></i> Description
            </div>
            <div class="dm-grid">
                <div class="dm-field dm-full">
                    <label>Department Description</label>
                    <textarea id="deptDesc" placeholder="Brief description about the department, its objectives, and key focus areas..."></textarea>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="dm-section-lbl">
                <i class="fas fa-address-card"></i> Contact Information
            </div>
            <div class="dm-grid">
                <div class="dm-field">
                    <label>Contact Email <span class="req">*</span></label>
                    <input type="email" id="deptEmail" placeholder="department@university.edu">
                </div>
                <div class="dm-field">
                    <label>Office Number <span class="req">*</span></label>
                    <input type="tel" id="deptOffice" placeholder="+1 234 567 890">
                </div>
                <div class="dm-field">
                    <label>Alternative Phone</label>
                    <input type="tel" id="deptAltPhone" placeholder="+1 234 567 891">
                </div>
                <div class="dm-field">
                    <label>Fax Number</label>
                    <input type="tel" id="deptFax" placeholder="+1 234 567 892">
                </div>
            </div>

            <!-- Additional Settings -->
            <div class="dm-section-lbl">
                <i class="fas fa-cog"></i> Additional Settings
            </div>
            <div class="dm-grid">
                <div class="dm-field">
                    <label>Establishment Year</label>
                    <input type="number" id="deptEstYear" placeholder="e.g. 2000" min="1900" max="2099">
                </div>
                <div class="dm-field">
                    <label>Budget Code</label>
                    <input type="text" id="deptBudgetCode" placeholder="e.g. BUD-2025-001">
                </div>
                <div class="dm-field">
                    <label>Department Type</label>
                    <select id="deptType">
                        <option value="Academic">Academic</option>
                        <option value="Administrative">Administrative</option>
                        <option value="Research">Research</option>
                        <option value="Support">Support</option>
                    </select>
                </div>
                <div class="dm-field">
                    <label>Programs Offered</label>
                    <input type="text" id="deptPrograms" placeholder="e.g. B.Tech, M.Tech, Ph.D.">
                    <span class="dm-hint">Comma-separated list of programs</span>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="dm-bar">
                <button class="dm-btn dm-btn-ghost" onclick="showList()">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <span></span>
                <button class="dm-btn dm-btn-primary" onclick="saveDepartment()">
                    <i class="fas fa-save"></i> Save Department
                </button>
            </div>
        </div>
    </div>

    <!-- ================= VIEW DEPARTMENT (read-only) ================= -->
