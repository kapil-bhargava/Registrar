@model List<Regis.Models.DepartmentModel>
@using Regis.Models

@{
    ViewBag.Title = "Department Management";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    var faculties = ViewBag.Faculties as List<FacultyModel> ?? new List<FacultyModel>();
    var deptMasterList = ViewBag.DepartmentMasterList as List<DepartmentMasterModel> ?? new List<DepartmentMasterModel>();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/departmentManagement.css" rel="stylesheet" />

<div class="dm-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="dm-card" id="dmListWrap">
        <!-- Header -->
        <div class="dm-list-head">
            <div>
                <h2><i class="fas fa-building"></i> Department Management</h2>
                <p>Manage all departments, faculty associations, and campus locations.</p>
            </div>
            <div class="dm-header-actions">
                <button class="dm-btn dm-btn-primary" onclick="showForm()">
                    <i class="fas fa-plus-circle"></i> Add Department
                </button>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="dm-quick-stats">
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-building"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number">@Model.Count</span>
                    <span class="dm-stat-label">Total Departments</span>
                </div>
            </div>
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number">@Model.Count(d => d.IsActive)</span>
                    <span class="dm-stat-label">Active</span>
                </div>
            </div>
            <div class="dm-stat-card">
                <div class="dm-stat-icon"><i class="fas fa-university"></i></div>
                <div class="dm-stat-info">
                    <span class="dm-stat-number">@faculties.Count</span>
                    <span class="dm-stat-label">Faculties</span>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="dm-table-toolbar">
            <div class="dm-search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search by department name, code, or faculty..." id="departmentSearch">
            </div>
            <div class="dm-filter-group">
                <select id="filterStatus">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
        </div>

        <!-- Department List -->
        <div class="dm-table-scroll">
            <table class="dm-table dm-list-table">
                <thead>
                    <tr>
                        <th>Department Name</th>
                        <th>Code</th>
                        <th>Faculty</th>
                        <th>Campus</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="departmentTableBody">
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td class="dm-name"><i class="fas fa-building"></i> @d.DepartmentName</td>
                            <td><span class="dm-code-badge">@d.DepartmentCode</span></td>
                            <td>@d.FacultyName</td>
                            <td>@d.CampusName</td>
                            <td>
                                @if (d.IsActive)
                                {
                                    <span class="dm-pill dm-pill-active"><i class="fas fa-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="dm-pill dm-pill-inactive"><i class="fas fa-circle"></i> Inactive</span>
                                }
                            </td>
                            <td class="dm-actions">
                                <button type="button" class="dm-mini-btn" title="Edit" onclick="showForm(this)"
                                        data-id="@d.DepartmentId" data-code="@d.DepartmentCode" data-name="@d.DepartmentName"
                                        data-facultyid="@d.FacultyId" data-campus="@d.CampusName"
                                        data-active="@d.IsActive.ToString().ToLower()">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <a class="dm-mini-btn dm-mini-delete" title="Delete"
                                   href="@Url.Action("DeleteDepartment", "AcademicSetup", new { id = d.DepartmentId })"
                                   onclick="return confirm('Delete this department?');">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Legend -->
        <div class="dm-legend">
            <span><span class="dm-legend-dot active"></span> Active</span>
            <span><span class="dm-legend-dot inactive"></span> Inactive</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT DEPARTMENT FORM ================= -->
    @using (Html.BeginForm("DepartmentManagement", "AcademicSetup", FormMethod.Post))
    {
        <div class="dm-card dm-form-card" id="dmFormWrap" style="display:none;">

            <div class="dm-back-row">
                <button type="button" class="dm-back-link" onclick="showList()">
                    <i class="fas fa-arrow-left"></i> Back to Department List
                </button>
            </div>

            <div class="dm-body">
                <div class="dm-head">
                    <div class="dm-icon"><i class="fas fa-building"></i></div>
                    <div>
                        <h2 id="dmFormTitle">Add Department</h2>
                        <p>Pick a department from Department Master and map it to a Faculty.</p>
                    </div>
                </div>

                <input type="hidden" id="departmentId" name="DepartmentId" value="0" />
                <!-- These two carry the values picked from the dropdown below to the Controller -->
                <input type="hidden" id="deptName" name="DepartmentName" value="" />
                <input type="hidden" id="deptCode" name="DepartmentCode" value="" />

                <!-- Basic Information -->
                <div class="dm-section-lbl">
                    <i class="fas fa-info-circle"></i> Basic Information
                </div>
                <div class="dm-grid">
                    <!-- Department Name + Code now come from Department Master, via ONE dropdown -->
                    <div class="dm-field dm-full">
                        <label>Department (from Department Master) <span class="req">*</span></label>
                        <select id="deptMasterSelect" onchange="onDeptMasterChange()">
                            <option value="">-- Select Department --</option>
                            @foreach (var dm in deptMasterList)
                            {
                                <option value="@dm.DepartmentId"
                                        data-name="@dm.DepartmentName"
                                        data-code="@dm.DepartmentCode"
                                        data-facultyid="@dm.FacultyId"
                                        data-campus="@dm.CampusName">
                                    @dm.DepartmentName (@dm.DepartmentCode)
                                </option>
                            }
                        </select>
                        <span class="dm-hint">Managed from Department Master — add new departments there first</span>
                    </div>
                    <div class="dm-field">
                        <label>Department Code</label>
                        <input type="text" id="deptCodeDisplay" placeholder="Auto-filled" readonly disabled>
                    </div>
                    <div class="dm-field">
                        <label>Faculty <span class="req">*</span></label>
                        @*<select id="deptFaculty" name="FacultyId">
            <option value="">-- Select Faculty --</option>
            @foreach (var f in faculties)
            {
                <option value="@f.FacultyId">@f.FacultyName</option>
            }
        </select>*@
                        <select id="deptFaculty" name="FacultyId" onchange="onFacultyChange()">
                            <option value="">-- Select Faculty --</option>
                            @foreach (var f in faculties)
                            {
                               <option value="@f.FacultyId">@f.FacultyName</option>
                            }
                        </select>
                        <span class="dm-hint">Auto-filled from Department Master, editable if needed</span>
                    </div>
                    <div class="dm-field">
                        <label>Campus</label>
                        @Html.DropDownList("CampusId", (SelectList)ViewBag.CampusList, "Select Campus", new { id = "deptCampus" })
                        <span class="dm-hint">Auto-filled from Faculty's default campus, editable if needed</span>
                    </div>
                    <div class="dm-field">
                        <label>Status</label>
                        <div class="dm-status-row">
                            <label class="dm-switch">
                                <input type="checkbox" id="deptStatus" checked>
                                <span class="dm-slider"></span>
                            </label>
                            <span class="dm-status-text dm-active" id="dmStatusText">Active</span>
                        </div>
                        <input type="hidden" id="deptIsActive" name="IsActive" value="true" />
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="dm-bar">
                    <button type="button" class="dm-btn dm-btn-ghost" onclick="showList()">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <span></span>
                    <button type="submit" class="dm-btn dm-btn-primary" onclick="return validateBeforeSubmit()">
                        <i class="fas fa-save"></i> <span id="dmSubmitText">Save Department</span>
                    </button>
                </div>
            </div>
        </div>
    }

</div>

<!-- Toast Notification -->
<div class="dm-toast" id="dmToast">
    <i class="fas fa-check-circle"></i>
    <span id="dmToastMessage">Success!</span>
</div>

<script>
    // ----- When a Department Master entry is picked, auto-fill Name/Code/Faculty/Campus -----
    function onDeptMasterChange() {
        const select = document.getElementById('deptMasterSelect');
        const opt = select.options[select.selectedIndex];

        const name = opt.getAttribute('data-name') || '';
        const code = opt.getAttribute('data-code') || '';
        const facultyId = opt.getAttribute('data-facultyid') || '';
        const campus = opt.getAttribute('data-campus') || '';

        document.getElementById('deptName').value = name;
        document.getElementById('deptCode').value = code;
        document.getElementById('deptCodeDisplay').value = code;
        document.getElementById('deptFaculty').value = facultyId;
        document.getElementById('deptCampus').value = campus;
    }

    function validateBeforeSubmit() {
        if (!document.getElementById('deptMasterSelect').value) {
            showToast('Please select a Department from Department Master', 'error');
            return false;
        }
        if (!document.getElementById('deptFaculty').value) {
            showToast('Please select a Faculty', 'error');
            return false;
        }
        return true;
    }

    // ----- Toast -----
    function showToast(msg, type) {
        const toast = document.getElementById('dmToast');
        const messageEl = document.getElementById('dmToastMessage');
        const icon = toast.querySelector('i');
        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' : 'fas fa-info-circle';
        toast.className = 'dm-toast show ' + (type || '');
        setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // ----- Status Toggle -----
    document.getElementById('deptStatus').addEventListener('change', function () {
        const t = document.getElementById('dmStatusText');
        document.getElementById('deptIsActive').value = this.checked ? 'true' : 'false';
        if (this.checked) {
            t.textContent = 'Active';
            t.className = 'dm-status-text dm-active';
        } else {
            t.textContent = 'Inactive';
            t.className = 'dm-status-text dm-inactive';
        }
    });

    function hideAll() {
        document.getElementById('dmListWrap').style.display = 'none';
        document.getElementById('dmFormWrap').style.display = 'none';
    }

    function showList() {
        hideAll();
        document.getElementById('dmListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showForm(btn) {
        hideAll();
        document.getElementById('dmFormWrap').style.display = 'block';

        if (btn) {
            document.getElementById('dmFormTitle').textContent = 'Edit Department';
            document.getElementById('dmSubmitText').textContent = 'Update Department';

            document.getElementById('departmentId').value = btn.dataset.id;
            document.getElementById('deptName').value = btn.dataset.name;
            document.getElementById('deptCode').value = btn.dataset.code;
            document.getElementById('deptCodeDisplay').value = btn.dataset.code;
            document.getElementById('deptFaculty').value = btn.dataset.facultyid || '';
            document.getElementById('deptCampus').value = btn.dataset.campus || '';

            // Try to pre-select the matching option in the Department Master dropdown
            const select = document.getElementById('deptMasterSelect');
            for (let i = 0; i < select.options.length; i++) {
                if (select.options[i].getAttribute('data-code') === btn.dataset.code) {
                    select.selectedIndex = i;
                    break;
                }
            }

            const active = btn.dataset.active === 'true';
            document.getElementById('deptStatus').checked = active;
            document.getElementById('deptIsActive').value = active ? 'true' : 'false';
            document.getElementById('dmStatusText').textContent = active ? 'Active' : 'Inactive';
            document.getElementById('dmStatusText').className = 'dm-status-text ' + (active ? 'dm-active' : 'dm-inactive');
        } else {
            document.getElementById('dmFormTitle').textContent = 'Add Department';
            document.getElementById('dmSubmitText').textContent = 'Save Department';
            document.getElementById('departmentId').value = 0;
            document.getElementById('deptMasterSelect').value = '';
            document.getElementById('deptName').value = '';
            document.getElementById('deptCode').value = '';
            document.getElementById('deptCodeDisplay').value = '';
            document.getElementById('deptFaculty').value = '';
            document.getElementById('deptCampus').value = '';
            document.getElementById('deptStatus').checked = true;
            document.getElementById('deptIsActive').value = 'true';
            document.getElementById('dmStatusText').textContent = 'Active';
            document.getElementById('dmStatusText').className = 'dm-status-text dm-active';
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ----- Search Functionality -----
    document.getElementById('departmentSearch')?.addEventListener('input', function (e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#departmentTableBody tr');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    document.getElementById('filterStatus')?.addEventListener('change', function () {
        const statusFilter = this.value;
        const rows = document.querySelectorAll('#departmentTableBody tr');
        rows.forEach(row => {
            const status = row.children[4]?.textContent.trim() || '';
            row.style.display = (!statusFilter || status.includes(statusFilter)) ? '' : 'none';
        });
    });
</script>
