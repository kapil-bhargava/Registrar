                    <tr>
                        <th>Department Name</th>
                        <th>Code</th>
                        <th>Faculty</th>
                        <th>Campus</th>
                        <th>HOD</th>
                        <th>Faculty Count</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="departmentTableBody">
                    <tr>
