@using Regis.Models
@{
    ViewBag.Title = "Academic Session";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    ViewBag.ActiveMenu = "Academic";
    ViewData["ActiveSubMenu"] = "Session";

    var sessions = ViewBag.Sessions as List<AcademicSessionModel> ?? new List<AcademicSessionModel>();
    var sessionTypes = ViewBag.SessionTypes as List<SessionTypeModel> ?? new List<SessionTypeModel>();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="asListWrap">
        <!-- Header -->
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-calendar-alt"></i> Academic Sessions</h2>
                <p>Manage all academic sessions for the university. Only one session can be active at a time.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="showWizard()">
                <i class="fas fa-plus-circle"></i> Add New Session
            </button>
        </div>

        <!-- Quick Stats (computed server-side from real data) -->
        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-calendar-check"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@sessions.Count</span>
                    <span class="as-stat-label">Total Sessions</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-play-circle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@(sessions.FirstOrDefault(s => s.Status == "Active")?.SessionName ?? "None")</span>
                    <span class="as-stat-label">Current Active</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-lock"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@sessions.Count(s => s.Status == "Locked")</span>
                    <span class="as-stat-label">Locked Sessions</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-archive"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@sessions.Count(s => s.Status == "Archived")</span>
                    <span class="as-stat-label">Archived</span>
                </div>
            </div>
        </div>

        <!-- Session List — Razor loop over real DB data -->
        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Session Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in sessions)
                    {
                        <tr data-id="@s.AcademicSessionId">
                            <td><strong>@s.SessionName</strong></td>
                            <td>@s.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@s.EndDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="as-type-badge">@s.SessionTypeName</span></td>
                            <td>
                                @if (s.Status == "Active")
                                {
                                    <span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span>
                                }
                                else if (s.Status == "Locked")
                                {
                                    <span class="as-pill as-pill-locked"><i class="fas fa-lock"></i> Locked</span>
                                }
                                else if (s.Status == "Archived")
                                {
                                    <span class="as-pill as-pill-archived"><i class="fas fa-archive"></i> Archived</span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-draft"><i class="fas fa-pencil"></i> Draft</span>
                                }
                            </td>
                            <td>
                                <button class="as-mini-btn" title="View Details" onclick="viewSession(@s.AcademicSessionId)"><i class="fas fa-eye"></i></button>

                                @if (s.Status == "Draft")
                                {
                                    <button class="as-mini-btn" title="Edit" onclick="editSession(@s.AcademicSessionId)"><i class="fas fa-edit"></i></button>
                                    <button class="as-mini-btn" title="Activate" onclick="openActivateStep(@s.AcademicSessionId, '@s.SessionName')"><i class="fas fa-bolt"></i></button>
                                }
                                @if (s.Status == "Active")
                                {
                                    <button class="as-mini-btn" title="Close &amp; Archive" onclick="openCloseStep(@s.AcademicSessionId, '@s.SessionName')"><i class="fas fa-lock"></i></button>
                                }
                                @if (s.Status == "Draft")
                                {
                                    <button class="as-mini-btn" title="Delete" onclick="deleteSession(@s.AcademicSessionId)"><i class="fas fa-trash-alt"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Legend -->
        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot locked"></span> Locked</span>
            <span><span class="as-legend-dot archived"></span> Archived</span>
            <span><span class="as-legend-dot closed"></span> Closed</span>
            <span><span class="as-legend-dot draft"></span> Draft</span>
        </div>
    </div>

    <!-- ================= WIZARD (Add / Activate / Close) ================= -->
    <div class="as-card as-wizard-card" id="asWizardWrap" style="display:none;">

        <!-- Back Button -->
        <div class="as-back-row">
            <button class="as-back-link" onclick="showList()">
                <i class="fas fa-arrow-left"></i> Back to Sessions List
            </button>
        </div>

        <!-- STEPPER -->
        <div class="as-stepper">
            <div class="as-step-line">
                <div class="as-step-line-fill" id="stepLineFill"></div>
            </div>
            <div class="as-step" id="stepIndicator1">
                <div class="as-step-circle">1</div>
                <div class="as-step-label">Create</div>
            </div>
            <div class="as-step" id="stepIndicator2">
                <div class="as-step-circle">2</div>
                <div class="as-step-label">Activate</div>
            </div>
            <div class="as-step" id="stepIndicator3">
                <div class="as-step-circle">3</div>
                <div class="as-step-label">Close</div>
            </div>
        </div>

        <div class="as-body">

            <!-- ================= STEP 1 : CREATE SESSION ================= -->
            <div class="as-page active" id="asPage1">
                <div class="as-head">
                    <div class="as-icon"><i class="fas fa-plus-circle"></i></div>
                    <div>
                        <h2>Create Academic Session</h2>
                        <p>Define a new academic session with all necessary details.</p>
                    </div>
                </div>

                <!-- Basic Information -->
                <div class="as-section-title">
                    <i class="fas fa-info-circle"></i> Basic Information
                </div>
                <div class="as-grid">
                    <div class="as-field as-full">
                        <label>Session Name <span class="req">*</span></label>
                        <input type="text" id="sessionName" placeholder="e.g. Academic Year 2026-27">
                        <span class="as-hint">Enter a unique name for this academic session</span>
                    </div>

                    <div class="as-field">
                        <label>Session Code <span class="req">*</span></label>
                        <input type="text" id="sessionCode" placeholder="e.g. AY-2026-27">
                        <span class="as-hint">Unique identifier for system reference</span>
                    </div>

                    <!-- Session Type dropdown — sourced from Session Type Master -->
                    <div class="as-field">
                        <label>Session Type <span class="req">*</span></label>
                        <select id="sessionType">
                            <option value="">-- Select Session Type --</option>
                            @foreach (var st in sessionTypes)
                            {
                                <option value="@st.SessionTypeId">@st.SessionTypeName (@st.SessionTypeCode)</option>
                            }
                        </select>
                        <span class="as-hint">Options come from Session Type Master</span>
                    </div>

                    <!-- Parent Session dropdown — sourced from this same table (previous sessions) -->
                    <div class="as-field">
                        <label>Parent Session <span class="optional">(optional)</span></label>
                        <select id="parentSession">
                            <option value="">-- None --</option>
                            @foreach (var p in sessions)
                            {
                                <option value="@p.AcademicSessionId">@p.SessionName (@p.SessionTypeName)</option>
                            }
                        </select>
                        <span class="as-hint">Link to a parent academic year if this is a sub-session</span>
                    </div>
                </div>

                <!-- Date Range -->
                <div class="as-section-title">
                    <i class="fas fa-calendar-alt"></i> Date Range
                </div>
                <div class="as-grid">
                    <div class="as-field">
                        <label>Start Date <span class="req">*</span></label>
                        <input type="date" id="startDate">
                    </div>

                    <div class="as-field">
                        <label>End Date <span class="req">*</span></label>
                        <input type="date" id="endDate">
                    </div>

                    <div class="as-field">
                        <label>Duration</label>
                        <input type="text" id="duration" readonly disabled>
                        <span class="as-hint">Auto-calculated from start and end dates</span>
                    </div>

                    <div class="as-field">
                        <label>Academic Year</label>
                        <input type="text" id="academicYear" placeholder="e.g. 2026-27">
                    </div>
                </div>

                <!-- Additional Settings -->
                <div class="as-section-title">
                    <i class="fas fa-cog"></i> Additional Settings
                </div>
                <div class="as-grid">
                    <div class="as-field">
                        <label>Maximum Credits</label>
                        <input type="number" id="maxCredits" value="24" min="10" max="30">
                        <span class="as-hint">Maximum credits a student can take per session</span>
                    </div>

                    <div class="as-field">
                        <label>Status</label>
                        <select id="sessionStatus">
                            <option value="Draft">Draft</option>
                            <option value="Active">Active</option>
                            <option value="Locked">Locked</option>
                            <option value="Archived">Archived</option>
                        </select>
                        <span class="as-hint">Choosing "Active" will automatically lock any currently active session</span>
                    </div>
                </div>

                <div class="as-bar">
                    <span></span>
                    <div class="as-step-count">Step 1 of 3</div>
                    <button class="as-btn as-btn-primary" onclick="saveSession()">
                        <i class="fas fa-save"></i> Save &amp; Continue
                    </button>
                </div>
            </div>

            <!-- ================= STEP 2 : ACTIVATE SESSION ================= -->
            <div class="as-page" id="asPage2">
                <div class="as-head">
                    <div class="as-icon"><i class="fas fa-bolt"></i></div>
                    <div>
                        <h2>Activate Session</h2>
                        <p>Only one session should be active at a time. Activating this session will lock the previous active one.</p>
                    </div>
                </div>

                <!-- Session to Activate -->
                <div class="as-current-session">
                    <div class="as-current-label">📌 Session to Activate</div>
                    <div class="as-current-value" id="sessionToActivateName">—</div>
                    <span class="as-pill as-pill-draft"><i class="fas fa-pencil"></i> Draft</span>
                </div>

                <!-- Warning -->
                <div class="as-warning-box">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <strong>Warning:</strong> Activating this session will lock the current active session.
                        All data in the previous session will become read-only.
                    </div>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="goToStep(1)">
                        <i class="fas fa-arrow-left"></i> Previous
                    </button>
                    <div class="as-step-count">Step 2 of 3</div>
                    <button class="as-btn as-btn-primary" onclick="activateSession()">
                        <i class="fas fa-check-circle"></i> Activate Session
                    </button>
                </div>
            </div>

            <!-- ================= STEP 3 : CLOSE SESSION ================= -->
            <div class="as-page" id="asPage3">
                <div class="as-head">
                    <div class="as-icon"><i class="fas fa-lock"></i></div>
                    <div>
                        <h2>Close &amp; Archive Session</h2>
                        <p>Lock all records and archive the session for historical reference.</p>
                    </div>
                </div>

                <!-- Session to Close -->
                <div class="as-current-session as-close-session">
                    <div class="as-current-label">📌 Session to Close</div>
                    <div class="as-current-value" id="sessionToCloseName">—</div>
                    <span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span>
                </div>

                <!-- Warning -->
                <div class="as-warning-box as-warning-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>
                        <strong>⚠️ This action cannot be undone!</strong><br>
                        Once a session is closed and archived, all data becomes read-only.
                        Please ensure all operations for this session are complete.
                    </div>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="goToStep(2)">
                        <i class="fas fa-arrow-left"></i> Previous
                    </button>
                    <div class="as-step-count">Step 3 of 3</div>
                    <button class="as-btn as-btn-danger" onclick="closeSession()">
                        <i class="fas fa-check-circle"></i> Close &amp; Archive Session
                    </button>
                </div>
            </div>

            <!-- ================= DONE STATE ================= -->
            <div class="as-page" id="asPageDone">
                <div class="as-done">
                    <div class="as-done-icon"><i class="fas fa-check-circle"></i></div>
                    <h2>Done!</h2>
                    <p id="doneMessage">Action completed successfully.</p>
                    <div class="as-done-actions">
                        <button class="as-btn as-btn-primary" onclick="location.reload()">
                            <i class="fas fa-plus-circle"></i> Start New Session
                        </button>
                        <button class="as-btn as-btn-outline" onclick="location.reload()">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <!-- /asWizardWrap -->

</div>

<!-- Toast Notification -->
<div class="as-toast" id="asToast">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage">Success!</span>
</div>

<script>
    // Tracks which session the wizard is currently working on (for Edit / Activate / Close)
    let activeWizardSessionId = null;

    function showWizard() {
        document.getElementById('asListWrap').style.display = 'none';
        document.getElementById('asWizardWrap').style.display = 'block';
        goToStep(1);
        updateStepper(1, 0);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showList() {
        document.getElementById('asWizardWrap').style.display = 'none';
        document.getElementById('asListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showToast(msg, type) {
        const toast = document.getElementById('asToast');
        const messageEl = document.getElementById('toastMessage');
        const icon = toast.querySelector('i');

        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' :
                'fas fa-info-circle';
        toast.className = 'as-toast show ' + (type || '');

        setTimeout(() => {
            toast.classList.remove('show');
        }, 3000);
    }

    function goToStep(n) {
        document.querySelectorAll('.as-page').forEach(p => p.classList.remove('active'));
        document.getElementById('asPage' + n).classList.add('active');
        updateStepper(n);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateStepper(activeStep, completedUpto) {
        completedUpto = completedUpto || (activeStep - 1);
        for (let i = 1; i <= 3; i++) {
            const el = document.getElementById('stepIndicator' + i);
            const circle = el.querySelector('.as-step-circle');
            el.classList.remove('done', 'current');
            if (i <= completedUpto) {
                el.classList.add('done');
                circle.innerHTML = '<i class="fas fa-check"></i>';
            } else if (i === activeStep) {
                el.classList.add('current');
                circle.innerHTML = i;
            } else {
                circle.innerHTML = i;
            }
        }
        const pct = ((completedUpto) / 2) * 100;
        document.getElementById('stepLineFill').style.width = Math.min(pct, 100) + '%';
    }

    // Calculate duration on date change
    document.getElementById('startDate').addEventListener('change', calculateDuration);
    document.getElementById('endDate').addEventListener('change', calculateDuration);

    function calculateDuration() {
        const start = new Date(document.getElementById('startDate').value);
        const end = new Date(document.getElementById('endDate').value);
        if (start && end && end > start) {
            const diffTime = Math.abs(end - start);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            document.getElementById('duration').value = diffDays + ' Days';
        }
    }

    // ===================== STEP 1 : SAVE / UPDATE (AJAX -> Controller) =====================
    function saveSession() {
        const name = document.getElementById('sessionName').value.trim();
        if (!name) { showToast('Session Name is required', 'error'); return; }

        const code = document.getElementById('sessionCode').value.trim();
        if (!code) { showToast('Session Code is required', 'error'); return; }

        const sessionTypeId = document.getElementById('sessionType').value;
        if (!sessionTypeId) { showToast('Please select a Session Type', 'error'); return; }

        const start = document.getElementById('startDate').value;
        const end = document.getElementById('endDate').value;
        if (!start || !end || start >= end) { showToast('End date must be after start date', 'error'); return; }

        const payload = {
            AcademicSessionId: activeWizardSessionId || 0,
            SessionName: name,
            SessionCode: code,
            SessionTypeId: parseInt(sessionTypeId),
            StartDate: start,
            EndDate: end,
            AcademicYear: document.getElementById('academicYear').value,
            MaxCredits: parseInt(document.getElementById('maxCredits').value || 24),
            Status: document.getElementById('sessionStatus').value
        };

        const isEditing = !!activeWizardSessionId;
        const url = isEditing ? '/AcademicSetup/UpdateAcademicSession' : '/AcademicSetup/SaveAcademicSession';

        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
            .then(res => res.json())
            .then(data => {
                if (!data.success) { showToast(data.message, 'error'); return; }

                if (!isEditing) activeWizardSessionId = data.id;
                document.getElementById('sessionToActivateName').textContent = name;

                showToast(data.message, 'success');

                // Agar user ne khud "Active" ya "Locked" ya "Archived" choose kar liya,
                // toh ab Activate/Close wizard steps se guzarne ki zaroorat nahi — seedha list par wapas jao.
                if (payload.Status !== 'Draft') {
                    setTimeout(() => location.reload(), 800);
                    return;
                }

                goToStep(2);
                updateStepper(2, 1);
            })
            .catch(() => showToast('Server error while saving session', 'error'));
    }

    // ===================== EDIT (fetch existing data, prefill wizard) =====================
    function editSession(id) {
        fetch('/AcademicSetup/GetAcademicSession?id=' + id)
            .then(res => res.json())
            .then(s => {
                activeWizardSessionId = id;
                showWizard();
                document.getElementById('sessionName').value = s.SessionName;
                document.getElementById('sessionCode').value = s.SessionCode;
                document.getElementById('sessionType').value = s.SessionTypeId;
                document.getElementById('startDate').value = s.StartDate ? s.StartDate.substring(0, 10) : '';
                document.getElementById('endDate').value = s.EndDate ? s.EndDate.substring(0, 10) : '';
                document.getElementById('academicYear').value = s.AcademicYear || '';
                document.getElementById('maxCredits').value = s.MaxCredits || 24;
                document.getElementById('sessionStatus').value = s.Status || 'Draft';
                calculateDuration();
            });
    }

    function viewSession(id) {
        fetch('/AcademicSetup/GetAcademicSession?id=' + id)
            .then(res => res.json())
            .then(s => {
                alert(
                    'Session: ' + s.SessionName + '\n' +
                    'Code: ' + s.SessionCode + '\n' +
                    'Start: ' + s.StartDate.substring(0, 10) + '\n' +
                    'End: ' + s.EndDate.substring(0, 10) + '\n' +
                    'Status: ' + s.Status
                );
            });
    }

    // ===================== STEP 2 : ACTIVATE (AJAX -> Controller) =====================
    function openActivateStep(id, name) {
        activeWizardSessionId = id;
        document.getElementById('sessionToActivateName').textContent = name;
        showWizard();
        goToStep(2);
        updateStepper(2, 1);
    }

    function activateSession() {
        if (!activeWizardSessionId) { showToast('No session selected', 'error'); return; }

        fetch('/AcademicSetup/ActivateAcademicSession', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + activeWizardSessionId
        })
            .then(res => res.json())
            .then(data => {
                showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) {
                    document.getElementById('sessionToCloseName').textContent = document.getElementById('sessionToActivateName').textContent;
                    goToStep(3);
                    updateStepper(3, 2);
                }
            })
            .catch(() => showToast('Server error while activating session', 'error'));
    }

    // ===================== STEP 3 : CLOSE (AJAX -> Controller) =====================
    function openCloseStep(id, name) {
        activeWizardSessionId = id;
        document.getElementById('sessionToCloseName').textContent = name;
        showWizard();
        goToStep(3);
        updateStepper(3, 2);
    }

    function closeSession() {
        if (!activeWizardSessionId) { showToast('No session selected', 'error'); return; }

        fetch('/AcademicSetup/CloseAcademicSession', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + activeWizardSessionId
        })
            .then(res => res.json())
            .then(data => {
                showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) {
                    document.querySelectorAll('.as-page').forEach(p => p.classList.remove('active'));
                    document.getElementById('asPageDone').classList.add('active');
                    document.getElementById('doneMessage').textContent =
                        'The session "' + document.getElementById('sessionToCloseName').textContent + '" has been locked and archived.';
                    updateStepper(3, 3);
                }
            })
            .catch(() => showToast('Server error while closing session', 'error'));
    }

    // ===================== DELETE (AJAX -> Controller) =====================
    function deleteSession(id) {
        if (!confirm('Delete this session? This cannot be undone.')) return;

        fetch('/AcademicSetup/DeleteAcademicSession', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + id
        })
            .then(res => res.json())
            .then(data => {
                showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) setTimeout(() => location.reload(), 800);
            });
    }
</script>