@using System.Web.Helpers
@{
    ViewBag.Title = "HOD Management";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    var overview = ViewBag.DepartmentHODOverview;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/HODManagement.css" rel="stylesheet" />

<div class="hod-wrap">

    <!-- ===================== LIST VIEW ===================== -->
    <div id="hodListView" class="hod-card">
        <!-- Header -->
        <div class="hod-list-head">
            <div>
                <h2><i class="fas fa-user-tie"></i> HOD Management</h2>
                <p>Assign, change and track Heads of Department across all departments.</p>
            </div>
            <div class="hod-header-actions">
                <button class="hod-btn hod-btn-primary" onclick="showForm('assign')">
                    <i class="fas fa-plus-circle"></i> Assign New HOD
                </button>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="hod-quick-stats">
            <div class="hod-stat-card">
                <div class="hod-stat-icon"><i class="fas fa-building"></i></div>
                <div class="hod-stat-info">
                    <span class="hod-stat-number" id="totalDepts">0</span>
                    <span class="hod-stat-label">Total Departments</span>
                </div>
            </div>
            <div class="hod-stat-card">
                <div class="hod-stat-icon"><i class="fas fa-user-check"></i></div>
                <div class="hod-stat-info">
                    <span class="hod-stat-number" id="hodAssigned">0</span>
                    <span class="hod-stat-label">HOD Assigned</span>
                </div>
            </div>
            <div class="hod-stat-card">
                <div class="hod-stat-icon"><i class="fas fa-user-slash"></i></div>
                <div class="hod-stat-info">
                    <span class="hod-stat-number" id="hodVacant">0</span>
                    <span class="hod-stat-label">Vacant Positions</span>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="hod-table-toolbar">
            <div class="hod-search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search by department, HOD name, or faculty..." id="hodSearch">
            </div>
            <div class="hod-filter-group">
                <select id="filterStatus">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Vacant">Vacant</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <div class="hod-table-scroll">
            <table class="hod-table" id="hodTable">
                <thead>
                    <tr>
                        <th>Department</th>
                        <th>HOD Name</th>
                        <th>Employee ID</th>
                        <th>Faculty</th>
                        <th>Effective Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="hodTableBody"></tbody>
            </table>
        </div>

        <!-- Legend -->
        <div class="hod-legend">
            <span><span class="hod-legend-dot active"></span> Active</span>
            <span><span class="hod-legend-dot vacant"></span> Vacant</span>
        </div>
    </div>

    <!-- ===================== FORM VIEW ===================== -->
    <div id="hodFormView" class="hod-card hod-form-card" style="display:none;">

        <div class="hod-back-row">
            <button class="hod-back-link" onclick="showList()">
                <i class="fas fa-arrow-left"></i> Back to HOD List
            </button>
        </div>

        <div class="hod-form-head">
            <div class="hod-form-icon"><i class="fas fa-user-tie"></i></div>
            <div>
                <h2 id="hodFormTitle">Assign HOD</h2>
                <p id="hodFormSubtitle">Select a department and assign a Head of Department.</p>
            </div>
        </div>

        <!-- Current HOD Display -->
        <div id="currentHodBlock" class="hod-current-hod" style="display:none;">
            <div class="hod-current-avatar" id="curAvt">-</div>
            <div class="hod-current-info">
                <p class="hod-current-name" id="curName">-</p>
                <p class="hod-current-meta" id="curMeta">-</p>
            </div>
            <span class="hod-pill hod-pill-active" id="curStatus">Active</span>
        </div>

        <!-- Form Fields -->
        <div class="hod-section-title">
            <i class="fas fa-info-circle"></i> Department Information
        </div>
        <div class="hod-grid">
            <div class="hod-field">
                <label>Department <span class="req">*</span></label>
                <select id="deptSelect" onchange="onDeptChange()">
                    <option value="">-- Select Department --</option>
                </select>
                <span class="hod-hint">Managed from Department Management</span>
            </div>
            <div class="hod-field">
                <label>Faculty</label>
                <input id="facultyField" type="text" placeholder="Auto-filled from department" readonly>
            </div>
        </div>

        <div class="hod-section-title">
            <i class="fas fa-user"></i> HOD Details
        </div>
        <div class="hod-grid">
            <div class="hod-field">
                <label>HOD Name <span class="req">*</span></label>
                <input id="hodName" type="text" placeholder="e.g. Dr. Ramesh Kumar">
            </div>
            <div class="hod-field">
                <label>Employee ID <span class="req">*</span></label>
                <input id="empId" type="text" placeholder="e.g. EMP-1042">
            </div>
            <div class="hod-field">
                <label>Designation</label>
                <select id="designation">
                    <option value="">-- Select Designation --</option>
                    <option>Professor</option>
                    <option>Associate Professor</option>
                    <option>Assistant Professor</option>
                    <option>Senior Lecturer</option>
                    <option>Reader</option>
                </select>
            </div>
            <div class="hod-field">
                <label>Contact Email <span class="req">*</span></label>
                <input id="hodEmail" type="email" placeholder="hod@university.edu">
            </div>
            <div class="hod-field">
                <label>Phone Number</label>
                <input id="hodPhone" type="tel" placeholder="+1 234 567 890">
            </div>
            <div class="hod-field">
                <label>Qualification</label>
                <input id="hodQualification" type="text" placeholder="e.g. Ph.D., M.Tech">
            </div>
        </div>

        <div class="hod-section-title">
            <i class="fas fa-calendar-check"></i> Assignment Details
        </div>
        <div class="hod-grid">
            <div class="hod-field">
                <label>Effective Date <span class="req">*</span></label>
                <input id="effDate" type="date">
                <span class="hod-hint">Date from which this HOD assignment takes effect.</span>
            </div>
            <div class="hod-field">
                <label>Tenure End Date <span class="optional">(optional)</span></label>
                <input id="tenureEnd" type="date">
                <span class="hod-hint">Expected end date of HOD tenure.</span>
            </div>
            <div class="hod-field">
                <label>Status</label>
                <div class="hod-toggle-row">
                    <label class="hod-switch">
                        <input type="checkbox" id="statusToggle" checked onchange="updateStatusLabel()">
                        <span class="hod-slider"></span>
                    </label>
                    <span class="hod-status-label hod-active" id="statusLabel">Active</span>
                </div>
            </div>
        </div>

        <div class="hod-section-title">
            <i class="fas fa-pen"></i> Change Reason
        </div>
        <div class="hod-grid">
            <div class="hod-field hod-full">
                <label>Reason for Change</label>
                <textarea id="reason" rows="3" placeholder="e.g. Promotion, transfer, term completion, resignation, new appointment..."></textarea>
            </div>
        </div>

        <!-- History Section -->
        <div id="historySection" class="hod-history-section">
            <div class="hod-section-title">
                <i class="fas fa-history"></i> HOD History
            </div>
            <div class="hod-history-box">
                <table class="hod-history-table">
                    <thead>
                        <tr>
                            <th>HOD Name</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Reason</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="historyBody">
                        <tr>
                            <td colspan="5" style="text-align:center; color:#94a3b8; padding:20px;">
                                <i class="fas fa-info-circle"></i> Select a department to view HOD history
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="hod-form-footer">
            <button class="hod-btn hod-btn-ghost" onclick="showList()">
                <i class="fas fa-times"></i> Cancel
            </button>
            <span></span>
            <button class="hod-btn hod-btn-primary" onclick="saveHod()">
                <i class="fas fa-save"></i> Save HOD Mapping
            </button>
        </div>
    </div>

</div>

<!-- Toast Notification -->
<div class="hod-toast" id="hodToast">
    <i class="fas fa-check-circle"></i>
    <span id="hodToastMessage">Success!</span>
</div>

<script>
    // ===== DATA STORE — seeded from real DB via controller, same shape the original JS expected =====
    const departments = @Html.Raw(Json.Encode(overview));

    // ===== UTILITY FUNCTIONS =====
    function getInitials(name) {
        if (!name || name === "-") return "-";
        return name.replace(/Dr\.\s*|Prof\.\s*/, "")
            .split(" ")
            .map(w => w[0])
            .join("")
            .slice(0, 2)
            .toUpperCase();
    }

    function getStatusClass(status) {
        const map = { 'Active': 'hod-pill-active', 'Vacant': 'hod-pill-vacant', 'Completed': 'hod-pill-completed' };
        return map[status] || 'hod-pill-vacant';
    }

    function getStatusDot(status) {
        const map = { 'Active': '🟢', 'Vacant': '🔴', 'Completed': '🔵' };
        return map[status] || '⚪';
    }

    function formatDate(dateStr) {
        if (!dateStr || dateStr === "-") return "-";
        const d = new Date(dateStr);
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    }

    // ===== RENDER LIST =====
    function renderList() {
        const body = document.getElementById("hodTableBody");
        body.innerHTML = departments.map(d => `
            <tr>
                <td><span class="hod-dept-name"><i class="fas fa-building"></i> ${d.Dept}</span></td>
                <td>
                    ${d.Hod === "-"
                ? '<span class="hod-unassigned"><i class="fas fa-user-slash"></i> Not Assigned</span>'
                : `<span class="hod-hod-name">${d.Hod}</span>`
            }
                </td>
                <td>${d.EmpId === "-" ? '<span class="hod-muted">-</span>' : d.EmpId}</td>
                <td><span class="hod-faculty-badge">${d.Faculty}</span></td>
                <td>${d.Date === "-" ? '<span class="hod-muted">-</span>' : formatDate(d.Date)}</td>
                <td><span class="hod-pill ${getStatusClass(d.Status)}">${getStatusDot(d.Status)} ${d.Status}</span></td>
                <td class="hod-actions">
                    ${d.Hod === "-"
                ? `<button class="hod-btn hod-btn-sm hod-btn-primary" onclick="showForm('assign','${d.DeptId}')">
                            <i class="fas fa-user-plus"></i> Assign
                           </button>`
                : `<button class="hod-mini-btn hod-mini-view" onclick="showForm('view','${d.DeptId}')" title="View Details">
                            <i class="fas fa-eye"></i>
                           </button>
                           <button class="hod-mini-btn hod-mini-edit" onclick="showForm('change','${d.DeptId}')" title="Change HOD">
                            <i class="fas fa-user-edit"></i>
                           </button>`
            }
                </td>
            </tr>
        `).join("");
        updateStats();
    }

    function updateStats() {
        const total = departments.length;
        const assigned = departments.filter(d => d.Hod !== "-").length;
        const vacant = departments.filter(d => d.Hod === "-").length;

        document.getElementById('totalDepts').textContent = total;
        document.getElementById('hodAssigned').textContent = assigned;
        document.getElementById('hodVacant').textContent = vacant;
    }

    function populateDeptSelect() {
        const sel = document.getElementById("deptSelect");
        sel.innerHTML = '<option value="">-- Select Department --</option>' +
            departments.map(d => `<option value="${d.DeptId}">${d.Dept}</option>`).join("");
    }

    // ===== SHOW/HIDE =====
    function showList() {
        document.getElementById("hodListView").style.display = 'block';
        document.getElementById("hodFormView").style.display = 'none';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showForm(mode, deptId) {
        document.getElementById("hodListView").style.display = 'none';
        document.getElementById("hodFormView").style.display = 'block';

        document.getElementById("hodName").value = "";
        document.getElementById("empId").value = "";
        document.getElementById("designation").value = "";
        document.getElementById("hodEmail").value = "";
        document.getElementById("hodPhone").value = "";
        document.getElementById("hodQualification").value = "";
        document.getElementById("effDate").value = "";
        document.getElementById("tenureEnd").value = "";
        document.getElementById("reason").value = "";
        document.getElementById("statusToggle").checked = true;
        updateStatusLabel();
        document.getElementById("currentHodBlock").style.display = 'none';

        const modeMap = {
            'assign': { title: 'Assign HOD', subtitle: 'Select a department and assign a new Head of Department.' },
            'change': { title: 'Change HOD', subtitle: 'Replace the current HOD with a new appointment.' },
            'view': { title: 'HOD Details', subtitle: 'View detailed information about the current HOD.' }
        };
        const selected = modeMap[mode] || modeMap['assign'];
        document.getElementById("hodFormTitle").textContent = selected.title;
        document.getElementById("hodFormSubtitle").textContent = selected.subtitle;

        const isView = mode === 'view';
        document.querySelectorAll('#hodFormView input, #hodFormView select, #hodFormView textarea').forEach(el => {
            el.disabled = isView;
        });
        document.querySelector('#hodFormView .hod-btn-primary').style.display = isView ? 'none' : 'inline-flex';

        if (deptId) {
            document.getElementById("deptSelect").value = deptId;
            document.getElementById("deptSelect").disabled = isView;
            onDeptChange(mode);
        } else {
            document.getElementById("deptSelect").value = "";
            document.getElementById("facultyField").value = "";
            document.getElementById("deptSelect").disabled = false;
            document.getElementById("historyBody").innerHTML = `
                <tr><td colspan="5" style="text-align:center; color:#94a3b8; padding:20px;">
                    <i class="fas fa-info-circle"></i> Select a department to view HOD history
                </td></tr>`;
        }

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ===== DEPARTMENT CHANGE =====
    function onDeptChange(mode) {
        const val = document.getElementById("deptSelect").value;
        if (!val) {
            document.getElementById("facultyField").value = "";
            document.getElementById("currentHodBlock").style.display = 'none';
            return;
        }

        const d = departments.find(x => String(x.DeptId) === String(val));
        if (!d) return;

        document.getElementById("facultyField").value = d.Faculty;

        if (d.Hod !== "-") {
            document.getElementById("currentHodBlock").style.display = 'flex';
            document.getElementById("curAvt").textContent = getInitials(d.Hod);
            document.getElementById("curName").textContent = d.Hod;
            document.getElementById("curMeta").textContent = `Since ${formatDate(d.Date)} · ${d.Email}`;
            document.getElementById("curStatus").textContent = d.Status;
            document.getElementById("curStatus").className = `hod-pill ${getStatusClass(d.Status)}`;

            if (mode === 'view' || mode === 'change') {
                document.getElementById("hodName").value = d.Hod;
                document.getElementById("empId").value = d.EmpId;
                document.getElementById("designation").value = d.Designation || '';
                document.getElementById("hodEmail").value = d.Email;
                document.getElementById("hodPhone").value = d.Phone || '';
                document.getElementById("hodQualification").value = d.Qualification || '';
                document.getElementById("effDate").value = d.Date;
                document.getElementById("tenureEnd").value = d.TenureEnd || '';
                document.getElementById("statusToggle").checked = d.Status === 'Active';
                updateStatusLabel();
            }
        } else {
            document.getElementById("currentHodBlock").style.display = 'none';
        }

        // History
        const hist = d.History || [];
        document.getElementById("historyBody").innerHTML = hist.length ? hist.map(h => `
            <tr>
                <td><strong>${h.Name}</strong></td>
                <td>${formatDate(h.From)}</td>
                <td>${formatDate(h.To)}</td>
                <td>${h.Reason}</td>
                <td><span class="hod-pill ${getStatusClass(h.Status)}">${getStatusDot(h.Status)} ${h.Status}</span></td>
            </tr>
        `).join("") : `
            <tr><td colspan="5" style="text-align:center; color:#94a3b8; padding:20px;">
                <i class="fas fa-info-circle"></i> No previous HOD history for this department
            </td></tr>`;
    }

    // ===== STATUS TOGGLE =====
    function updateStatusLabel() {
        const checked = document.getElementById("statusToggle").checked;
        const label = document.getElementById("statusLabel");
        label.textContent = checked ? "Active" : "Inactive";
        label.className = "hod-status-label " + (checked ? "hod-active" : "hod-inactive");
    }

    // ===== SAVE HOD (AJAX -> Controller) =====
    function saveHod() {
        const deptId = document.getElementById("deptSelect").value;
        const name = document.getElementById("hodName").value.trim();
        const eff = document.getElementById("effDate").value;
        const email = document.getElementById("hodEmail").value.trim();
        const empId = document.getElementById("empId").value.trim();

        if (!deptId) { showToast('Please select a department', 'error'); return; }
        if (!name) { showToast('Please enter HOD name', 'error'); return; }
        if (!eff) { showToast('Please select effective date', 'error'); return; }
        if (!email) { showToast('Please enter HOD email', 'error'); return; }

        const payload = {
            DepartmentId: parseInt(deptId),
            HODName: name,
            EmployeeId: empId,
            Designation: document.getElementById("designation").value,
            Qualification: document.getElementById("hodQualification").value,
            Email: email,
            Phone: document.getElementById("hodPhone").value,
            EffectiveDate: eff,
            TenureEndDate: document.getElementById("tenureEnd").value || null,
            ReasonForChange: document.getElementById("reason").value
        };

        fetch('/AcademicSetup/AssignHOD', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
            .then(res => res.json())
            .then(data => {
                showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) setTimeout(() => location.reload(), 800);
            })
            .catch(() => showToast('Server error while saving HOD', 'error'));
    }

    // ===== TOAST =====
    function showToast(msg, type) {
        const toast = document.getElementById('hodToast');
        const messageEl = document.getElementById('hodToastMessage');
        const icon = toast.querySelector('i');
        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' : 'fas fa-info-circle';
        toast.className = 'hod-toast show ' + (type || '');
        setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // ===== SEARCH & FILTER =====
    document.getElementById('hodSearch')?.addEventListener('input', function (e) {
        const searchTerm = e.target.value.toLowerCase();
        document.querySelectorAll('#hodTableBody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(searchTerm) ? '' : 'none';
        });
    });

    document.getElementById('filterStatus')?.addEventListener('change', function () {
        const statusFilter = this.value;
        document.querySelectorAll('#hodTableBody tr').forEach(row => {
            const status = row.children[5]?.textContent.trim() || '';
            row.style.display = (!statusFilter || status.includes(statusFilter)) ? '' : 'none';
        });
    });

    // ===== INIT =====
    populateDeptSelect();
    renderList();
</script>
