
@{
    ViewBag.Title = "ProgramManagement";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}



<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="prgListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-layer-group"></i> Program Management</h2>
                <p>Manage all academic programs — UG, PG, Diploma &amp; Certificate.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="prgShowForm()">
                <i class="fas fa-plus-circle"></i> Add New Program
            </button>
        </div>

        <!-- Program Dashboard -->
        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-layer-group"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number" id="prgTotalPrograms">4</span>
                    <span class="as-stat-label">Total Programs</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number" id="prgActivePrograms">4</span>
                    <span class="as-stat-label">Active Programs</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-users"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number" id="prgTotalStudents">5,234</span>
                    <span class="as-stat-label">Total Students</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-book"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number" id="prgTotalCourses">156</span>
                    <span class="as-stat-label">Total Courses</span>
                </div>
            </div>
        </div>

        <!-- Program List -->
        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Program Name</th>
                        <th>Program Type</th>
                        <th>Typical Duration</th>
                        <th>Total Courses</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="prgTableBody">
                    <tr>
                        <td><strong>Undergraduate</strong></td>
                        <td><span class="as-type-badge">UG</span></td>
                        <td>3–4 Years</td>
                        <td>62</td>
                        <td><span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td>
                            <button class="as-mini-btn" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="as-mini-btn" title="Edit" onclick="prgShowForm(this)"><i class="fas fa-edit"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Postgraduate</strong></td>
                        <td><span class="as-type-badge">PG</span></td>
                        <td>2 Years</td>
                        <td>48</td>
                        <td><span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td>
                            <button class="as-mini-btn" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="as-mini-btn" title="Edit" onclick="prgShowForm(this)"><i class="fas fa-edit"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Diploma</strong></td>
                        <td><span class="as-type-badge">Diploma</span></td>
                        <td>1–3 Years</td>
                        <td>28</td>
                        <td><span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td>
                            <button class="as-mini-btn" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="as-mini-btn" title="Edit" onclick="prgShowForm(this)"><i class="fas fa-edit"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Certificate Programs</strong></td>
                        <td><span class="as-type-badge">Certificate</span></td>
                        <td>3–12 Months</td>
                        <td>18</td>
                        <td><span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                        <td>
                            <button class="as-mini-btn" title="View Details"><i class="fas fa-eye"></i></button>
                            <button class="as-mini-btn" title="Edit" onclick="prgShowForm(this)"><i class="fas fa-edit"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot archived"></span> Inactive</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT PROGRAM FORM ================= -->
    <div class="as-card as-wizard-card" id="prgFormWrap" style="display:none;">

        <div class="as-back-row">
            <button class="as-back-link" onclick="prgShowList()">
                <i class="fas fa-arrow-left"></i> Back to Programs List
            </button>
        </div>

        <div class="as-body">
            <div class="as-page active">
                <div class="as-head">
                    <div class="as-icon"><i class="fas fa-layer-group"></i></div>
                    <div>
                        <h2 id="prgFormTitle">Add Program</h2>
                        <p>Define a new academic program category.</p>
                    </div>
                </div>

                <div class="as-section-title">
                    <i class="fas fa-info-circle"></i> Basic Information
                </div>
                <div class="as-grid">
                    <div class="as-field as-full">
                        <label>Program Name <span class="req">*</span></label>
                        <input type="text" id="programName" placeholder="e.g. Undergraduate (UG)">
                    </div>

                    <div class="as-field">
                        <label>Program Code <span class="req">*</span></label>
                        <input type="text" id="programCode" placeholder="e.g. UG">
                    </div>

                    <div class="as-field">
                        <label>Program Type <span class="req">*</span></label>
                        <select id="programTypeSelect" onchange="prgUpdateDuration()">
                            <option value="">-- Select Program Type --</option>
                            <option value="UG">Undergraduate (UG) — e.g. B.Tech, BCA, B.Sc, BA, B.Com, B.Pharm</option>
                            <option value="PG">Postgraduate (PG) — e.g. MBA, MCA, M.Tech, M.Sc, MA</option>
                            <option value="Diploma">Diploma — e.g. Polytechnic, Diploma in Pharmacy</option>
                            <option value="Certificate">Certificate — e.g. Data Science, AI, Cyber Security Certificate</option>
                        </select>
                    </div>

                    <div class="as-field">
                        <label>Typical Duration</label>
                        <input type="text" id="programDuration" placeholder="Auto-filled based on Program Type" readonly>
                        <span class="as-hint">UG: 3–4 Yrs · PG: 2 Yrs · Diploma: 1–3 Yrs · Certificate: 3–12 Months</span>
                    </div>

                    <div class="as-field">
                        <label>Academic Department</label>
                        <select id="programDepartment">
                            <option value="">-- Select Department --</option>
                            <option value="Computer Science">Computer Science</option>
                            <option value="Physics">Physics</option>
                            <option value="Management">Management</option>
                            <option value="Pharmacy">Pharmacy</option>
                        </select>
                    </div>

                    <div class="as-field">
                        <label>Status</label>
                        <select id="programStatus">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>

                    <div class="as-field as-full">
                        <label>Description</label>
                        <textarea id="programDescription" rows="3" placeholder="Brief description about this program..."></textarea>
                    </div>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="prgShowList()">Cancel</button>
                    <span></span>
                    <button class="as-btn as-btn-primary" onclick="prgSaveProgram()">
                        <i class="fas fa-save"></i> Save Program
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Toast Notification -->
<div class="as-toast" id="prgToast">
    <i class="fas fa-check-circle"></i>
    <span id="prgToastMessage">Success!</span>
</div>

<script>function prgShowForm(btn) {
        document.getElementById('prgListWrap').style.display = 'none';
        document.getElementById('prgFormWrap').style.display = 'block';
        document.getElementById('prgFormTitle').textContent = btn ? 'Edit Program' : 'Add Program';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function prgShowList() {
        document.getElementById('prgFormWrap').style.display = 'none';
        document.getElementById('prgListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function prgUpdateDuration() {
        const type = document.getElementById('programTypeSelect').value;
        const map = {
            'UG': '3–4 Years',
            'PG': '2 Years',
            'Diploma': '1–3 Years',
            'Certificate': '3–12 Months'
        };
        document.getElementById('programDuration').value = map[type] || '';
    }

    function prgShowToast(msg, type) {
        const toast = document.getElementById('prgToast');
        const messageEl = document.getElementById('prgToastMessage');
        const icon = toast.querySelector('i');
        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' : 'fas fa-info-circle';
        toast.className = 'as-toast show ' + (type || '');
        setTimeout(() => toast.classList.remove('show'), 3000);
    }

    function prgSaveProgram() {
        const name = document.getElementById('programName').value.trim();
        if (!name) { prgShowToast('Program Name is required', 'error'); return; }

        const type = document.getElementById('programTypeSelect').value;
        if (!type) { prgShowToast('Please select a Program Type', 'error'); return; }

        prgShowToast('Program "' + name + '" saved successfully!', 'success');
        prgShowList();
    }</script>


