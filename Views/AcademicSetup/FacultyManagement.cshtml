@model List<Regis.Models.FacultyModel>

@{
    ViewBag.Title = "Faculty Management";
}
<link href="~/Content/CSS/Facultymanagement.css" rel="stylesheet" />


<div class="fm-wrap">

    @if (TempData["Success"] != null)
    {
        <div class="fm-toast show success" style="position:static; transform:none; margin-bottom:1rem; display:flex;">
            <i class="fa fa-check-circle"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="fm-toast show error" style="position:static; transform:none; margin-bottom:1rem; display:flex;">
            <i class="fa fa-times-circle"></i> @TempData["Error"]
        </div>
    }

    <!-- ===== HEADER ===== -->
    <div class="fm-card" id="facultyHeader">
        <div class="fm-list-head" style="margin-bottom:0;">
            <div>
                <h2><i class="fa fa-chalkboard-teacher"></i> Faculty Management</h2>
                <p>Manage faculty assignments across departments and branches</p>
            </div>
            <div class="fm-header-actions">
                <button type="button" id="btnShowAddForm" class="fm-btn fm-btn-primary">
                    <i class="fa fa-plus"></i> Add Faculty
                </button>
            </div>
        </div>
    </div>

    <!-- ===== FORM CARD (hidden by default) ===== -->
    <div class="fm-card" id="facultyFormCard" style="display:none;">

        <div class="fm-section-title">
            <i class="fa fa-user-plus"></i>
            <span id="formCardTitle">Add Faculty</span>
        </div>

        <form method="post"
              id="facultyForm"
              action="@Url.Action("FacultyManagement", "AcademicSetup")">

            <input type="hidden" id="FacultyId" name="FacultyId" value="0" />

            <div class="fm-grid">

                <!-- Faculty Name -->
                <div class="fm-field">
                    <label>Faculty Name <span class="req">*</span></label>
                    <select name="EmployeeId" id="EmployeeId" class="form-control" required>
                        <option value="">-- Select Faculty --</option>
                        @foreach (var item in ViewBag.Employees)
                        {
                            <option value="@item.EmployeeId">@item.FullName</option>
                        }
                    </select>
                    <span class="fm-error" id="err_EmployeeId"></span>
                </div>

                <!-- Department -->
                <div class="fm-field">
                    <label>Department <span class="req">*</span></label>
                    <select name="DepartmentId" id="DepartmentId" class="form-control" required>
                        <option value="">-- Select Department --</option>
                        @foreach (var item in ViewBag.Departments)
                        {
                            <option value="@item.DepartmentId">@item.DepartmentName</option>
                        }
                    </select>
                    <span class="fm-error" id="err_DepartmentId"></span>
                </div>

                <!-- Branch -->
                <div class="fm-field">
                    <label>Branch <span class="req">*</span></label>
                    <select name="BranchId" id="BranchId" class="form-control" required>
                        <option value="">-- Select Branch --</option>
                        @foreach (var item in ViewBag.Branches)
                        {
                            <option value="@item.BranchId">@item.BranchName</option>
                        }
                    </select>
                    <span class="fm-error" id="err_BranchId"></span>
                </div>

                <!-- Semester -->
                <div class="fm-field">
                    <label>Semester <span class="req">*</span></label>
                    <select name="SemesterId" id="SemesterId" class="form-control" required>
                        <option value="">-- Select Semester --</option>
                        @foreach (var item in ViewBag.Semesters)
                        {
                            <option value="@item.SemesterId">@item.SemesterName</option>
                        }
                    </select>
                    <span class="fm-error" id="err_SemesterId"></span>
                </div>

                <!-- Designation -->
                <div class="fm-field">
                    <label>Designation <span class="req">*</span></label>
                    <select name="DesignationId" id="DesignationId" class="form-control" required>
                        <option value="">-- Select Designation --</option>
                        @foreach (var item in ViewBag.Designations)
                        {
                            <option value="@item.DesignationId">@item.DesignationName</option>
                        }
                    </select>
                    <span class="fm-error" id="err_DesignationId"></span>
                </div>

                <!-- Status -->
                <div class="fm-field">
                    <label>Status <span class="req">*</span></label>
                    <select name="Status" id="Status" class="form-control" required>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>

            </div>

            <div class="fm-bar">
                <span class="fm-step-count">Fields marked <span class="req">*</span> are required</span>
                <div style="display:flex; gap:0.6rem;">
                    <button type="button" id="btnCancelForm" class="fm-btn fm-btn-outline">
                        Cancel
                    </button>
                    <button type="submit" class="fm-btn fm-btn-primary" id="btnSubmitForm">
                        <i class="fa fa-save"></i> Save
                    </button>
                </div>
            </div>

        </form>

    </div>

    <!-- ===== LIST CARD (visible by default) ===== -->
    <div class="fm-card" id="facultyListCard">

        <div class="fm-section-title"><i class="fa fa-list"></i> Faculty List</div>

        <div class="fm-table-toolbar">
            <div class="fm-search-box">
                <i class="fa fa-search"></i>
                <input type="text" id="fmSearchInput" placeholder="Search by faculty, department, branch..." />
            </div>
        </div>

        <div class="fm-table-wrapper">
            <table class="fm-table" id="fmTable">
                <thead>
                    <tr>
                        <th>Faculty Name</th>
                        <th>Department</th>
                        <th>Branch</th>
                        <th>Semester</th>
                        <th>Designation</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-facultyid="@item.FacultyId"
                            data-employeeid="@item.EmployeeId"
                            data-departmentid="@item.DepartmentId"
                            data-branchid="@item.BranchId"
                            data-semesterid="@item.SemesterId"
                            data-designationid="@item.DesignationId"
                            data-status="@item.Status">
                            <td>
                                <div class="fm-user-name">
                                    <div class="fm-avatar">
                                        @(item.FacultyName != null && item.FacultyName.Length > 0 ? item.FacultyName.Substring(0, 1).ToUpper() : "F")
                                    </div>
                                    @item.FacultyName
                                </div>
                            </td>
                            <td><span class="fm-dept-badge">@item.DepartmentName</span></td>
                            <td>@item.BranchName</td>
                            <td>@item.SemesterName</td>
                            <td>@item.DesignationName</td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="fm-pill fm-pill-active"><i class="fa fa-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="fm-pill fm-pill-inactive"><i class="fa fa-circle"></i> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex; gap:0.4rem;">
                                    <button type="button"
                                            class="fm-btn fm-btn-outline fm-btn-sm btnEditFaculty">
                                        <i class="fa fa-pen"></i> Edit
                                    </button>
                                    <a href="@Url.Action("DeleteFacultyMaster", "AcademicSetup", new { id = item.FacultyId })"
                                       class="fm-btn fm-btn-danger fm-btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this faculty?');">
                                        <i class="fa fa-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <p id="fmNoResult" style="display:none; text-align:center; color:#94a3b8; padding:1rem;">
            No matching faculty found.
        </p>

    </div>

</div>

<style>
    .fm-error {
        color: #dc2626;
        font-size: 0.75rem;
        display: none;
    }
</style>

<script>
    var formCard = document.getElementById('facultyFormCard');
    var listCard = document.getElementById('facultyListCard');
    var headerCard = document.getElementById('facultyHeader');
    var formTitle = document.getElementById('formCardTitle');
    var facultyForm = document.getElementById('facultyForm');

    function resetForm() {
        facultyForm.reset();
        document.getElementById('FacultyId').value = 0;
        ['EmployeeId', 'DepartmentId', 'BranchId', 'SemesterId', 'DesignationId'].forEach(function (id) {
            document.getElementById(id).style.borderColor = '#e2e8f0';
            document.getElementById('err_' + id).style.display = 'none';
        });
    }

    // ===== Form khulte hi list + header hide, sirf form dikhega =====
    function showForm(isEdit) {
        formTitle.textContent = isEdit ? 'Edit Faculty' : 'Add Faculty';
        listCard.style.display = 'none';
        headerCard.style.display = 'none';
        formCard.style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ===== Form band hote hi list + header wapas dikhega =====
    function hideForm() {
        formCard.style.display = 'none';
        listCard.style.display = 'block';
        headerCard.style.display = 'flex';
        resetForm();
    }

    // ===== Add Faculty button =====
    document.getElementById('btnShowAddForm').addEventListener('click', function () {
        resetForm();
        showForm(false);
    });

    // ===== Cancel button =====
    document.getElementById('btnCancelForm').addEventListener('click', function () {
        hideForm();
    });

    // ===== Edit button (per row) — prefill form from row data =====
    document.querySelectorAll('.btnEditFaculty').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var row = btn.closest('tr');

            document.getElementById('FacultyId').value = row.getAttribute('data-facultyid');

            var empSelect = document.getElementById('EmployeeId');
            var empId = row.getAttribute('data-employeeid');
            for (var i = 0; i < empSelect.options.length; i++) {
                if (empSelect.options[i].value === empId) {
                    empSelect.selectedIndex = i;
                    break;
                }
            }

            document.getElementById('DepartmentId').value = row.getAttribute('data-departmentid');
            document.getElementById('BranchId').value = row.getAttribute('data-branchid');
            document.getElementById('SemesterId').value = row.getAttribute('data-semesterid');
            document.getElementById('DesignationId').value = row.getAttribute('data-designationid');
            document.getElementById('Status').value = row.getAttribute('data-status');

            showForm(true);
        });
    });

    // ===== Simple client-side validation =====
    facultyForm.addEventListener('submit', function (e) {

        var fields = ['EmployeeId', 'DepartmentId', 'BranchId', 'SemesterId', 'DesignationId'];
        var isValid = true;

        fields.forEach(function (id) {
            var field = document.getElementById(id);
            var err = document.getElementById('err_' + id);

            if (!field.value) {
                field.style.borderColor = '#dc2626';
                err.textContent = 'This field is required.';
                err.style.display = 'block';
                isValid = false;
            } else {
                field.style.borderColor = '#e2e8f0';
                err.style.display = 'none';
            }
        });

        if (!isValid) {
            e.preventDefault();
        }
    });

    // ===== Search in list =====
    document.getElementById('fmSearchInput').addEventListener('keyup', function () {
        var value = this.value.toLowerCase();
        var rows = document.querySelectorAll('#fmTable tbody tr');
        var visibleCount = 0;

        rows.forEach(function (row) {
            var text = row.innerText.toLowerCase();
            var match = text.indexOf(value) > -1;
            row.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        document.getElementById('fmNoResult').style.display = visibleCount === 0 ? 'block' : 'none';
    });
</script>