
@{
    ViewBag.Title = "AcademicProgress";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="apListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-chart-line"></i> Academic Progress</h2>
                <p>Track semester-wise SGPA &amp; attendance for each student.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="apShowForm()">
                <i class="fas fa-plus-circle"></i> Add Progress Record
            </button>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Name</th>
                        <th>Semester</th>
                        <th>SGPA</th>
                        <th>Attendance %</th>
                        <th>Result Status</th>
                    </tr>
                </thead>
                <tbody id="apTableBody"></tbody>
            </table>
        </div>
    </div>

    <!-- ================= ADD PROGRESS FORM ================= -->
    <div class="as-card as-wizard-card" id="apFormWrap" style="display:none;">
        <div class="as-back-row">
            <button class="as-back-link" onclick="apShowList()"><i class="fas fa-arrow-left"></i> Back to Academic Progress</button>
        </div>
        <div class="as-body">
            <div class="as-page active">
                <div class="as-head">
                    <div class="as-icon"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <h2>Add Progress Record</h2>
                        <p>Select a student — their course auto-fetches from Student Records.</p>
                    </div>
                </div>

                <div class="as-section-title"><i class="fas fa-user"></i> Student</div>
                <div class="as-grid">
                    <div class="as-field">
                        <label>Student <span class="req">*</span></label>
                        <select id="apStudent" onchange="apLoadStudent()">
                            <option value="">-- Select Student --</option>
                        </select>
                    </div>
                    <div class="as-field"><label>Course (auto)</label><input type="text" id="apCourse" readonly disabled></div>
                </div>

                <div class="as-section-title"><i class="fas fa-book-open"></i> Semester Result</div>
                <div class="as-grid">
                    <div class="as-field">
                        <label>Semester <span class="req">*</span></label>
                        <select id="apSemester">
                            <option value="">-- Select Semester --</option>
                            <option value="1">Semester 1</option>
                            <option value="2">Semester 2</option>
                            <option value="3">Semester 3</option>
                        </select>
                    </div>
                    <div class="as-field">
                        <label>SGPA <span class="req">*</span></label>
                        <input type="number" id="apSgpa" step="0.01" min="0" max="10" placeholder="e.g. 8.4">
                    </div>
                    <div class="as-field">
                        <label>Attendance % <span class="req">*</span></label>
                        <input type="number" id="apAttendance" min="0" max="100" placeholder="e.g. 88">
                    </div>
                    <div class="as-field">
                        <label>Result Status</label>
                        <select id="apResult">
                            <option value="Pass">Pass</option>
                            <option value="Fail">Fail</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="apShowList()">Cancel</button>
                    <span></span>
                    <button class="as-btn as-btn-primary" onclick="apSaveProgress()"><i class="fas fa-save"></i> Save Progress</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="as-toast" id="apToast"><i class="fas fa-check-circle"></i><span id="apToastMessage">Success!</span></div>

<script>function getStudents() { return JSON.parse(localStorage.getItem('erp_students') || '[]'); }
    function getProgress() { return JSON.parse(localStorage.getItem('erp_academicProgress') || '[]'); }
    function saveProgress(arr) { localStorage.setItem('erp_academicProgress', JSON.stringify(arr)); }

    function apPopulateStudents() {
        const students = getStudents().filter(s => s.status === 'Active');
        document.getElementById('apStudent').innerHTML = '<option value="">-- Select Student --</option>' +
            students.map(s => `<option value="${s.studentId}" data-name="${s.name}" data-course="${s.courseName}">${s.studentId} — ${s.name}</option>`).join('');
    }

    function apLoadStudent() {
        const select = document.getElementById('apStudent');
        const opt = select.options[select.selectedIndex];
        document.getElementById('apCourse').value = opt.getAttribute('data-course') || '';
    }

    function apRender() {
        const records = getProgress();
        document.getElementById('apTableBody').innerHTML = records.map(r => `
            <tr>
                <td><strong>${r.studentId}</strong></td>
                <td>${r.name}</td>
                <td>Semester ${r.semester}</td>
                <td>${r.sgpa}</td>
                <td>${r.attendance}%</td>
                <td>${r.result === 'Pass'
                    ? '<span class="as-pill as-pill-active"><i class="fas fa-check-circle"></i> Pass</span>'
                    : r.result === 'Fail'
                    ? '<span class="as-pill as-pill-locked"><i class="fas fa-times-circle"></i> Fail</span>'
                    : '<span class="as-pill as-pill-draft"><i class="fas fa-clock"></i> Pending</span>'}</td>
            </tr>`).join('') || '<tr><td colspan="6" style="text-align:center; color:#6B7A99;">No progress records yet</td></tr>';
    }

    function apShowForm() {
        apPopulateStudents();
        document.getElementById('apListWrap').style.display = 'none';
        document.getElementById('apFormWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function apShowList() {
        document.getElementById('apFormWrap').style.display = 'none';
        document.getElementById('apListWrap').style.display = 'block';
        apRender();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function apShowToast(msg, type) {
        const toast = document.getElementById('apToast');
        toast.querySelector('span').textContent = msg;
        toast.className = 'as-toast show ' + (type || '');
        setTimeout(() => toast.classList.remove('show'), 3000);
    }

    function apSaveProgress() {
        const select = document.getElementById('apStudent');
        const studentId = select.value;
        if (!studentId) { apShowToast('Please select a Student', 'error'); return; }
        const semester = document.getElementById('apSemester').value;
        if (!semester) { apShowToast('Please select a Semester', 'error'); return; }
        const sgpa = document.getElementById('apSgpa').value;
        if (!sgpa) { apShowToast('Please enter SGPA', 'error'); return; }

        const opt = select.options[select.selectedIndex];
        const records = getProgress();
        records.push({
            studentId,
            name: opt.getAttribute('data-name'),
            semester,
            sgpa,
            attendance: document.getElementById('apAttendance').value || 0,
            result: document.getElementById('apResult').value
        });
        saveProgress(records);

        apShowToast('Progress record saved!', 'success');
        apShowList();
    }

    apRender();</script>


