
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}



@*
    University.cshtml - University Setup Page
    Registrar ERP · Light Theme
*@
<link href="~/Content/css/university.css" rel="stylesheet" />
@{
    ViewData["Title"] = "University Setup";
    ViewData["PageTitle"] = "University Setup";
    ViewData["ActiveMenu"] = "University";
    ViewData["ActiveSubMenu"] = "ViewAll";
}

<!-- ===== PAGE HEADER ===== -->
@*<div class="page-head">
    <h1><i class="fas fa-university"></i> University Setup</h1>
    <div class="user-badge">
        <i class="fas fa-user-shield" style="color:#64748b;"></i> Registrar
        <span class="avatar">R</span>
    </div>
</div>*@

<!-- ===== EMPTY STATE (No University) ===== -->
<div class="empty-state" id="emptyState">
    <div class="icon-big">🏛</div>
    <h2>No University Configured Yet</h2>
    <p>
        To start using the ERP, you need to create your university profile first.
        This will be the foundation for all academic, admission, and student modules.
    </p>
    <button class="btn-primary" onclick="openCreateUniversity()">
        <i class="fas fa-plus-circle"></i> Add University
    </button>
    <div style="margin-top: 1.2rem; font-size: 0.8rem; color: #94a3b8;">
        <i class="fas fa-info-circle"></i> You can always edit this later
    </div>
</div>

<!-- ===== UNIVERSITY LIST ===== -->
<div class="university-list" id="universityList">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
        <span style="font-weight: 600; color: #0b1b33; font-size: 0.95rem;">
            <i class="fas fa-list"></i> Configured Universities
            <span style="font-weight:400; color:#94a3b8; font-size:0.8rem; margin-left:0.3rem;" id="uniCount"></span>
        </span>
        <button class="btn-outline" style="padding: 0.3rem 1.2rem; font-size: 0.8rem;" onclick="openCreateUniversity()">
            <i class="fas fa-plus"></i> Add New
        </button>
    </div>
    <div id="universityContainer"></div>
</div>

<!-- ===== PROGRESS STEPS ===== -->
<div class="progress-steps">
    <span class="step" id="stepUniversity"><i class="far fa-circle"></i> University Profile</span>
    <span class="step"><i class="far fa-circle"></i> Academic Session</span>
    <span class="step"><i class="far fa-circle"></i> Faculty</span>
    <span class="step"><i class="far fa-circle"></i> Department</span>
    <span class="step"><i class="far fa-circle"></i> Program</span>
    <span class="step"><i class="far fa-circle"></i> Course</span>
    <span class="step"><i class="far fa-circle"></i> Semester</span>
    <span class="step"><i class="far fa-circle"></i> Subject</span>
    <span class="step"><i class="far fa-circle"></i> Seat Matrix</span>
</div>

<!-- ===== MASTERS SECTION ===== -->
<div class="master-section">
    <h3><i class="fas fa-database"></i> Masters (Reference Data)</h3>
    <p>These lookup tables are used across the ERP. Configured once, reused everywhere.</p>
    <div class="master-grid">
        <div class="tag"><i class="fas fa-tag"></i> Category (SC/ST/OBC/Gen)</div>
        <div class="tag"><i class="fas fa-flag"></i> Nationality</div>
        <div class="tag"><i class="fas fa-school"></i> Board / University</div>
        <div class="tag"><i class="fas fa-building"></i> Country / State / City</div>
        <div class="tag"><i class="fas fa-coins"></i> Fee Heads</div>
        <div class="tag"><i class="fas fa-percent"></i> Discount / Scholarship</div>
        <div class="tag"><i class="fas fa-user-tie"></i> Designation</div>
        <div class="tag"><i class="fas fa-cog"></i> System Settings</div>
    </div>
</div>

<!-- ===== MODAL (Add/Edit University) ===== -->
<div class="modal-overlay" id="universityModal">
    <div class="modal">
        <div class="modal-header">
            <h2><i class="fas fa-university"></i> <span id="modalTitle">Add University</span></h2>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <form id="universityForm" onsubmit="saveUniversity(event)">
            <div class="form-grid">
                <div class="field full">
                    <label><i class="fas fa-building-columns"></i> University Name <span class="req">*</span></label>
                    <input type="text" id="uniName" placeholder="e.g. Springfield University" required />
                </div>
                <div class="field">
                    <label><i class="fas fa-tag"></i> Short Name <span class="req">*</span></label>
                    <input type="text" id="uniShort" placeholder="e.g. SU" required />
                </div>
                <div class="field">
                    <label><i class="fas fa-barcode"></i> University Code <span class="req">*</span></label>
                    <input type="text" id="uniCode" placeholder="e.g. SPR-26" required />
                </div>
                <div class="field">
                    <label><i class="fas fa-layer-group"></i> Type <span class="req">*</span></label>
                    <select id="uniType" required>
                        <option value="">— Select —</option>
                        <option value="Public">Public</option>
                        <option value="Private">Private</option>
                        <option value="Deemed">Deemed University</option>
                        <option value="Central">Central University</option>
                        <option value="State">State University</option>
                    </select>
                </div>
                <div class="field">
                    <label><i class="fas fa-calendar-alt"></i> Established Year <span class="req">*</span></label>
                    <input type="number" id="uniEst" placeholder="e.g. 2005" min="1800" max="2099" required />
                </div>
                <div class="field">
                    <label><i class="fas fa-envelope"></i> Official Email <span class="req">*</span></label>
                    <input type="email" id="uniEmail" placeholder="registrar@university.edu" required />
                </div>
                <div class="field">
                    <label><i class="fas fa-phone-alt"></i> Contact Number <span class="req">*</span></label>
                    <input type="tel" id="uniPhone" placeholder="+1 234 567 890" required />
                </div>
                <div class="field">
                    <label><i class="fas fa-globe"></i> Website</label>
                    <input type="url" id="uniWebsite" placeholder="https://www.example.edu" />
                </div>
                <div class="field">
                    <label><i class="fas fa-file-invoice"></i> Tax / GST Number</label>
                    <input type="text" id="uniTax" placeholder="GSTIN 22AAAAA0000A1Z5" />
                </div>
                <div class="field">
                    <label><i class="fas fa-sitemap"></i> Affiliated University</label>
                    <input type="text" id="uniAffiliated" placeholder="e.g. State University of New York" />
                </div>
                <div class="field full">
                    <label><i class="fas fa-circle-check"></i> Status <span class="req">*</span></label>
                    <select id="uniStatus" required>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="form-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save University</button>
            </div>
        </form>
    </div>
</div>

<!-- ===== JAVASCRIPT ===== -->
<script>
    (function() {
        'use strict';

        // ----- Data Store -----
        let universities = [];
        let editingId = null;
        let idCounter = 1;

        // ----- DOM refs -----
        const emptyState = document.getElementById('emptyState');
        const universityList = document.getElementById('universityList');
        const universityContainer = document.getElementById('universityContainer');
        const uniCount = document.getElementById('uniCount');
        const modal = document.getElementById('universityModal');
        const modalTitle = document.getElementById('modalTitle');
        const form = document.getElementById('universityForm');

        function generateId() { return idCounter++; }

        // ----- Render -----
        function renderUniversities() {
            const container = universityContainer;
            container.innerHTML = '';

            if (universities.length === 0) {
                emptyState.style.display = 'block';
                universityList.classList.remove('visible');
                updateProgressStep(false);
                if (uniCount) uniCount.textContent = '(0)';
                return;
            }

            emptyState.style.display = 'none';
            universityList.classList.add('visible');
            updateProgressStep(true);
            if (uniCount) uniCount.textContent = `(${universities.length})`;

            universities.forEach((uni, index) => {
                const div = document.createElement('div');
                div.className = 'uni-item';
                div.style.animation = `fadeIn 0.3s ease ${index * 0.05}s`;
                const statusClass = uni.status === 'Active' ? '' : 'inactive';
                const statusIcon = uni.status === 'Active' ? '#22c55e' : '#ef4444';
                div.innerHTML = `
                    <div class="info">
                        <div class="uni-icon"><i class="fas fa-university"></i></div>
                        <div class="details">
                            <strong>${uni.name}</strong>
                            <div class="meta">
                                <span><i class="fas fa-tag"></i> ${uni.code}</span>
                                <span><i class="fas fa-calendar-alt"></i> Est. ${uni.estYear}</span>
                                <span><i class="fas fa-layer-group"></i> ${uni.type}</span>
                                <span><i class="fas fa-envelope"></i> ${uni.email}</span>
                                ${uni.phone ? `<span><i class="fas fa-phone"></i> ${uni.phone}</span>` : ''}
                                ${uni.website ? `<span><i class="fas fa-globe"></i> ${uni.website.replace(/^https?:\/\//, '')}</span>` : ''}
                                ${uni.tax ? `<span><i class="fas fa-file-invoice"></i> ${uni.tax}</span>` : ''}
                                ${uni.affiliated && uni.affiliated !== '—' ? `<span><i class="fas fa-sitemap"></i> ${uni.affiliated}</span>` : ''}
                            </div>
                        </div>
                    </div>
                    <div style="display:flex; align-items:center; gap:0.8rem; flex-wrap:wrap;">
                        <span class="status ${statusClass}">
                            <i class="fas fa-circle" style="font-size:0.4rem; color:${statusIcon};"></i>
                            ${uni.status}
                        </span>
                        <div class="actions">
                            <button class="edit-btn" onclick="editUniversity(${uni.id})" title="Edit">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button class="delete-btn" onclick="deleteUniversity(${uni.id})" title="Delete">
                                <i class="fas fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function updateProgressStep(hasUniversity) {
            const step = document.getElementById('stepUniversity');
            if (hasUniversity) {
                step.className = 'step done';
                step.innerHTML = '<i class="fas fa-check-circle"></i> University Profile';
            } else {
                step.className = 'step active';
                step.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> University Profile (pending)';
            }
        }

        // ----- Open Create -----
        window.openCreateUniversity = function() {
            editingId = null;
            modalTitle.textContent = 'Add University';
            form.reset();
            document.getElementById('uniStatus').value = 'Active';
            document.getElementById('uniType').value = '';
            modal.classList.add('open');
        };

        // ----- Open Edit -----
        window.editUniversity = function(id) {
            const uni = universities.find(u => u.id === id);
            if (!uni) return;

            editingId = id;
            modalTitle.textContent = 'Edit University';
            document.getElementById('uniName').value = uni.name;
            document.getElementById('uniShort').value = uni.shortName;
            document.getElementById('uniCode').value = uni.code;
            document.getElementById('uniType').value = uni.type;
            document.getElementById('uniEst').value = uni.estYear;
            document.getElementById('uniEmail').value = uni.email;
            document.getElementById('uniPhone').value = uni.phone;
            document.getElementById('uniWebsite').value = uni.website || '';
            document.getElementById('uniTax').value = uni.tax || '';
            document.getElementById('uniAffiliated').value = uni.affiliated || '';
            document.getElementById('uniStatus').value = uni.status;
            modal.classList.add('open');
        };

        window.closeModal = function() {
            modal.classList.remove('open');
            editingId = null;
        };

        // ----- Save -----
        window.saveUniversity = function(e) {
            e.preventDefault();

            const name = document.getElementById('uniName').value.trim();
            const shortName = document.getElementById('uniShort').value.trim();
            const code = document.getElementById('uniCode').value.trim();
            const type = document.getElementById('uniType').value;
            const estYear = document.getElementById('uniEst').value;
            const email = document.getElementById('uniEmail').value.trim();
            const phone = document.getElementById('uniPhone').value.trim();
            const website = document.getElementById('uniWebsite').value.trim();
            const tax = document.getElementById('uniTax').value.trim();
            const affiliated = document.getElementById('uniAffiliated').value.trim();
            const status = document.getElementById('uniStatus').value;

            if (!name || !shortName || !code || !type || !estYear || !email || !phone) {
                alert('Please fill in all required fields.');
                return;
            }

            if (editingId) {
                const index = universities.findIndex(u => u.id === editingId);
                if (index !== -1) {
                    universities[index] = {
                        ...universities[index],
                        name, shortName, code, type, estYear, email, phone,
                        website, tax, affiliated, status
                    };
                }
                alert('✅ University updated successfully!');
            } else {
                const newUni = {
                    id: generateId(),
                    name, shortName, code, type, estYear, email, phone,
                    website, tax, affiliated, status
                };
                universities.push(newUni);
                alert('✅ University added successfully!');
            }

            closeModal();
            renderUniversities();
        };

        // ----- Delete -----
        window.deleteUniversity = function(id) {
            const uni = universities.find(u => u.id === id);
            if (!uni) return;
            if (!confirm(`Are you sure you want to delete "${uni.name}"?`)) return;

            universities = universities.filter(u => u.id !== id);
            renderUniversities();
            alert('🗑️ University deleted.');
        };

        // ----- Modal close on overlay / escape -----
        modal.addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        // ----- Inject animation -----
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes fadeIn {
                from { opacity: 0; transform: translateY(-8px); }
                to { opacity: 1; transform: translateY(0); }
            }
        `;
        document.head.appendChild(style);

        // ----- Initial render (with sample data for demo) -----
        // Remove this block for a completely fresh empty state
        setTimeout(() => {
            if (universities.length === 0) {
                universities.push({
                    id: generateId(),
                    name: 'Springfield University',
                    shortName: 'SU',
                    code: 'SPR-26',
                    type: 'Public',
                    estYear: '2005',
                    email: 'info@springfield.edu',
                    phone: '+1 555 0123 456',
                    website: 'https://springfield.edu',
                    tax: 'GSTIN 12ABCDE1234F1Z',
                    affiliated: 'State University System',
                    status: 'Active'
                });
                renderUniversities();
            }
        }, 100);

        // Expose render for debugging
        window.renderUniversities = renderUniversities;

    })();
</script>