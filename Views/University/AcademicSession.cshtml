
@{
    ViewBag.Title = "AcademicSession";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
<link href="~/Content/Academicsession.css" rel="stylesheet" />


<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">


<div class="as-wrap">

    <div class="as-card">

        <!-- STEPPER -->
        <div class="as-stepper">
            <div class="as-step-line">
                <div class="as-step-line-fill" id="stepLineFill"></div>
            </div>
            <div class="as-step" id="stepIndicator1">
                <div class="as-step-circle">1</div>
                <div class="as-step-label">Add</div>
            </div>
            <div class="as-step" id="stepIndicator2">
                <div class="as-step-circle">2</div>
                <div class="as-step-label">Activate</div>
            </div>
            <div class="as-step" id="stepIndicator3">
                <div class="as-step-circle">3</div>
                <div class="as-step-label">Close</div>
            </div>
        </div>

        <div class="as-body">

            <!-- ================= STEP 1 : ADD SESSION ================= -->
            <div class="as-page active" id="asPage1">
                <div class="as-head">
                    <div class="as-icon">🗓</div>
                    <div>
                        <h2>Create Academic Session</h2>
                        <p>Define a new academic session for the university.</p>
                    </div>
                </div>

                <div class="as-grid">
                    <div class="as-field as-full">
                        <label>👤 Session Name <span class="req">*</span></label>
                        <input type="text" id="sessionName" placeholder="e.g. 2026-27">
                    </div>

                    <div class="as-field">
                        <label>📅 Start Date <span class="req">*</span></label>
                        <input type="date" id="startDate" value="2026-04-01">
                    </div>

                    <div class="as-field">
                        <label>📅 End Date <span class="req">*</span></label>
                        <input type="date" id="endDate" value="2027-03-31">
                    </div>

                    <div class="as-field">
                        <label>📚 Session Type</label>
                        <select id="sessionType">
                            <option>Annual</option>
                            <option>Semester</option>
                            <option>Trimester</option>
                            <option>Quarterly</option>
                        </select>
                    </div>

                    <div class="as-field">
                        <label>⚙ Status</label>
                        <select id="sessionStatus">
                            <option>Active</option>
                            <option>Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="as-bar">
                    <span></span>
                    <div class="as-step-count">Step 1 of 3</div>
                    <button class="as-btn as-btn-primary" onclick="saveSession()">
                        <span class="as-check">✔</span> Save &amp; Continue
                    </button>
                </div>
            </div>

            <!-- ================= STEP 2 : ACTIVATE SESSION ================= -->
            <div class="as-page" id="asPage2">
                <div class="as-head">
                    <div class="as-icon">⚡</div>
                    <div>
                        <h2>Activate Session</h2>
                        <p>Only one session should normally be active at a time.</p>
                    </div>
                </div>

                <table class="as-table">
                    <thead>
                        <tr>
                            <th>Session</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="sessionTableBody">
                        <tr>
                            <td>2025-26</td>
                            <td><span class="as-pill as-pill-active">Active</span></td>
                            <td><span class="as-pill as-pill-default">Default</span></td>
                        </tr>
                        <tr id="newSessionRow" style="display:none;">
                            <td id="newSessionName">2026-27</td>
                            <td><span class="as-pill as-pill-inactive">Inactive</span></td>
                            <td><button class="as-mini-btn" onclick="activateRow()">Activate</button></td>
                        </tr>
                    </tbody>
                </table>

                <div class="as-check-group">
                    <label class="as-checkbox"><input type="checkbox" id="makeDefault"> Make Default Session</label>
                    <label class="as-checkbox"><input type="checkbox" id="lockPrevious"> Lock Previous Session</label>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="goToStep(1)">← Previous</button>
                    <div class="as-step-count">Step 2 of 3</div>
                    <button class="as-btn as-btn-primary" onclick="activateSession()">
                        <span class="as-check">✔</span> Activate Session
                    </button>
                </div>
            </div>

            <!-- ================= STEP 3 : CLOSE SESSION ================= -->
            <div class="as-page" id="asPage3">
                <div class="as-head">
                    <div class="as-icon">🔒</div>
                    <div>
                        <h2>Close Session</h2>
                        <p>Lock records and archive the previous academic session.</p>
                    </div>
                </div>

                <div class="as-current-session">
                    <span>Current Session</span>
                    <strong id="currentSessionLabel">2025-26</strong>
                </div>

                <div class="as-check-group as-check-col">
                    <label class="as-checkbox"><input type="checkbox" checked> Lock Student Records</label>
                    <label class="as-checkbox"><input type="checkbox" checked> Complete Promotion</label>
                    <label class="as-checkbox"><input type="checkbox" checked> Archive Session</label>
                    <label class="as-checkbox"><input type="checkbox" checked> Prevent Editing</label>
                    <label class="as-checkbox"><input type="checkbox" checked> Generate Session Reports</label>
                </div>

                <div class="as-bar">
                    <button class="as-btn as-btn-ghost" onclick="goToStep(2)">← Previous</button>
                    <div class="as-step-count">Step 3 of 3</div>
                    <button class="as-btn as-btn-danger" onclick="closeSession()">
                        <span class="as-check">✔</span> Close Session
                    </button>
                </div>
            </div>

            <!-- ================= DONE STATE ================= -->
            <div class="as-page" id="asPageDone">
                <div class="as-done">
                    <div class="as-done-icon">✔</div>
                    <h2>Session Closed Successfully</h2>
                    <p>2025-26 has been locked and archived. 2026-27 is now the active academic session.</p>
                    <button class="as-btn as-btn-primary" onclick="resetWizard()">Start New Session</button>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="as-toast" id="asToast"></div>

<script>
    let currentStep = 1;

    function showToast(msg) {
        const t = document.getElementById('asToast');
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2200);
    }

    function goToStep(n) {
        document.querySelectorAll('.as-page').forEach(p => p.classList.remove('active'));
        document.getElementById('asPage' + n).classList.add('active');
        currentStep = n;
        updateStepper(n);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateStepper(activeStep, completedUpto) {
        completedUpto = completedUpto || (activeStep - 1);
        for (let i = 1; i <= 3; i++) {
            const el = document.getElementById('stepIndicator' + i);
            const circle = el.querySelector('.as-step-circle');
            el.classList.remove('done', 'current');
            if (i <= completedUpto) {
                el.classList.add('done');
                circle.innerHTML = '✔';
            } else if (i === activeStep) {
                el.classList.add('current');
                circle.innerHTML = i;
            } else {
                circle.innerHTML = i;
            }
        }
        const pct = ((completedUpto) / 2) * 100;
        document.getElementById('stepLineFill').style.width = Math.min(pct, 100) + '%';
    }

    function saveSession() {
        const name = document.getElementById('sessionName').value.trim();
        if (!name) { showToast('Session Name is required'); return; }
        document.getElementById('newSessionName').textContent = name;
        showToast('Session saved successfully');
        goToStep(2);
        updateStepper(2, 1);
    }

    function activateRow() {
        document.getElementById('newSessionRow').style.display = 'table-row';
    }

    function activateSession() {
        activateRow();
        showToast('Session activated');
        goToStep(3);
        updateStepper(3, 2);
    }

    function closeSession() {
        document.querySelectorAll('.as-page').forEach(p => p.classList.remove('active'));
        document.getElementById('asPageDone').classList.add('active');
        updateStepper(3, 3);
        showToast('Session closed successfully');
    }

    function resetWizard() {
        document.getElementById('sessionName').value = '';
        document.getElementById('newSessionRow').style.display = 'none';
        goToStep(1);
        updateStepper(1, 0);
    }

    updateStepper(1, 0);
</script>

