@model Regis.Models.UniversityProfileModel

@{
    ViewBag.Title = "UniversityForm";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
<link href="~/Content/CSS/uniForm.css" rel="stylesheet" />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="form-container">

    <!-- Header -->
    <div class="form-header">
        <h1><i class="fas fa-university"></i> University Setup</h1>
        <span class="step-badge"><i class="fas fa-flag-checkered"></i> Step <span id="currentStepDisplay">1</span> of 5</span>
    </div>

    <!-- Progress Bar -->
    <div class="progress-wrapper">
        <div class="progress-steps" id="progressSteps">
            <div class="step-dot active" data-step="0">
                <div class="dot">1</div>
                <span class="label">Profile</span>
            </div>
            <div class="step-dot" data-step="1">
                <div class="dot">2</div>
                <span class="label">Details</span>
            </div>
            <div class="step-dot" data-step="2">
                <div class="dot">3</div>
                <span class="label">Logo</span>
            </div>
            <div class="step-dot" data-step="3">
                <div class="dot">4</div>
                <span class="label">Address</span>
            </div>
            <div class="step-dot" data-step="4">
                <div class="dot">5</div>
                <span class="label">Contact</span>
            </div>
        </div>
        <div class="progress-fill" id="progressFill" style="width: 0%;"></div>
    </div>

    <!-- Steps Container -->
    @using (Html.BeginForm("UniversityForm", "University", FormMethod.Post, new { id = "universityForm", enctype = "multipart/form-data", novalidate = "novalidate" }))
    {
        @Html.HiddenFor(m => m.UniversityId)

        <div class="steps-container">

            <!-- ===== STEP 1: University Profile ===== -->
            <div class="step-panel active" data-step="0">
                <h2><i class="fas fa-id-card"></i> University Profile</h2>
                <p class="subtitle">Basic identity and core information about the university.</p>
                <div class="form-grid">
                    <div class="field full">
                        <label><i class="fas fa-building-columns"></i> University Name <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.UniversityName, new { id = "uniName", placeholder = "e.g. Springfield University", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-tag"></i> Short Name <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.ShortName, new { id = "uniShort", placeholder = "e.g. SU", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-barcode"></i> University Code <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.UniversityCode, new { id = "uniCode", placeholder = "e.g. SPR-26", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-layer-group"></i> University Type <span class="req">*</span></label>
                        @Html.DropDownListFor(m => m.UniversityTypeId, (SelectList)ViewBag.UniversityTypeList, "— Select —", new { id = "uniType", @class = "form-control", required = "required" })
                        <span class="hint"><i class="fas fa-info-circle"></i> Managed from University Type Master</span>
                    </div>
                    <div class="field">
                        <label><i class="fas fa-calendar-alt"></i> Established Year <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.EstablishedYear, new { id = "uniEst", type = "number", placeholder = "e.g. 2005", min = "1800", max = "2099", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-certificate"></i> Accreditation Details <span class="optional">(optional)</span></label>
                        @Html.TextBoxFor(m => m.Accreditation, new { id = "uniAccreditation", placeholder = "e.g. NAAC A++, NBA" })
                        <span class="hint"><i class="fas fa-info-circle"></i> Comma separated</span>
                    </div>
                    <div class="field">
                        <label><i class="fas fa-globe"></i> University Website</label>
                        @Html.TextBoxFor(m => m.Website, new { id = "uniWebsite", type = "url", placeholder = "https://www.example.edu" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-envelope"></i> Official Email <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.Email, new { id = "uniEmail", type = "email", placeholder = "registrar@university.edu", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-phone-alt"></i> Contact Number <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.Phone, new { id = "uniPhone", type = "tel", placeholder = "+1 234 567 890", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-file-invoice"></i> Tax / GST Number <span class="optional">(if applicable)</span></label>
                        @Html.TextBoxFor(m => m.TaxNumber, new { id = "uniTax", placeholder = "e.g. GSTIN 22AAAAA0000A1Z5" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-sitemap"></i> Affiliated University <span class="optional">(if applicable)</span></label>
                        @Html.TextBoxFor(m => m.AffiliatedUniversity, new { id = "uniAffiliated", placeholder = "e.g. State University of New York" })
                    </div>
                    <div class="field full">
                        <label><i class="fas fa-circle-check"></i> Status <span class="req">*</span></label>
                        @Html.DropDownListFor(m => m.IsActive, new List<SelectListItem>
                                {
                            new SelectListItem { Text = "Active", Value = "true", Selected = Model.IsActive },
                            new SelectListItem { Text = "Inactive", Value = "false", Selected = !Model.IsActive }
                        }, new { id = "uniStatus", @class = "form-control", required = "required" })
                    </div>
                </div>
            </div>

            <!-- ===== STEP 2: University Details ===== -->
            <div class="step-panel" data-step="1">
                <h2><i class="fas fa-info-circle"></i> University Details</h2>
                <p class="subtitle">General, legal, contact, and social media information.</p>

                <h3 style="font-size:0.9rem; font-weight:600; color:#0b1b33; margin:1rem 0 0.8rem; display:flex; align-items:center; gap:0.4rem;">
                    <i class="fas fa-file-pen" style="color:#4f6ef7;"></i> General Information
                </h3>
                <div class="form-grid">
                    <div class="field">
                        <label><i class="fas fa-quote-left"></i> Motto</label>
                        @Html.TextBoxFor(m => m.Motto, new { id = "detMotto", placeholder = "e.g. Knowledge is Power" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-eye"></i> Vision</label>
                        @Html.TextBoxFor(m => m.Vision, new { id = "detVision", placeholder = "e.g. To be a global leader in education" })
                    </div>
                    <div class="field full">
                        <label><i class="fas fa-bullseye"></i> Mission</label>
                        @Html.TextAreaFor(m => m.Mission, new { id = "detMission", placeholder = "Describe the university's mission..." })
                    </div>
                    <div class="field full">
                        <label><i class="fas fa-align-left"></i> Description</label>
                        @Html.TextAreaFor(m => m.Description, new { id = "detDescription", placeholder = "Brief description of the university..." })
                    </div>
                    <div class="field full">
                        <label><i class="fas fa-building"></i> About University</label>
                        @Html.TextAreaFor(m => m.AboutUniversity, new { id = "detAbout", placeholder = "Detailed about the university..." })
                    </div>
                </div>

                <h3 style="font-size:0.9rem; font-weight:600; color:#0b1b33; margin:1.5rem 0 0.8rem; display:flex; align-items:center; gap:0.4rem;">
                    <i class="fas fa-gavel" style="color:#4f6ef7;"></i> Legal Information
                </h3>
                <div class="form-grid">
                    <div class="field">
                        <label><i class="fas fa-registered"></i> Registration Number</label>
                        @Html.TextBoxFor(m => m.RegistrationNumber, new { id = "detRegNumber", placeholder = "e.g. REG-2024-001" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-certificate"></i> UGC Approval Number</label>
                        @Html.TextBoxFor(m => m.UGCApprovalNumber, new { id = "detUGC", placeholder = "e.g. UGC-APP-1234" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-check-circle"></i> AICTE Approval</label>
                        @Html.TextBoxFor(m => m.AICTEApproval, new { id = "detAICTE", placeholder = "e.g. AICTE-APP-5678" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-star"></i> NAAC Grade</label>
                        @Html.DropDownListFor(m => m.NAACGrade, new List<SelectListItem>
                                {
                            new SelectListItem { Text = "— Select —", Value = "" },
                            new SelectListItem { Text = "A++", Value = "A++" },
                            new SelectListItem { Text = "A+", Value = "A+" },
                            new SelectListItem { Text = "A", Value = "A" },
                            new SelectListItem { Text = "B++", Value = "B++" },
                            new SelectListItem { Text = "B+", Value = "B+" },
                            new SelectListItem { Text = "B", Value = "B" },
                            new SelectListItem { Text = "C", Value = "C" }
                        }, new { id = "detNAAC", @class = "form-control" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-trophy"></i> NIRF Rank</label>
                        @Html.TextBoxFor(m => m.NIRFRank, new { id = "detNIRF", placeholder = "e.g. 15" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-certificate"></i> ISO Certification</label>
                        @Html.TextBoxFor(m => m.ISOCertification, new { id = "detISO", placeholder = "e.g. ISO 9001:2015" })
                    </div>
                </div>

                <h3 style="font-size:0.9rem; font-weight:600; color:#0b1b33; margin:1.5rem 0 0.8rem; display:flex; align-items:center; gap:0.4rem;">
                    <i class="fas fa-phone" style="color:#4f6ef7;"></i> Contact Information
                </h3>
                <div class="form-grid">
                    <div class="field">
                        <label><i class="fas fa-phone"></i> Office Number</label>
                        @Html.TextBoxFor(m => m.OfficeNumber, new { id = "detOffice", type = "tel", placeholder = "+1 234 567 890" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-fax"></i> Fax Number</label>
                        @Html.TextBoxFor(m => m.FaxNumber, new { id = "detFax", type = "tel", placeholder = "+1 234 567 891" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-envelope"></i> Email</label>
                        @Html.TextBoxFor(m => m.DetailsEmail, new { id = "detEmail", type = "email", placeholder = "info@university.edu" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-globe"></i> Website</label>
                        @Html.TextBoxFor(m => m.DetailsWebsite, new { id = "detWebsite", type = "url", placeholder = "https://www.example.edu" })
                    </div>
                </div>

                <h3 style="font-size:0.9rem; font-weight:600; color:#0b1b33; margin:1.5rem 0 0.8rem; display:flex; align-items:center; gap:0.4rem;">
                    <i class="fas fa-share-alt" style="color:#4f6ef7;"></i> Social Media
                </h3>
                <div class="form-grid">
                    <div class="field">
                        <label><i class="fab fa-facebook"></i> Facebook</label>
                        @Html.TextBoxFor(m => m.Facebook, new { id = "detFacebook", type = "url", placeholder = "https://facebook.com/university" })
                    </div>
                    <div class="field">
                        <label><i class="fab fa-linkedin"></i> LinkedIn</label>
                        @Html.TextBoxFor(m => m.LinkedIn, new { id = "detLinkedIn", type = "url", placeholder = "https://linkedin.com/school/university" })
                    </div>
                    <div class="field">
                        <label><i class="fab fa-instagram"></i> Instagram</label>
                        @Html.TextBoxFor(m => m.Instagram, new { id = "detInstagram", type = "url", placeholder = "https://instagram.com/university" })
                    </div>
                    <div class="field">
                        <label><i class="fab fa-twitter"></i> Twitter</label>
                        @Html.TextBoxFor(m => m.Twitter, new { id = "detTwitter", type = "url", placeholder = "https://twitter.com/university" })
                    </div>
                </div>
            </div>

            <!-- ===== STEP 3: Logo Management ===== -->
            <div class="step-panel" data-step="2">
                <h2><i class="fas fa-image"></i> Logo Management</h2>
                <p class="subtitle">Upload your university branding assets. All files are optional.</p>
                <div class="file-upload-grid">
                    <div class="file-upload-item" onclick="document.getElementById('LogoMainFile').click()">
                        <i class="fas fa-university"></i>
                        <div class="file-label">@(string.IsNullOrEmpty(Model.LogoMainPath) ? "University Logo" : "Uploaded ✓ (replace)")</div>
                        <div class="file-hint">PNG, JPG, SVG · Max 2MB</div>
                        <input type="file" id="LogoMainFile" name="LogoMainFile" accept="image/*" />
                    </div>
                    <div class="file-upload-item" onclick="document.getElementById('LogoDarkFile').click()">
                        <i class="fas fa-moon"></i>
                        <div class="file-label">@(string.IsNullOrEmpty(Model.LogoDarkPath) ? "Dark Theme Logo" : "Uploaded ✓ (replace)")</div>
                        <div class="file-hint">PNG, JPG, SVG · Max 2MB</div>
                        <input type="file" id="LogoDarkFile" name="LogoDarkFile" accept="image/*" />
                    </div>
                    <div class="file-upload-item" onclick="document.getElementById('LogoLightFile').click()">
                        <i class="fas fa-sun"></i>
                        <div class="file-label">@(string.IsNullOrEmpty(Model.LogoLightPath) ? "Light Theme Logo" : "Uploaded ✓ (replace)")</div>
                        <div class="file-hint">PNG, JPG, SVG · Max 2MB</div>
                        <input type="file" id="LogoLightFile" name="LogoLightFile" accept="image/*" />
                    </div>
                    <div class="file-upload-item" onclick="document.getElementById('LogoSidebarFile').click()">
                        <i class="fas fa-bars"></i>
                        <div class="file-label">@(string.IsNullOrEmpty(Model.LogoSidebarPath) ? "Small Logo (Sidebar)" : "Uploaded ✓ (replace)")</div>
                        <div class="file-hint">PNG, JPG, SVG · Max 1MB</div>
                        <input type="file" id="LogoSidebarFile" name="LogoSidebarFile" accept="image/*" />
                    </div>
                    <div class="file-upload-item" onclick="document.getElementById('FaviconFile').click()" style="grid-column: 1 / -1; max-width: 300px; margin: 0 auto;">
                        <i class="fas fa-circle"></i>
                        <div class="file-label">@(string.IsNullOrEmpty(Model.FaviconPath) ? "Favicon" : "Uploaded ✓ (replace)")</div>
                        <div class="file-hint">ICO, PNG · 16x16 or 32x32</div>
                        <input type="file" id="FaviconFile" name="FaviconFile" accept="image/*" />
                    </div>
                </div>
                <div style="margin-top: 1rem; padding: 0.8rem 1rem; background: #f8fafc; border-radius: 14px; border: 1px solid #eef2f6;">
                    <span style="font-size:0.8rem; color:#64748b;"><i class="fas fa-info-circle"></i> Leave a slot empty to keep the previously uploaded file.</span>
                </div>
            </div>

            <!-- ===== STEP 4: Address ===== -->
            <div class="step-panel" data-step="3">
                <h2><i class="fas fa-map-pin"></i> Address</h2>
                <p class="subtitle">Complete physical address of the university.</p>
                <div class="form-grid">
                    <div class="field">
                        <label><i class="fas fa-flag"></i> Country <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.Country, new { id = "addrCountry", placeholder = "e.g. United States", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-map"></i> State <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.State, new { id = "addrState", placeholder = "e.g. California", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-map-pin"></i> District</label>
                        @Html.TextBoxFor(m => m.District, new { id = "addrDistrict", placeholder = "e.g. Los Angeles County" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-city"></i> City <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.City, new { id = "addrCity", placeholder = "e.g. Los Angeles", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-location-dot"></i> Area / Locality</label>
                        @Html.TextBoxFor(m => m.Area, new { id = "addrArea", placeholder = "e.g. Downtown" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-road"></i> Street</label>
                        @Html.TextBoxFor(m => m.Street, new { id = "addrStreet", placeholder = "e.g. 123 University Ave" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-hashtag"></i> Building Number</label>
                        @Html.TextBoxFor(m => m.BuildingNumber, new { id = "addrBuilding", placeholder = "e.g. 42" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-mailbox"></i> Postal Code <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.PostalCode, new { id = "addrPostal", placeholder = "e.g. 90001", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-crosshairs"></i> Latitude</label>
                        @Html.TextBoxFor(m => m.Latitude, new { id = "addrLat", placeholder = "e.g. 34.0522" })
                        <span class="hint">Decimal degrees</span>
                    </div>
                    <div class="field">
                        <label><i class="fas fa-crosshairs"></i> Longitude</label>
                        @Html.TextBoxFor(m => m.Longitude, new { id = "addrLng", placeholder = "e.g. -118.2437" })
                        <span class="hint">Decimal degrees</span>
                    </div>
                </div>
            </div>

            <!-- ===== STEP 5: Contact Details ===== -->
            <div class="step-panel" data-step="4">
                <h2><i class="fas fa-address-book"></i> Contact Details</h2>
                <p class="subtitle">Departmental and helpline contact information.</p>
                <div class="form-grid">
                    <div class="field">
                        <label><i class="fas fa-phone"></i> Office Number <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.ContOffice, new { id = "contOffice", type = "tel", placeholder = "+1 234 567 890", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-mobile-alt"></i> Mobile Number</label>
                        @Html.TextBoxFor(m => m.ContMobile, new { id = "contMobile", type = "tel", placeholder = "+1 234 567 891" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-phone"></i> Alternate Number</label>
                        @Html.TextBoxFor(m => m.ContAlternate, new { id = "contAlternate", type = "tel", placeholder = "+1 234 567 892" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-headset"></i> Admission Helpline <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.ContAdmissionHelpline, new { id = "contAdmission", type = "tel", placeholder = "+1 234 567 893", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-user-tie"></i> Registrar Office Number</label>
                        @Html.TextBoxFor(m => m.ContRegistrarOffice, new { id = "contRegistrar", type = "tel", placeholder = "+1 234 567 894" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-envelope"></i> Email <span class="req">*</span></label>
                        @Html.TextBoxFor(m => m.ContEmail, new { id = "contEmail", type = "email", placeholder = "contact@university.edu", required = "required" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-life-ring"></i> Support Email</label>
                        @Html.TextBoxFor(m => m.ContSupportEmail, new { id = "contSupport", type = "email", placeholder = "support@university.edu" })
                    </div>
                    <div class="field">
                        <label><i class="fas fa-globe"></i> Website</label>
                        @Html.TextBoxFor(m => m.ContWebsite, new { id = "contWebsite", type = "url", placeholder = "https://www.example.edu" })
                    </div>
                </div>
            </div>

        </div>

        <!-- Navigation -->
        <div class="form-nav">
            <button type="button" class="btn btn-prev" id="prevBtn" onclick="changeStep(-1)">
                <i class="fas fa-arrow-left"></i> Previous
            </button>
            <span class="step-indicator" id="stepIndicator">Step 1 of 5</span>
            <button type="button" class="btn btn-next" id="nextBtn" onclick="changeStep(1)">
                Next <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn btn-submit" id="submitBtn" style="display:none;">
                <i class="fas fa-check-circle"></i> Save University
            </button>
        </div>
    }
</div>

<script>
    (function () {
        let currentStep = 0;
        const totalSteps = 5;

        const panels = document.querySelectorAll('.step-panel');
        const dots = document.querySelectorAll('.step-dot');
        const progressFill = document.getElementById('progressFill');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');
        const stepIndicator = document.getElementById('stepIndicator');
        const currentStepDisplay = document.getElementById('currentStepDisplay');

        function updateUI() {
            panels.forEach((panel, index) => panel.classList.toggle('active', index === currentStep));

            dots.forEach((dot, index) => {
                dot.classList.remove('active', 'done');
                if (index === currentStep) dot.classList.add('active');
                else if (index < currentStep) dot.classList.add('done');
            });

            const progress = (currentStep / (totalSteps - 1)) * 100;
            progressFill.style.width = progress + '%';

            prevBtn.style.display = currentStep === 0 ? 'none' : 'inline-flex';
            nextBtn.style.display = currentStep === totalSteps - 1 ? 'none' : 'inline-flex';
            submitBtn.style.display = currentStep === totalSteps - 1 ? 'inline-flex' : 'none';

            const display = currentStep + 1;
            stepIndicator.textContent = `Step ${display} of ${totalSteps}`;
            if (currentStepDisplay) currentStepDisplay.textContent = display;
        }

        window.changeStep = function (direction) {
            const newStep = currentStep + direction;
            if (newStep < 0 || newStep >= totalSteps) return;
            currentStep = newStep;
            updateUI();
            document.querySelector('.form-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        dots.forEach((dot, index) => {
            dot.addEventListener('click', function () {
                if (index === currentStep) return;
                if (index < currentStep || index === currentStep + 1) {
                    currentStep = index;
                    updateUI();
                    document.querySelector('.form-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
                } else {
                    alert('Please complete the current step first.');
                }
            });
        });

        document.querySelectorAll('.file-upload-item input[type="file"]').forEach(input => {
            input.addEventListener('change', function () {
                const parent = this.closest('.file-upload-item');
                const label = parent.querySelector('.file-label');
                if (this.files.length > 0) {
                    label.textContent = this.files[0].name;
                    parent.style.borderColor = '#22c55e';
                    parent.style.background = '#f0fdf4';
                }
            });
        });

        updateUI();

        // ----- Validate ALL required fields (across all steps) before final submit -----
        document.getElementById('universityForm').addEventListener('submit', function (e) {
            const requiredFields = document.querySelectorAll('#universityForm [required]');
            let firstInvalid = null;

            requiredFields.forEach(field => {
                if (!field.value || !field.value.trim()) {
                    if (!firstInvalid) firstInvalid = field;
                }
            });

            if (firstInvalid) {
                e.preventDefault();

                // Jump to the step that contains the invalid field
                const panel = firstInvalid.closest('.step-panel');
                if (panel) {
                    const stepIndex = parseInt(panel.dataset.step, 10);
                    currentStep = stepIndex;
                    updateUI();
                    document.querySelector('.form-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
                }

                setTimeout(() => firstInvalid.focus(), 300);
                alert('Please fill "' + (firstInvalid.previousElementSibling ? firstInvalid.previousElementSibling.textContent.trim() : 'a required field') + '" before saving.');
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowRight' && !e.ctrlKey && !e.metaKey && currentStep < totalSteps - 1) {
                e.preventDefault();
                changeStep(1);
            } else if (e.key === 'ArrowLeft' && !e.ctrlKey && !e.metaKey && currentStep > 0) {
                e.preventDefault();
                changeStep(-1);
            }
        });
    })();
</script>
