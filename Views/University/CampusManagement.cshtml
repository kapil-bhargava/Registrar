@model List<Regis.Models.CampusModel>

@{
    ViewBag.Title = "CampusManagement";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/campusManagement.css" rel="stylesheet" />

<div class="cm-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="cm-card" id="cmListWrap">
        <div class="cm-list-head">
            <div>
                <h2>Campus Management</h2>
                <p>Manage all campuses under the university.</p>
            </div>
            <button class="cm-btn cm-btn-primary" onclick="showForm()">+ Add New Campus</button>
        </div>

        <table class="cm-table cm-list-table">
            <thead>
                <tr>
                    <th>Campus Name</th>
                    <th>Campus Code</th>
                    <th>Contact</th>
                    <th>Dean</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="campusTableBody">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="cm-name">@item.CampusName</td>
                        <td>@item.CampusCode</td>
                        <td>@item.ContactNumber</td>
                        <td>@item.Dean</td>
                        <td>@item.CampusTypeName</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="cm-pill cm-pill-active">Active</span>
                            }
                            else
                            {
                                <span class="cm-pill cm-pill-inactive">Inactive</span>
                            }
                        </td>
                        <td>
                            <button type="button"
                                    class="cm-mini-btn"
                                    onclick="showForm(this)"
                                    data-id="@item.CampusId"
                                    data-name="@item.CampusName"
                                    data-code="@item.CampusCode"
                                    data-typeid="@item.CampusTypeId"
                                    data-capacity="@item.Capacity"
                                    data-address="@item.Address"
                                    data-contact="@item.ContactNumber"
                                    data-email="@item.Email"
                                    data-dean="@item.Dean"
                                    data-active="@item.IsActive.ToString().ToLower()">
                                Edit
                            </button>
                            <a class="cm-mini-btn"
                               href="@Url.Action("DeleteCampus", "University", new { id = item.CampusId })"
                               onclick="return confirm('Are you sure you want to delete this campus?');">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ================= ADD / EDIT CAMPUS FORM ================= -->
    @using (Html.BeginForm("CampusManagement", "University", FormMethod.Post))
    {
        <div class="cm-card" id="cmFormWrap" style="display:none;">

            <div class="cm-back-row">
                <button type="button" class="cm-back-link" onclick="showList()">← Back to Campus List</button>
            </div>

            <div class="cm-body">
                <div class="cm-head">
                    <div class="cm-icon">🏫</div>
                    <div>
                        <h2 id="cmFormTitle">Add Campus</h2>
                        <p>Enter campus details, contact information and type.</p>
                    </div>
                </div>

                <input type="hidden" id="campusId" name="CampusId" value="0" />

                <div class="cm-section-lbl">Basic Information</div>
                <div class="cm-grid">
                    <div class="cm-field">
                        <label>Campus Name <span class="req">*</span></label>
                        <input type="text" id="campusName" name="CampusName" placeholder="e.g. Main Campus">
                    </div>
                    <div class="cm-field">
                        <label>Campus Code <span class="req">*</span></label>
                        <input type="text" id="campusCode" name="CampusCode" placeholder="e.g. CMP-004">
                    </div>
                    <div class="cm-field">
                        <label>Campus Type</label>
                        @Html.DropDownList("CampusTypeId", (SelectList)ViewBag.CampusTypeList, "Select type", new { @class = "form-control", id = "campusType" })
                        <span class="as-hint">Managed from Campus Master — updates here automatically.</span>
                    </div>
                    <div class="cm-field">
                        <label>Capacity <span style="color:var(--cm-muted); font-weight:400;">(students)</span></label>
                        <input type="number" id="campusCapacity" name="Capacity" placeholder="e.g. 2500" min="0">
                    </div>
                    <div class="cm-field">
                        <label>Status</label>
                        <div class="cm-status-row">
                            <label class="cm-switch"><input type="checkbox" id="campusStatus" checked><span class="cm-slider"></span></label>
                            <span class="cm-status-text cm-active" id="cmStatusText">Active</span>
                        </div>
                        <input type="hidden" id="campusIsActive" name="IsActive" value="true" />
                    </div>
                </div>

                <div class="cm-section-lbl">Address</div>
                <div class="cm-grid">
                    <div class="cm-field cm-full">
                        <label>Address <span class="req">*</span></label>
                        <textarea id="campusAddress" name="Address" placeholder="Full campus address"></textarea>
                    </div>
                </div>

                <div class="cm-section-lbl">Contact &amp; Leadership</div>
                <div class="cm-grid">
                    <div class="cm-field">
                        <label>Contact Number <span class="req">*</span></label>
                        <input type="tel" id="campusContact" name="ContactNumber" placeholder="e.g. 0522-1234567">
                    </div>
                    <div class="cm-field">
                        <label>Email <span class="req">*</span></label>
                        <input type="email" id="campusEmail" name="Email" placeholder="campus@university.edu">
                    </div>
                    <div class="cm-field">
                        <label>Dean</label>
                        <input type="text" id="campusDean" name="Dean" placeholder="e.g. Dr. R. Sharma">
                    </div>
                </div>

                <div class="cm-bar">
                    <button type="button" class="cm-btn cm-btn-ghost" onclick="showList()">Cancel</button>
                    <span></span>
                    <button type="submit" class="cm-btn cm-btn-primary">
                        <span class="cm-check">✔</span> <span id="cmSubmitText">Save Campus</span>
                    </button>
                </div>
            </div>
        </div>
    }

</div>

<div class="cm-toast" id="cmToast"></div>

<script>
    document.getElementById('campusStatus').addEventListener('change', function () {
        const t = document.getElementById('cmStatusText');
        document.getElementById('campusIsActive').value = this.checked ? 'true' : 'false';
        if (this.checked) { t.textContent = 'Active'; t.className = 'cm-status-text cm-active'; }
        else { t.textContent = 'Inactive'; t.className = 'cm-status-text cm-inactive'; }
    });

    function showForm(btn) {
        document.getElementById('cmListWrap').style.display = 'none';
        document.getElementById('cmFormWrap').style.display = 'block';

        if (btn) {
            // EDIT MODE — fill form from data attributes
            document.getElementById('cmFormTitle').textContent = 'Edit Campus';
            document.getElementById('cmSubmitText').textContent = 'Update Campus';

            document.getElementById('campusId').value = btn.dataset.id;
            document.getElementById('campusName').value = btn.dataset.name;
            document.getElementById('campusCode').value = btn.dataset.code;
            document.getElementById('campusType').value = btn.dataset.typeid || '';
            document.getElementById('campusCapacity').value = btn.dataset.capacity;
            document.getElementById('campusAddress').value = btn.dataset.address;
            document.getElementById('campusContact').value = btn.dataset.contact;
            document.getElementById('campusEmail').value = btn.dataset.email;
            document.getElementById('campusDean').value = btn.dataset.dean;

            const active = btn.dataset.active === 'true';
            document.getElementById('campusStatus').checked = active;
            document.getElementById('campusIsActive').value = active ? 'true' : 'false';
            const t = document.getElementById('cmStatusText');
            t.textContent = active ? 'Active' : 'Inactive';
            t.className = active ? 'cm-status-text cm-active' : 'cm-status-text cm-inactive';
        } else {
            document.getElementById('cmFormTitle').textContent = 'Add Campus';
            document.getElementById('cmSubmitText').textContent = 'Save Campus';
            clearForm();
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showList() {
        document.getElementById('cmFormWrap').style.display = 'none';
        document.getElementById('cmListWrap').style.display = 'block';
    }

    function clearForm() {
        document.getElementById('campusId').value = 0;
        document.querySelectorAll('#cmFormWrap input[type=text], #cmFormWrap input[type=tel], #cmFormWrap input[type=email], #cmFormWrap input[type=number], #cmFormWrap select, #cmFormWrap textarea').forEach(el => el.value = '');
        document.getElementById('campusStatus').checked = true;
        document.getElementById('campusIsActive').value = 'true';
        document.getElementById('cmStatusText').textContent = 'Active';
        document.getElementById('cmStatusText').className = 'cm-status-text cm-active';
    }
</script>
