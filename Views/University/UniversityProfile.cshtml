@model Regis.Models.UniversityProfileModel

@{
    ViewBag.Title = "UniversityProfile";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <div class="as-card">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-university"></i> University Profile</h2>
                <p>Saved information about your university.</p>
            </div>
            <a class="as-btn as-btn-primary" href="@Url.Action("UniversityForm", "University")">
                <i class="fas fa-edit"></i> Edit Profile
            </a>
        </div>

        @if (!string.IsNullOrEmpty(Model.LogoMainPath))
        {
            <div style="text-align:center; margin: 1rem 0 1.5rem;">
                <img src="@Url.Content(Model.LogoMainPath)" alt="University Logo" style="max-height:90px;" />
            </div>
        }

        <!-- ================= PROFILE ================= -->
        <div class="as-section-title"><i class="fas fa-id-card"></i> Profile</div>
        <div class="as-grid">
            <div class="as-field"><label>University Name</label><p>@Model.UniversityName</p></div>
            <div class="as-field"><label>Short Name</label><p>@Model.ShortName</p></div>
            <div class="as-field"><label>University Code</label><p>@Model.UniversityCode</p></div>
            <div class="as-field"><label>University Type</label><p>@ViewBag.UniversityTypeName</p></div>
            <div class="as-field"><label>Established Year</label><p>@Model.EstablishedYear</p></div>
            <div class="as-field"><label>Accreditation</label><p>@Model.Accreditation</p></div>
            <div class="as-field"><label>Website</label><p>@Model.Website</p></div>
            <div class="as-field"><label>Email</label><p>@Model.Email</p></div>
            <div class="as-field"><label>Contact Number</label><p>@Model.Phone</p></div>
            <div class="as-field"><label>Tax / GST Number</label><p>@Model.TaxNumber</p></div>
            <div class="as-field"><label>Affiliated University</label><p>@Model.AffiliatedUniversity</p></div>
            <div class="as-field">
                <label>Status</label>
                <p>
                    @if (Model.IsActive)
                    {
                        <span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span>
                    }
                    else
                    {
                        <span class="as-pill as-pill-inactive"><i class="fas fa-circle"></i> Inactive</span>
                    }
                </p>
            </div>
        </div>

        <!-- ================= DETAILS ================= -->
        <div class="as-section-title"><i class="fas fa-info-circle"></i> Details</div>
        <div class="as-grid">
            <div class="as-field"><label>Motto</label><p>@Model.Motto</p></div>
            <div class="as-field"><label>Vision</label><p>@Model.Vision</p></div>
            <div class="as-field as-full"><label>Mission</label><p>@Model.Mission</p></div>
            <div class="as-field as-full"><label>Description</label><p>@Model.Description</p></div>
            <div class="as-field as-full"><label>About University</label><p>@Model.AboutUniversity</p></div>
            <div class="as-field"><label>Registration Number</label><p>@Model.RegistrationNumber</p></div>
            <div class="as-field"><label>UGC Approval Number</label><p>@Model.UGCApprovalNumber</p></div>
            <div class="as-field"><label>AICTE Approval</label><p>@Model.AICTEApproval</p></div>
            <div class="as-field"><label>NAAC Grade</label><p>@Model.NAACGrade</p></div>
            <div class="as-field"><label>NIRF Rank</label><p>@Model.NIRFRank</p></div>
            <div class="as-field"><label>ISO Certification</label><p>@Model.ISOCertification</p></div>
            <div class="as-field"><label>Office Number</label><p>@Model.OfficeNumber</p></div>
            <div class="as-field"><label>Fax Number</label><p>@Model.FaxNumber</p></div>
            <div class="as-field"><label>Details Email</label><p>@Model.DetailsEmail</p></div>
            <div class="as-field"><label>Details Website</label><p>@Model.DetailsWebsite</p></div>
            <div class="as-field"><label>Facebook</label><p>@Model.Facebook</p></div>
            <div class="as-field"><label>LinkedIn</label><p>@Model.LinkedIn</p></div>
            <div class="as-field"><label>Instagram</label><p>@Model.Instagram</p></div>
            <div class="as-field"><label>Twitter</label><p>@Model.Twitter</p></div>
        </div>

        <!-- ================= LOGOS ================= -->
        <div class="as-section-title"><i class="fas fa-image"></i> Logos</div>
        <div class="as-grid">
            <div class="as-field">
                <label>Main Logo</label>
                @if (!string.IsNullOrEmpty(Model.LogoMainPath))
                {<p><img src="@Url.Content(Model.LogoMainPath)" style="max-height:60px;" /></p> }
                else
                { <p>—</p>}
            </div>
            <div class="as-field">
                <label>Dark Theme Logo</label>
                @if (!string.IsNullOrEmpty(Model.LogoDarkPath))
                {<p><img src="@Url.Content(Model.LogoDarkPath)" style="max-height:60px;" /></p> }
                else
                { <p>—</p>}
            </div>
            <div class="as-field">
                <label>Light Theme Logo</label>
                @if (!string.IsNullOrEmpty(Model.LogoLightPath))
                {<p><img src="@Url.Content(Model.LogoLightPath)" style="max-height:60px;" /></p> }
                else
                { <p>—</p>}
            </div>
            <div class="as-field">
                <label>Sidebar Logo</label>
                @if (!string.IsNullOrEmpty(Model.LogoSidebarPath))
                {<p><img src="@Url.Content(Model.LogoSidebarPath)" style="max-height:60px;" /></p> }
                else
                { <p>—</p>}
            </div>
            <div class="as-field">
                <label>Favicon</label>
                @if (!string.IsNullOrEmpty(Model.FaviconPath))
                {<p><img src="@Url.Content(Model.FaviconPath)" style="max-height:32px;" /></p> }
                else
                { <p>—</p>}
            </div>
        </div>

        <!-- ================= ADDRESS ================= -->
        <div class="as-section-title"><i class="fas fa-map-pin"></i> Address</div>
        <div class="as-grid">
            <div class="as-field"><label>Country</label><p>@Model.Country</p></div>
            <div class="as-field"><label>State</label><p>@Model.State</p></div>
            <div class="as-field"><label>District</label><p>@Model.District</p></div>
            <div class="as-field"><label>City</label><p>@Model.City</p></div>
            <div class="as-field"><label>Area / Locality</label><p>@Model.Area</p></div>
            <div class="as-field"><label>Street</label><p>@Model.Street</p></div>
            <div class="as-field"><label>Building Number</label><p>@Model.BuildingNumber</p></div>
            <div class="as-field"><label>Postal Code</label><p>@Model.PostalCode</p></div>
            <div class="as-field"><label>Latitude</label><p>@Model.Latitude</p></div>
            <div class="as-field"><label>Longitude</label><p>@Model.Longitude</p></div>
        </div>

        <!-- ================= CONTACT ================= -->
        <div class="as-section-title"><i class="fas fa-address-book"></i> Contact</div>
        <div class="as-grid">
            <div class="as-field"><label>Office Number</label><p>@Model.ContOffice</p></div>
            <div class="as-field"><label>Mobile Number</label><p>@Model.ContMobile</p></div>
            <div class="as-field"><label>Alternate Number</label><p>@Model.ContAlternate</p></div>
            <div class="as-field"><label>Admission Helpline</label><p>@Model.ContAdmissionHelpline</p></div>
            <div class="as-field"><label>Registrar Office Number</label><p>@Model.ContRegistrarOffice</p></div>
            <div class="as-field"><label>Email</label><p>@Model.ContEmail</p></div>
            <div class="as-field"><label>Support Email</label><p>@Model.ContSupportEmail</p></div>
            <div class="as-field"><label>Website</label><p>@Model.ContWebsite</p></div>
        </div>

        <div class="as-legend">
            <span>Last updated: @(Model.UpdatedDate?.ToString("dd-MM-yyyy HH:mm"))</span>
        </div>
    </div>

</div>
