@{
    ViewBag.Title = "University Profile";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    ViewData["ActiveMenu"] = "University";
    ViewData["ActiveSubMenu"] = "Profile";
}

<link href="~/Content/CSS/universityProfile.css" rel="stylesheet" />

<div class="profile-container">

    <!-- ===== HEADER ===== -->
    <div class="profile-header">
        <div class="header-left">
            <h1><i class="fas fa-university"></i> University Profile</h1>
            <p class="breadcrumb-text">Complete overview of your university's information</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-edit" onclick="enableEdit()">
                <i class="fas fa-pen"></i> Edit Profile
            </button>
            <button class="btn btn-save" id="saveBtn" style="display:none;" onclick="saveProfile()">
                <i class="fas fa-save"></i> Save Changes
            </button>
            <button class="btn btn-cancel" id="cancelBtn" style="display:none;" onclick="cancelEdit()">
                <i class="fas fa-times"></i> Cancel
            </button>
        </div>
    </div>

    <!-- ===== STATUS BANNER ===== -->
    <div class="status-banner">
        <div class="status-item">
            <span class="status-label">Status</span>
            <span class="status-value active"><i class="fas fa-circle"></i> Active</span>
        </div>
        <div class="status-item">
            <span class="status-label">Last Updated</span>
            <span class="status-value">January 15, 2025</span>
        </div>
        <div class="status-item">
            <span class="status-label">Profile Completeness</span>
            <div class="progress-bar-wrapper">
                <div class="progress-bar" style="width: 85%;"></div>
                <span class="progress-text">85%</span>
            </div>
        </div>
        <div class="status-item">
            <span class="status-label">University Code</span>
            <span class="status-value">SPR-26</span>
        </div>
    </div>

    <!-- ===== QUICK STATS ===== -->
    <div class="quick-stats">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-building-columns"></i></div>
            <div class="stat-info">
                <span class="stat-number">1</span>
                <span class="stat-label">University</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-flag"></i></div>
            <div class="stat-info">
                <span class="stat-number">3</span>
                <span class="stat-label">Campuses</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-certificate"></i></div>
            <div class="stat-info">
                <span class="stat-number">5</span>
                <span class="stat-label">Accreditations</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div class="stat-info">
                <span class="stat-number">15K+</span>
                <span class="stat-label">Students</span>
            </div>
        </div>
    </div>

    <!-- ===== PROFILE CONTENT ===== -->
    <div class="profile-content">

        <!-- ====== SECTION 1: BASIC INFORMATION ====== -->
        <div class="profile-section">
            <div class="section-header">
                <h2><i class="fas fa-id-card"></i> Basic Information</h2>
                <span class="section-badge required">Required</span>
            </div>
            <div class="section-body">
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label"><i class="fas fa-building-columns"></i> University Name</span>
                        <span class="info-value" id="displayUniName">Springfield University</span>
                        <input type="text" class="edit-field" id="editUniName" value="Springfield University" style="display:none;" />
                    </div>
                    <div class="info-item">
                        <span class="info-label"><i class="fas fa-tag"></i> Short Name</span>
                        <span class="info-value" id="displayShortName">SU</span>
                        <input type="text" class="edit-field" id="editShortName" value="SU" style="display:none;" />
                    </div>
                    <div class="info-item">
                        <span class="info-label"><i class="fas fa-barcode"></i> University Code</span>
                        <span class="info-value" id="displayUniCode">SPR-26</span>
                        <input type="text" class="edit-field" id="editUniCode" value="SPR-26" style="display:none;" />
                    </div>
                    <div class="info-item">
                        <span class="info-label"><i class="fas fa-layer-group"></i> University Type</span>
                        <span class="info-value" id="displayUniType">Public</span>
                        <select class="edit-field" id="editUniType" style="display:none;">
                            <option value="Public" selected>Public</option>
                            <option value="Private">Private</option>
                            <option value="Deemed">Deemed University</option>
                            <option value="Central">Central University</option>
                            <option value="State">State University</option>
                        </select>
                    </div>
                    <div class="info-item">
                        <span class="info-label"><i class="fas fa-calendar-alt"></i> Established Year</span>
                        <span class="info-value" id="displayEstYear">2005</span>
                        <input type="number" class="edit-field" id="editEstYear" value="2005" style="display:none;" />
                    </div>
                    <div class="info-item">
                        <span class="info-label"><i class="fas fa-circle-check"></i> Status</span>
                        <span class="info-value">
                            <span class="status-badge active"><i class="fas fa-circle"></i> Active</span>
                        </span>
                        <select class="edit-field" id="editStatus" style="display:none;">
                            <option value="Active" selected>Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- ====== SECTION 2: CONTACT INFORMATION ====== -->
        <div class="profile-section">
            <div class="section-header">
                <h2><i class="fas fa-address-card"></i> Contact Information</h2>
                <span class="section-badge required">Required</span>
            </div>
            <div class="section-body">
                <div class="info-grid">
                    <div class="info-item">
