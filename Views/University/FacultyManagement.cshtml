@{
    ViewBag.Title = "Faculty Management";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    ViewBag.ActiveMenu = "Academic";
    ViewData["ActiveSubMenu"] = "Faculty";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/facultyManagement.css" rel="stylesheet" />

<div class="fm-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="fm-card" id="fmListWrap">
        <!-- Header -->
        <div class="fm-list-head">
            <div>
                <h2><i class="fas fa-chalkboard-teacher"></i> Faculty Management</h2>
                <p>Manage all faculty members, departments, and faculty assignments.</p>
            </div>
            <div class="fm-header-actions">
                <button class="fm-btn fm-btn-outline" onclick="showWizard('faculty')">
                    <i class="fas fa-user-plus"></i> Add Faculty
                </button>
                <button class="fm-btn fm-btn-primary" onclick="showWizard('department')">
                    <i class="fas fa-plus-circle"></i> Add Department
                </button>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="fm-quick-stats">
            <div class="fm-stat-card">
                <div class="fm-stat-icon"><i class="fas fa-users"></i></div>
                <div class="fm-stat-info">
                    <span class="fm-stat-number" id="totalFaculty">348</span>
                    <span class="fm-stat-label">Total Faculty</span>
                </div>
            </div>
            <div class="fm-stat-card">
                <div class="fm-stat-icon"><i class="fas fa-building"></i></div>
                <div class="fm-stat-info">
                    <span class="fm-stat-number" id="totalDepartments">12</span>
                    <span class="fm-stat-label">Departments</span>
                </div>
            </div>
            <div class="fm-stat-card">
                <div class="fm-stat-icon"><i class="fas fa-user-tie"></i></div>
                <div class="fm-stat-info">
                    <span class="fm-stat-number" id="activeFaculty">312</span>
                    <span class="fm-stat-label">Active Faculty</span>
                </div>
            </div>
            <div class="fm-stat-card">
                <div class="fm-stat-icon"><i class="fas fa-user-clock"></i></div>
                <div class="fm-stat-info">
                    <span class="fm-stat-number" id="onLeave">36</span>
                    <span class="fm-stat-label">On Leave</span>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="fm-tabs">
            <button class="fm-tab active" data-tab="faculty" onclick="switchTab('faculty')">
                <i class="fas fa-users"></i> Faculty
            </button>
            <button class="fm-tab" data-tab="departments" onclick="switchTab('departments')">
                <i class="fas fa-building"></i> Departments
            </button>
            <button class="fm-tab" data-tab="assignments" onclick="switchTab('assignments')">
                <i class="fas fa-tasks"></i> Assignments
            </button>
            <button class="fm-tab" data-tab="attendance" onclick="switchTab('attendance')">
                <i class="fas fa-clipboard-check"></i> Attendance
            </button>
        </div>

        <!-- ===== FACULTY LIST ===== -->
        <div class="fm-tab-content active" id="tabFaculty">
            <div class="fm-table-toolbar">
                <div class="fm-search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search faculty by name, ID, or department..." id="facultySearch">
                </div>
                <div class="fm-filter-group">
                    <select id="facultyFilterDept">
                        <option value="">All Departments</option>
                        <option value="CSE">Computer Science</option>
                        <option value="ECE">Electronics</option>
                        <option value="ME">Mechanical Engineering</option>
                        <option value="CE">Civil Engineering</option>
                        <option value="MBA">MBA</option>
                    </select>
                    <select id="facultyFilterStatus">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="On Leave">On Leave</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <div class="fm-table-wrapper">
                <table class="fm-table">
                    <thead>
                        <tr>
                            <th>Faculty ID</th>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Designation</th>
                            <th>Qualification</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>FAC-001</strong></td>
                            <td><span class="fm-user-name"><span class="fm-avatar">JD</span> Dr. John Doe</span></td>
                            <td><span class="fm-dept-badge">CSE</span></td>
                            <td>Professor</td>
                            <td>Ph.D. (Computer Science)</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="fm-mini-btn" title="Assign"><i class="fas fa-tasks"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>FAC-002</strong></td>
                            <td><span class="fm-user-name"><span class="fm-avatar">JS</span> Dr. Jane Smith</span></td>
                            <td><span class="fm-dept-badge">ECE</span></td>
                            <td>Associate Professor</td>
                            <td>Ph.D. (Electronics)</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="fm-mini-btn" title="Assign"><i class="fas fa-tasks"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>FAC-003</strong></td>
                            <td><span class="fm-user-name"><span class="fm-avatar">MR</span> Prof. Mike Ross</span></td>
                            <td><span class="fm-dept-badge">MBA</span></td>
                            <td>Assistant Professor</td>
                            <td>MBA (Finance)</td>
                            <td><span class="fm-pill fm-pill-leave"><i class="fas fa-clock"></i> On Leave</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="fm-mini-btn" title="Assign"><i class="fas fa-tasks"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>FAC-004</strong></td>
                            <td><span class="fm-user-name"><span class="fm-avatar">SW</span> Dr. Sarah Wilson</span></td>
                            <td><span class="fm-dept-badge">ME</span></td>
                            <td>Professor</td>
                            <td>Ph.D. (Mechanical)</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="fm-mini-btn" title="Assign"><i class="fas fa-tasks"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="fm-pagination">
                <span>Showing 1-10 of 348 faculty</span>
                <div class="fm-pagination-btns">
                    <button class="fm-mini-btn"><i class="fas fa-chevron-left"></i></button>
                    <button class="fm-mini-btn active">1</button>
                    <button class="fm-mini-btn">2</button>
                    <button class="fm-mini-btn">3</button>
                    <button class="fm-mini-btn">...</button>
                    <button class="fm-mini-btn">35</button>
                    <button class="fm-mini-btn"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        </div>

        <!-- ===== DEPARTMENTS LIST ===== -->
        <div class="fm-tab-content" id="tabDepartments">
            <div class="fm-table-wrapper">
                <table class="fm-table">
                    <thead>
                        <tr>
                            <th>Department Code</th>
                            <th>Department Name</th>
                            <th>Head of Department</th>
                            <th>Faculty Count</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>CSE</strong></td>
                            <td>Computer Science & Engineering</td>
                            <td>Dr. John Doe</td>
                            <td>45</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>ECE</strong></td>
                            <td>Electronics & Communication</td>
                            <td>Dr. Jane Smith</td>
                            <td>38</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>ME</strong></td>
                            <td>Mechanical Engineering</td>
                            <td>Dr. Sarah Wilson</td>
                            <td>42</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>MBA</strong></td>
                            <td>Master of Business Administration</td>
                            <td>Prof. Mike Ross</td>
                            <td>28</td>
                            <td><span class="fm-pill fm-pill-leave"><i class="fas fa-clock"></i> On Leave</span></td>
                            <td>
                                <button class="fm-mini-btn" title="View"><i class="fas fa-eye"></i></button>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===== ASSIGNMENTS ===== -->
        <div class="fm-tab-content" id="tabAssignments">
            <div class="fm-table-toolbar">
                <div class="fm-search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search assignments..." id="assignmentSearch">
                </div>
                <button class="fm-btn fm-btn-primary fm-btn-sm" onclick="showWizard('assignment')">
                    <i class="fas fa-plus"></i> New Assignment
                </button>
            </div>

            <div class="fm-table-wrapper">
                <table class="fm-table">
                    <thead>
                        <tr>
                            <th>Faculty</th>
                            <th>Course</th>
                            <th>Department</th>
                            <th>Session</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Dr. John Doe</td>
                            <td>CS101 - Programming Fundamentals</td>
                            <td>CSE</td>
                            <td>2025-26</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="fm-mini-btn" title="Remove"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>Dr. Jane Smith</td>
                            <td>ECE201 - Digital Electronics</td>
                            <td>ECE</td>
                            <td>2025-26</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-circle"></i> Active</span></td>
                            <td>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                <button class="fm-mini-btn" title="Remove"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===== ATTENDANCE ===== -->
        <div class="fm-tab-content" id="tabAttendance">
            <div class="fm-table-toolbar">
                <div class="fm-search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search attendance records...">
                </div>
                <div class="fm-filter-group">
                    <select>
                        <option>Today</option>
                        <option>This Week</option>
                        <option>This Month</option>
                        <option>Custom Range</option>
                    </select>
                </div>
            </div>

            <div class="fm-table-wrapper">
                <table class="fm-table">
                    <thead>
                        <tr>
                            <th>Faculty</th>
                            <th>Department</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Dr. John Doe</td>
                            <td>CSE</td>
                            <td>15 Jan 2025</td>
                            <td><span class="fm-pill fm-pill-active"><i class="fas fa-check"></i> Present</span></td>
                            <td>09:00 AM</td>
                            <td>05:30 PM</td>
                            <td>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>Dr. Jane Smith</td>
                            <td>ECE</td>
                            <td>15 Jan 2025</td>
                            <td><span class="fm-pill fm-pill-leave"><i class="fas fa-clock"></i> Leave</span></td>
                            <td>—</td>
                            <td>—</td>
                            <td>
                                <button class="fm-mini-btn" title="Edit"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Legend -->
        <div class="fm-legend">
            <span><span class="fm-legend-dot active"></span> Active</span>
            <span><span class="fm-legend-dot leave"></span> On Leave</span>
            <span><span class="fm-legend-dot inactive"></span> Inactive</span>
            <span><span class="fm-legend-dot present"></span> Present</span>
            <span><span class="fm-legend-dot absent"></span> Absent</span>
        </div>
    </div>

    <!-- ================= WIZARD ================= -->
    <div class="fm-card fm-wizard-card" id="fmWizardWrap" style="display:none;">

        <!-- Back Button -->
        <div class="fm-back-row">
            <button class="fm-back-link" onclick="showList()">
                <i class="fas fa-arrow-left"></i> Back to List
            </button>
        </div>

        <!-- Wizard Type -->
        <div class="fm-wizard-type" id="wizardType">
            <button class="fm-btn fm-btn-sm fm-btn-ghost" data-type="faculty" onclick="setWizardType('faculty')">
                <i class="fas fa-user"></i> Add Faculty
            </button>
            <button class="fm-btn fm-btn-sm fm-btn-ghost" data-type="department" onclick="setWizardType('department')">
                <i class="fas fa-building"></i> Add Department
            </button>
            <button class="fm-btn fm-btn-sm fm-btn-ghost" data-type="assignment" onclick="setWizardType('assignment')">
                <i class="fas fa-tasks"></i> New Assignment
            </button>
        </div>

        <!-- ===== FACULTY WIZARD ===== -->
        <div class="fm-wizard-content" id="wizardFaculty">
            <!-- Personal Information -->
            <div class="fm-section-title">
                <i class="fas fa-user"></i> Personal Information
            </div>
            <div class="fm-grid">
                <div class="fm-field">
                    <label>First Name <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. John">
                </div>
                <div class="fm-field">
                    <label>Last Name <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. Doe">
                </div>
                <div class="fm-field">
                    <label>Email <span class="req">*</span></label>
                    <input type="email" placeholder="john.doe@university.edu">
                </div>
                <div class="fm-field">
                    <label>Phone <span class="req">*</span></label>
                    <input type="tel" placeholder="+1 234 567 890">
                </div>
                <div class="fm-field">
                    <label>Date of Birth</label>
                    <input type="date">
                </div>
                <div class="fm-field">
                    <label>Gender</label>
                    <select>
                        <option value="">-- Select --</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="fm-field fm-full">
                    <label>Address</label>
                    <textarea placeholder="Full address..."></textarea>
                </div>
            </div>

            <!-- Professional Information -->
            <div class="fm-section-title">
                <i class="fas fa-briefcase"></i> Professional Information
            </div>
            <div class="fm-grid">
                <div class="fm-field">
                    <label>Employee ID <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. EMP-2025-001">
                </div>
                <div class="fm-field">
                    <label>Department <span class="req">*</span></label>
                    <select>
                        <option value="">-- Select Department --</option>
                        <option>CSE</option>
                        <option>ECE</option>
                        <option>ME</option>
                        <option>CE</option>
                        <option>MBA</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Designation <span class="req">*</span></label>
                    <select>
                        <option value="">-- Select Designation --</option>
                        <option>Professor</option>
                        <option>Associate Professor</option>
                        <option>Assistant Professor</option>
                        <option>Senior Lecturer</option>
                        <option>Lecturer</option>
                        <option>Teaching Assistant</option>
                        <option>Research Scholar</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Qualification <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. Ph.D. (Computer Science)">
                </div>
                <div class="fm-field">
                    <label>Experience (Years)</label>
                    <input type="number" placeholder="e.g. 10" min="0">
                </div>
                <div class="fm-field">
                    <label>Specialization</label>
                    <input type="text" placeholder="e.g. Artificial Intelligence">
                </div>
                <div class="fm-field">
                    <label>Join Date <span class="req">*</span></label>
                    <input type="date" value="2025-04-01">
                </div>
                <div class="fm-field">
                    <label>Status</label>
                    <select>
                        <option value="Active">Active</option>
                        <option value="On Leave">On Leave</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <!-- Education -->
            <div class="fm-section-title">
                <i class="fas fa-graduation-cap"></i> Education
            </div>
            <div class="fm-grid">
                <div class="fm-field fm-full">
                    <label>Highest Qualification <span class="req">*</span></label>
                    <select>
                        <option value="">-- Select --</option>
                        <option>Ph.D.</option>
                        <option>M.Phil.</option>
                        <option>Master's Degree</option>
                        <option>Bachelor's Degree</option>
                        <option>Diploma</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Degree Name <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. Ph.D. in Computer Science">
                </div>
                <div class="fm-field">
                    <label>University <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. MIT">
                </div>
                <div class="fm-field">
                    <label>Year of Passing</label>
                    <input type="number" placeholder="e.g. 2020" min="1980" max="2030">
                </div>
                <div class="fm-field fm-full">
                    <label>Additional Qualifications</label>
                    <textarea placeholder="List additional qualifications, certifications..."></textarea>
                </div>
            </div>

            <!-- Expertise -->
            <div class="fm-section-title">
                <i class="fas fa-star"></i> Expertise & Research
            </div>
            <div class="fm-grid">
                <div class="fm-field fm-full">
                    <label>Areas of Expertise</label>
                    <input type="text" placeholder="e.g. Machine Learning, Data Science, Cloud Computing">
                    <span class="fm-hint">Comma-separated values</span>
                </div>
                <div class="fm-field fm-full">
                    <label>Research Publications</label>
                    <textarea placeholder="List research publications, papers, journals..."></textarea>
                </div>
                <div class="fm-field fm-full">
                    <label>Awards & Recognitions</label>
                    <textarea placeholder="List any awards, recognitions, honors..."></textarea>
                </div>
            </div>

            <!-- Workload -->
            <div class="fm-section-title">
                <i class="fas fa-tasks"></i> Workload Settings
            </div>
            <div class="fm-grid">
                <div class="fm-field">
                    <label>Max Teaching Load (Hours/Week)</label>
                    <input type="number" value="20" min="5" max="40">
                </div>
                <div class="fm-field">
                    <label>Current Teaching Load (Hours/Week)</label>
                    <input type="number" value="16" min="0" max="40" readonly disabled>
                </div>
                <div class="fm-field">
                    <label>Advisory Role</label>
                    <select>
                        <option value="">-- None --</option>
                        <option>Academic Advisor</option>
                        <option>Research Advisor</option>
                        <option>Project Coordinator</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Office Location</label>
                    <input type="text" placeholder="e.g. Building A, Room 301">
                </div>
            </div>

            <div class="fm-bar">
                <span></span>
                <div class="fm-step-count">Step 1 of 1</div>
                <button class="fm-btn fm-btn-primary" onclick="saveFaculty()">
                    <i class="fas fa-save"></i> Save Faculty
                </button>
            </div>
        </div>

        <!-- ===== DEPARTMENT WIZARD ===== -->
        <div class="fm-wizard-content" id="wizardDepartment" style="display:none;">
            <div class="fm-grid">
                <div class="fm-field">
                    <label>Department Code <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. CSE">
                    <span class="fm-hint">Unique code for the department</span>
                </div>
                <div class="fm-field">
                    <label>Department Name <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. Computer Science & Engineering">
                </div>
                <div class="fm-field">
                    <label>Head of Department</label>
                    <select>
                        <option value="">-- Select Faculty --</option>
                        <option>Dr. John Doe</option>
                        <option>Dr. Jane Smith</option>
                        <option>Dr. Sarah Wilson</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Status</label>
                    <select>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Department Email</label>
                    <input type="email" placeholder="cse@university.edu">
                </div>
                <div class="fm-field">
                    <label>Phone</label>
                    <input type="tel" placeholder="+1 234 567 890">
                </div>
                <div class="fm-field fm-full">
                    <label>Description</label>
                    <textarea placeholder="Brief description of the department..."></textarea>
                </div>
            </div>

            <div class="fm-bar">
                <span></span>
                <div class="fm-step-count">Step 1 of 1</div>
                <button class="fm-btn fm-btn-primary" onclick="saveDepartment()">
                    <i class="fas fa-save"></i> Save Department
                </button>
            </div>
        </div>

        <!-- ===== ASSIGNMENT WIZARD ===== -->
        <div class="fm-wizard-content" id="wizardAssignment" style="display:none;">
            <div class="fm-grid">
                <div class="fm-field">
                    <label>Faculty <span class="req">*</span></label>
                    <select>
                        <option value="">-- Select Faculty --</option>
                        <option>Dr. John Doe</option>
                        <option>Dr. Jane Smith</option>
                        <option>Dr. Sarah Wilson</option>
                        <option>Prof. Mike Ross</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Course <span class="req">*</span></label>
                    <select>
                        <option value="">-- Select Course --</option>
                        <option>CS101 - Programming Fundamentals</option>
                        <option>CS201 - Data Structures</option>
                        <option>ECE201 - Digital Electronics</option>
                        <option>ME301 - Thermodynamics</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Session <span class="req">*</span></label>
                    <select>
                        <option value="">-- Select Session --</option>
                        <option>2025-26</option>
                        <option>2024-25</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Assignment Type</label>
                    <select>
                        <option>Primary Instructor</option>
                        <option>Co-Instructor</option>
                        <option>Teaching Assistant</option>
                        <option>Lab Instructor</option>
                    </select>
                </div>
                <div class="fm-field">
                    <label>Credits</label>
                    <input type="number" value="4" min="1" max="6">
                </div>
                <div class="fm-field">
                    <label>Status</label>
                    <select>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <div class="fm-bar">
                <span></span>
                <div class="fm-step-count">Step 1 of 1</div>
                <button class="fm-btn fm-btn-primary" onclick="saveAssignment()">
                    <i class="fas fa-save"></i> Save Assignment
                </button>
            </div>
        </div>

        <!-- ===== DONE STATE ===== -->
        <div class="fm-done" id="fmDone" style="display:none;">
            <div class="fm-done-icon"><i class="fas fa-check-circle"></i></div>
            <h2>Faculty Added Successfully!</h2>
            <p id="fmDoneMessage">Dr. John Doe has been added to the faculty.</p>
            <div class="fm-done-actions">
                <button class="fm-btn fm-btn-primary" onclick="resetWizard()">
                    <i class="fas fa-plus"></i> Add Another
                </button>
                <button class="fm-btn fm-btn-outline" onclick="showList()">
                    <i class="fas fa-arrow-left"></i> Back to List
                </button>
