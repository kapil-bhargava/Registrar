        </div>

    </div>

</div>

<!-- Toast Notification -->
<div class="fm-toast" id="fmToast">
    <i class="fas fa-check-circle"></i>
    <span id="fmToastMessage">Success!</span>
</div>

<script>
    let currentWizardType = 'faculty';

    function showWizard(type) {
        document.getElementById('fmListWrap').style.display = 'none';
        document.getElementById('fmWizardWrap').style.display = 'block';
        setWizardType(type || 'faculty');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showList() {
        document.getElementById('fmWizardWrap').style.display = 'none';
        document.getElementById('fmListWrap').style.display = 'block';
        document.getElementById('fmDone').style.display = 'none';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function setWizardType(type) {
        currentWizardType = type;
        document.querySelectorAll('.fm-wizard-content').forEach(el => el.style.display = 'none');
        document.querySelectorAll('#wizardType .fm-btn').forEach(el => el.classList.remove('active'));

        document.getElementById('wizard' + type.charAt(0).toUpperCase() + type.slice(1)).style.display = 'block';
        document.querySelector('#wizardType .fm-btn[data-type="' + type + '"]').classList.add('active');
        document.getElementById('fmDone').style.display = 'none';
    }

    function switchTab(tab) {
        document.querySelectorAll('.fm-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.fm-tab-content').forEach(c => c.classList.remove('active'));
        document.querySelector('.fm-tab[data-tab="' + tab + '"]').classList.add('active');
        document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    }

    function showToast(msg, type) {
        const toast = document.getElementById('fmToast');
        const messageEl = document.getElementById('fmToastMessage');
        const icon = toast.querySelector('i');

        messageEl.textContent = msg;
        icon.className = type === 'success' ? 'fas fa-check-circle' :
            type === 'error' ? 'fas fa-exclamation-circle' :
                'fas fa-info-circle';
        toast.className = 'fm-toast show ' + (type || '');

        setTimeout(() => {
            toast.classList.remove('show');
        }, 3000);
    }

    function saveFaculty() {
        const name = document.querySelector('#wizardFaculty input[placeholder*="John"]');
        if (!name || !name.value.trim()) {
            showToast('Please enter faculty name', 'error');
            return;
        }
        document.getElementById('fmDoneMessage').textContent = name.value.trim() + ' has been added to the faculty.';
        document.querySelectorAll('.fm-wizard-content').forEach(el => el.style.display = 'none');
        document.getElementById('fmDone').style.display = 'block';
        showToast('Faculty added successfully!', 'success');
    }

    function saveDepartment() {
        const dept = document.querySelector('#wizardDepartment input[placeholder*="Computer"]');
        if (!dept || !dept.value.trim()) {
            showToast('Please enter department name', 'error');
            return;
        }
        document.getElementById('fmDoneMessage').textContent = 'Department "' + dept.value.trim() + '" has been created.';
        document.querySelectorAll('.fm-wizard-content').forEach(el => el.style.display = 'none');
        document.getElementById('fmDone').style.display = 'block';
        showToast('Department added successfully!', 'success');
    }

    function saveAssignment() {
        document.getElementById('fmDoneMessage').textContent = 'Assignment has been created successfully.';
        document.querySelectorAll('.fm-wizard-content').forEach(el => el.style.display = 'none');
        document.getElementById('fmDone').style.display = 'block';
        showToast('Assignment created successfully!', 'success');
    }

    function resetWizard() {
        document.getElementById('fmDone').style.display = 'none';
        setWizardType(currentWizardType);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Search functionality
    document.getElementById('facultySearch')?.addEventListener('input', function (e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelector('#tabFaculty tbody tr');
        // Add your search logic here
        showToast('Searching: ' + searchTerm, 'info');
    });
</script>