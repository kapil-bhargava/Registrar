@model List<Regis.Models.SeatMatrixModel>
@using Regis.Models

@{
    ViewBag.Title = "SeatMatrix";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    var courses = ViewBag.Courses as List<CourseMasterModel> ?? new List<CourseMasterModel>();
    var sessions = ViewBag.Sessions as List<AcademicSessionModel> ?? new List<AcademicSessionModel>();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="smListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-chair"></i> Seat Matrix</h2>
                <p>Define the total intake capacity (seats) for each course, per academic session.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="smShowForm()">
                <i class="fas fa-plus-circle"></i> Add Seat Matrix
            </button>
        </div>

        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-chair"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count</span>
                    <span class="as-stat-label">Course Entries</span>
                </div>
            </div>
            <div class="as-stat-card active">
                <div class="as-stat-icon"><i class="fas fa-users"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Sum(m => m.TotalSeats)</span>
                    <span class="as-stat-label">Total Seats (All Courses)</span>
                </div>
            </div>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Academic Session</th>
                        <th>Total Seats</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="smTableBody">
                    @foreach (var m in Model)
                    {
                        <tr>
                           <td><strong>@m.CourseName (@m.CourseCode)</strong></td>
                            <td>@m.SessionName</td>
                            <td>@m.TotalSeats</td>
                            <td>
                                @if (m.IsActive)
                                {
                                    <span class="as-pill as-pill-active"><i class="fas fa-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-inactive"><i class="fas fa-circle"></i> Inactive</span>
                                }
                            </td>
                            <td>
                                <button class="as-mini-btn" title="Edit" onclick="smEditForm(@m.SeatMatrixId)"><i class="fas fa-edit"></i></button>
                                <a class="as-mini-btn" title="Delete"
                                   href="@Url.Action("DeleteSeatMatrix", "SeatManagement", new { id = m.SeatMatrixId })"
                                   onclick="return confirm('Delete this seat matrix entry?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Active</span>
            <span><span class="as-legend-dot archived"></span> Inactive</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT SEAT MATRIX FORM ================= -->
    @using (Html.BeginForm("SeatMatrix", "SeatManagement", FormMethod.Post, new { id = "seatMatrixForm", onsubmit = "return smValidate();" }))
    {
        <div class="as-card as-wizard-card" id="smFormWrap" style="display:none;">
            <div class="as-back-row">
                <button type="button" class="as-back-link" onclick="smShowList()">
                    <i class="fas fa-arrow-left"></i> Back to Seat Matrix List
                </button>
            </div>

            <div class="as-body">
                <div class="as-page active">
                    <div class="as-head">
                        <div class="as-icon"><i class="fas fa-chair"></i></div>
                        <div>
                            <h2 id="smFormTitle">Add Seat Matrix</h2>
                            <p>Define the total number of seats available for a course in a session.</p>
                        </div>
                    </div>

                    <div class="as-section-title">
                        <i class="fas fa-info-circle"></i> Seat Details
                    </div>

                    <input type="hidden" id="seatMatrixId" name="SeatMatrixId" value="0" />

                    <div class="as-grid">
                        <div class="as-field">
                            <label>Course <span class="req">*</span></label>
                          <select id="smCourse" name="CourseId" required>
                              <option value="">-- Select Course --</option>
                              @foreach (var c in courses)
                              {
                                  <option value="@c.CourseId">@c.CourseName (@c.CourseCode)</option>
                              }
                          </select>
                        </div>

                        <div class="as-field">
                            <label>Academic Session <span class="req">*</span></label>
                            <select id="smSession" name="AcademicSessionId" required>
                                <option value="">-- Select Session --</option>
                                @foreach (var s in sessions)
                                {
                                    <option value="@s.AcademicSessionId">@s.SessionName</option>
                                }
                            </select>
                        </div>

                        <div class="as-field">
                            <label>Total Seats <span class="req">*</span></label>
                            <input type="number" id="smTotalSeatsInput" name="TotalSeats" placeholder="e.g. 120" min="1" required>
                            <span class="as-hint">This is the overall intake capacity — you'll split it by category next</span>
                        </div>

                        <div class="as-field">
                            <label>Status</label>
                            <select id="smStatus" name="IsActive">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="as-warning-box">
                        <i class="fas fa-info-circle"></i>
                        <div>
                            <strong>Next Step:</strong> After saving, go to <strong>Category-wise Seats</strong> to split this total into General / OBC / SC / ST / EWS.
                        </div>
                    </div>

                    <div class="as-bar">
                        <button type="button" class="as-btn as-btn-ghost" onclick="smShowList()">Cancel</button>
                        <span></span>
                        <button type="submit" class="as-btn as-btn-primary">
                            <i class="fas fa-save"></i> <span id="smSubmitText">Save Seat Matrix</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<div class="as-toast" id="smToast">
    <i class="fas fa-check-circle"></i>
    <span id="smToastMessage">Success!</span>
</div>

<script>
    function smShowForm() {
        document.getElementById('smListWrap').style.display = 'none';
        document.getElementById('smFormWrap').style.display = 'block';
        smResetForm();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function smShowList() {
        document.getElementById('smFormWrap').style.display = 'none';
        document.getElementById('smListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function smResetForm() {
        document.getElementById('smFormTitle').textContent = 'Add Seat Matrix';
        document.getElementById('smSubmitText').textContent = 'Save Seat Matrix';
        document.getElementById('seatMatrixId').value = 0;
        document.getElementById('smCourse').value = '';
        document.getElementById('smSession').value = '';
        document.getElementById('smTotalSeatsInput').value = '';
        document.getElementById('smStatus').value = 'true';
    }

    function smEditForm(id) {
        fetch('/SeatManagement/GetSeatMatrixById?id=' + id)
            .then(res => res.json())
            .then(m => {
                smShowForm();
                document.getElementById('smFormTitle').textContent = 'Edit Seat Matrix';
                document.getElementById('smSubmitText').textContent = 'Update Seat Matrix';

                document.getElementById('seatMatrixId').value = m.SeatMatrixId;
                document.getElementById('smCourse').value = m.CourseId;
                document.getElementById('smSession').value = m.AcademicSessionId;
                document.getElementById('smTotalSeatsInput').value = m.TotalSeats;
                document.getElementById('smStatus').value = m.IsActive.toString().toLowerCase();
            });
    }

    function smValidate() {
        const course = document.getElementById('smCourse').value;
        if (!course) { alert('Please select a Course'); return false; }

        const session = document.getElementById('smSession').value;
        if (!session) { alert('Please select an Academic Session'); return false; }

        const seats = document.getElementById('smTotalSeatsInput').value;
        if (!seats || seats <= 0) { alert('Please enter valid Total Seats'); return false; }

        return true;
    }
</script>