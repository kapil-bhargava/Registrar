@model List<Regis.Models.SeatCategoryMappingModel>
@using Regis.Models

@{
    ViewBag.Title = "CategorywiseSeats";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    var seatMatrixList = ViewBag.SeatMatrixList as List<SeatMatrixModel> ?? new List<SeatMatrixModel>();
    var categories = ViewBag.Categories as List<CategoryModel> ?? new List<CategoryModel>();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="~/Content/CSS/academicSession.css" rel="stylesheet" />

<div class="as-wrap">

    <!-- ================= LIST PAGE ================= -->
    <div class="as-card" id="cwsListWrap">
        <div class="as-list-head">
            <div>
                <h2><i class="fas fa-users-cog"></i> Category-wise Seats</h2>
                <p>Split each course's total seats (from Seat Matrix) across reservation categories.</p>
            </div>
            <button class="as-btn as-btn-primary" onclick="cwsShowForm()">
                <i class="fas fa-plus-circle"></i> Add Category Mapping
            </button>
        </div>

        <div class="as-quick-stats">
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-users-cog"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(m => m.CategoryAllocations.Any())</span>
                    <span class="as-stat-label">Courses Mapped</span>
                </div>
            </div>
            <div class="as-stat-card">
                <div class="as-stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="as-stat-info">
                    <span class="as-stat-number">@Model.Count(m => !m.CategoryAllocations.Any())</span>
                    <span class="as-stat-label">Pending Mapping</span>
                </div>
            </div>
        </div>

        <div class="as-table-wrapper">
            <table class="as-table as-list-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Session</th>
                        <th>Total Seats</th>
                        <th>Category Split</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="cwsTableBody">
                    @foreach (var m in Model)
                    {
                        int sum = m.CategoryAllocations.Sum(a => a.AllocatedSeats);
                        <tr>
                            <td><strong>@m.CourseName (@m.CourseCode)</strong></td>
                            <td>@m.SessionName</td>
                            <td>@m.TotalSeats</td>
                            <td>
                                @if (m.CategoryAllocations.Any())
                                {
                                    foreach (var a in m.CategoryAllocations)
                                    {
                                        <span class="rd-doc-chip">@a.CategoryName: @a.AllocatedSeats</span>
                                    }
                                }
                                else
                                {
                                    <span class="as-hint">Not mapped</span>
                                }
                            </td>
                            <td>
                                @if (m.CategoryAllocations.Any() && sum == m.TotalSeats)
                                {
                                    <span class="as-pill as-pill-active"><i class="fas fa-check-circle"></i> Balanced</span>
                                }
                                else if (m.CategoryAllocations.Any())
                                {
                                    <span class="as-pill as-pill-locked"><i class="fas fa-exclamation-triangle"></i> Mismatch</span>
                                }
                                else
                                {
                                    <span class="as-pill as-pill-draft"><i class="fas fa-exclamation-circle"></i> Not Mapped</span>
                                }
                            </td>
                            <td>
                                <button class="as-mini-btn" title="Edit" onclick="cwsEditForm(@m.SeatMatrixId)"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="as-legend">
            <span><span class="as-legend-dot active"></span> Balanced (sum = total seats)</span>
            <span><span class="as-legend-dot locked"></span> Mismatch</span>
        </div>
    </div>

    <!-- ================= ADD / EDIT CATEGORY MAPPING FORM ================= -->
    @using (Html.BeginForm("CategorywiseSeats", "SeatManagement", FormMethod.Post, new { id = "cwsForm", onsubmit = "return cwsValidateSubmit();" }))
    {
        <div class="as-card as-wizard-card" id="cwsFormWrap" style="display:none;">
            <div class="as-back-row">
                <button type="button" class="as-back-link" onclick="cwsShowList()">
                    <i class="fas fa-arrow-left"></i> Back to Category-wise Seats List
                </button>
            </div>

            <div class="as-body">
                <div class="as-page active">
                    <div class="as-head">
                        <div class="as-icon"><i class="fas fa-users-cog"></i></div>
                        <div>
                            <h2 id="cwsFormTitle">Add Category Mapping</h2>
                            <p>Choose a Seat Matrix entry, then split its total seats across categories.</p>
                        </div>
                    </div>

                    <div class="as-section-title">
                        <i class="fas fa-chair"></i> Select Seat Matrix
                    </div>
                    <div class="as-grid">
                        <div class="as-field as-full">
                            <label>Course + Session (from Seat Matrix) <span class="req">*</span></label>
                            <select id="cwsSeatMatrix" name="SeatMatrixId" onchange="cwsLoadTotal()" required>
                                <option value="">-- Select Seat Matrix Entry --</option>
                                @foreach (var sm in seatMatrixList)
                                {
                                    <option value="@sm.SeatMatrixId" data-total="@sm.TotalSeats">
                                        @sm.CourseName (@sm.CourseCode) — @sm.SessionName (Total: @sm.TotalSeats)
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="as-field">
                            <label>Total Seats</label>
                            <input type="number" id="cwsTotalSeats" readonly disabled placeholder="Auto-filled from Seat Matrix">
                        </div>
                    </div>

                    <div class="as-section-title">
                        <i class="fas fa-tag"></i> Split by Category
                        <span class="as-hint" style="display:inline-block; margin-left:8px;">(Categories come from Category Master)</span>
                    </div>
                    <div class="as-grid as-calendar-grid" id="cwsCategoryFields">
                        @foreach (var cat in categories)
                        {
                            <div class="as-field">
                                <label>@cat.CategoryName</label>
                                <input type="number" class="cws-cat-input" data-category-id="@cat.CategoryId" min="0" value="0" oninput="cwsRecalculate()">
                            </div>
                        }
                    </div>

                    <div class="as-current-session" id="cwsBalanceBox">
                        <div class="as-current-label">📊 Live Balance Check</div>
                        <div class="as-current-value">
                            Allocated: <span id="cwsAllocatedSum">0</span> / <span id="cwsTargetTotal">0</span> Total Seats
                        </div>
                        <span class="as-pill" id="cwsBalancePill">Enter seats above</span>
                    </div>

                    <input type="hidden" id="categoryIdsCsv" name="CategoryIdsCsv" value="" />
                    <input type="hidden" id="seatsCsv" name="SeatsCsv" value="" />

                    <div class="as-bar">
                        <button type="button" class="as-btn as-btn-ghost" onclick="cwsShowList()">Cancel</button>
                        <span></span>
                        <button type="submit" class="as-btn as-btn-primary">
                            <i class="fas fa-save"></i> Save Category Mapping
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<div class="as-toast" id="cwsToast">
    <i class="fas fa-check-circle"></i>
    <span id="cwsToastMessage">Success!</span>
</div>

<script>
    function cwsShowForm() {
        document.getElementById('cwsListWrap').style.display = 'none';
        document.getElementById('cwsFormWrap').style.display = 'block';
        cwsResetForm();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function cwsShowList() {
        document.getElementById('cwsFormWrap').style.display = 'none';
        document.getElementById('cwsListWrap').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function cwsResetForm() {
        document.getElementById('cwsFormTitle').textContent = 'Add Category Mapping';
        document.getElementById('cwsSeatMatrix').value = '';
        document.getElementById('cwsTotalSeats').value = '';
        document.querySelectorAll('.cws-cat-input').forEach(inp => inp.value = 0);
        cwsRecalculate();
    }

    function cwsLoadTotal() {
        const select = document.getElementById('cwsSeatMatrix');
        const selectedOption = select.options[select.selectedIndex];
        const total = selectedOption.dataset.total || 0;
        document.getElementById('cwsTotalSeats').value = total;
        cwsRecalculate();
    }

    function cwsRecalculate() {
        const inputs = document.querySelectorAll('.cws-cat-input');
        let sum = 0;
        inputs.forEach(inp => sum += parseInt(inp.value || 0));

        const target = parseInt(document.getElementById('cwsTotalSeats').value || 0);
        document.getElementById('cwsAllocatedSum').textContent = sum;
        document.getElementById('cwsTargetTotal').textContent = target;

        const pill = document.getElementById('cwsBalancePill');
        if (target === 0) {
            pill.className = 'as-pill as-pill-draft';
            pill.innerHTML = '<i class="fas fa-info-circle"></i> Select a Seat Matrix entry first';
        } else if (sum === target) {
            pill.className = 'as-pill as-pill-active';
            pill.innerHTML = '<i class="fas fa-check-circle"></i> Balanced';
        } else if (sum < target) {
            pill.className = 'as-pill as-pill-draft';
            pill.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + (target - sum) + ' seats remaining';
        } else {
            pill.className = 'as-pill as-pill-locked';
            pill.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Over by ' + (sum - target) + ' seats';
        }
    }

    function cwsEditForm(seatMatrixId) {
        cwsShowForm();
        document.getElementById('cwsFormTitle').textContent = 'Edit Category Mapping';
        document.getElementById('cwsSeatMatrix').value = seatMatrixId;
        cwsLoadTotal();

        fetch('/SeatManagement/GetSeatCategoryMappingBySeatMatrix?id=' + seatMatrixId)
            .then(res => res.json())
            .then(rows => {
                document.querySelectorAll('.cws-cat-input').forEach(inp => {
                    const match = rows.find(r => r.CategoryId == inp.dataset.categoryId);
                    inp.value = match ? match.AllocatedSeats : 0;
                });
                cwsRecalculate();
            });
    }

    function cwsValidateSubmit() {
        const matrix = document.getElementById('cwsSeatMatrix').value;
        if (!matrix) { alert('Please select a Seat Matrix entry'); return false; }

        const sum = parseInt(document.getElementById('cwsAllocatedSum').textContent);
        const target = parseInt(document.getElementById('cwsTotalSeats').value);

        if (sum !== target) {
            alert('Category seats (' + sum + ') must equal Total Seats (' + target + ')');
            return false;
        }

        const ids = [];
        const seats = [];
        document.querySelectorAll('.cws-cat-input').forEach(inp => {
            ids.push(inp.dataset.categoryId);
            seats.push(inp.value || 0);
        });
        document.getElementById('categoryIdsCsv').value = ids.join(',');
        document.getElementById('seatsCsv').value = seats.join(',');

        return true;
    }
</script>