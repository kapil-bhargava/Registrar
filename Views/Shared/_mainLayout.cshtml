<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Registrar ERP</title>

    <!-- ====== STYLES ====== -->
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Inter Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet">
    <!-- Site-wide Styles -->
    <link href="~/Content/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- ============================================================ -->
    <!-- 1. SIDEBAR (Partial) -->
    <!-- ============================================================ -->
    @*<partial name="~/Views/Shared/_Sidebar.cshtml" />*@


    <!-- ============================================================ -->
    <!-- 2. MAIN WRAPPER -->
    <!-- ============================================================ -->
    <div class="main-wrapper">

        <!-- ====== 2.1 NAVBAR (Partial) ====== -->
        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")

        <!-- ====== 2.2 PAGE CONTENT ====== -->
        <main class="page-content">
            <div class="container-fluid">
                <!-- Page Title (optional, can be set by view) -->
                @if (!string.IsNullOrEmpty(ViewData["PageTitle"]?.ToString()))
                {
                    <div class="page-header">
                        <h1>@ViewData["PageTitle"]</h1>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                                @if (!string.IsNullOrEmpty(ViewData["Breadcrumb"]?.ToString()))
                                {
                                    <li class="breadcrumb-item active" aria-current="page">@ViewData["Breadcrumb"]</li>
                                }
                            </ol>
                        </nav>
                    </div>
                }

                <!-- Main Content from Child View -->
                @*@Html.Partial("_Navbar")*@
                @RenderBody()
            </div>
        </main>

        <!-- ====== 2.3 FOOTER (Partial) ====== -->

        @Html.Partial("_Footer")
    </div>

    <!-- ============================================================ -->
    <!-- 3. SCRIPTS -->
    <!-- ============================================================ -->
    <!-- jQuery (required for many Bootstrap features) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous">
    </script>

    <!-- Bootstrap 5 Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous">
    </script>

    <!-- Site-wide Scripts -->
    @*<script src="~/js/site.js" asp-append-version="true"></script>*@

    <!-- Render additional scripts from views -->
    @*@await RenderSectionAsync("Scripts", required: false)*@
</body>
</html>