        <!-- Masters -->
        <li>
            <div class="parent @(activeMenu == "Masters" ? "active" : "")" data-target="subMasters">
                <i class="fas fa-database"></i>
                Masters
                <span class="arrow"><i class="fas fa-chevron-down"></i></span>
            </div>
            <ul class="submenu @(activeMenu == "Masters" ? "open" : "")" id="subMasters">
                <li>
