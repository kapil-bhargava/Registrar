    <!-- Sidebar Footer -->
    <div class="sidebar-footer">
        <span class="status-dot online"></span>
        <span>System Online</span>
        <span style="margin-left: auto; font-size: 0.65rem;">v2.0</span>
    </div>
</aside>

<!-- Sidebar Overlay (for mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<script>
    (function() {
        'use strict';

        // ----- DOM References -----
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const menuTree = document.getElementById('menuTree');

        // ----- Toggle Submenu -----
        document.querySelectorAll('.parent[data-target]').forEach(function(parent) {
            parent.addEventListener('click', function(e) {
                e.stopPropagation();

                const targetId = this.getAttribute('data-target');
                const submenu = document.getElementById(targetId);
                if (!submenu) return;

                // Toggle open class
                submenu.classList.toggle('open');

                // Rotate arrow
                const arrow = this.querySelector('.arrow i');
                if (arrow) {
                    arrow.style.transform = submenu.classList.contains('open')
                        ? 'rotate(180deg)'
                        : 'rotate(0deg)';
                }

                // Update active state
                document.querySelectorAll('.parent').forEach(function(p) {
                    p.classList.remove('active');
                });
                this.classList.add('active');

                // Close other submenus (optional - uncomment for single open)
                // document.querySelectorAll('.submenu').forEach(function(sub) {
                //     if (sub.id !== targetId) {
                //         sub.classList.remove('open');
                //         const siblingParent = sub.parentElement?.querySelector('.parent');
                //         if (siblingParent) {
                //             const arrow = siblingParent.querySelector('.arrow i');
                //             if (arrow) arrow.style.transform = 'rotate(0deg)';
                //         }
                //     }
                // });
            });
        });

        // ----- Submenu Link Click -----
        document.querySelectorAll('.submenu li a').forEach(function(link) {
            link.addEventListener('click', function(e) {
                // Remove active from all submenu links
                document.querySelectorAll('.submenu li a').forEach(function(l) {
                    l.classList.remove('active-link');
                });
                this.classList.add('active-link');

                // Highlight parent
                const parentLi = this.closest('li')?.parentElement?.previousElementSibling;
                if (parentLi && parentLi.classList.contains('parent')) {
                    document.querySelectorAll('.parent').forEach(function(p) {
                        p.classList.remove('active');
                    });
                    parentLi.classList.add('active');

                    // Ensure submenu is open
                    const targetId = parentLi.getAttribute('data-target');
                    if (targetId) {
                        const sub = document.getElementById(targetId);
                        if (sub) {
                            sub.classList.add('open');
                            const arrow = parentLi.querySelector('.arrow i');
                            if (arrow) arrow.style.transform = 'rotate(180deg)';
                        }
                    }
                }

                // Close mobile sidebar after navigation
                if (window.innerWidth <= 992) {
                    closeSidebar();
                }
            });
        });

        // ----- Parent click (non-dropdown) -----
        document.querySelectorAll('.parent:not([data-target])').forEach(function(parent) {
            parent.addEventListener('click', function() {
                document.querySelectorAll('.parent').forEach(function(p) {
                    p.classList.remove('active');
                });
                this.classList.add('active');

                // Close mobile sidebar
                if (window.innerWidth <= 992) {
                    closeSidebar();
                }
            });
        });

        // ----- Open/Close Sidebar (Mobile) -----
        function openSidebar() {
            sidebar.classList.add('open');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Expose for navbar hamburger
        window.toggleSidebar = function() {
            if (sidebar.classList.contains('open')) {
                closeSidebar();
            } else {
                openSidebar();
            }
        };

        // Close on overlay click
        if (overlay) {
            overlay.addEventListener('click', closeSidebar);
        }

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && sidebar.classList.contains('open')) {
                closeSidebar();
            }
        });

        // Handle window resize
        let resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function() {
                if (window.innerWidth > 992 && sidebar.classList.contains('open')) {
                    closeSidebar();
                }
            }, 250);
        });

        // ----- Initialize: Open submenu if active -----
        document.querySelectorAll('.submenu.open').forEach(function(sub) {
            const parent = sub.parentElement?.querySelector('.parent');
            if (parent) {
                const arrow = parent.querySelector('.arrow i');
                if (arrow) arrow.style.transform = 'rotate(180deg)';
            }
        });

        // ----- Set active parent for active submenu links -----
        document.querySelectorAll('.submenu li a.active-link').forEach(function(link) {
            const parentLi = link.closest('li')?.parentElement?.previousElementSibling;
            if (parentLi && parentLi.classList.contains('parent')) {
                parentLi.classList.add('active');
                const targetId = parentLi.getAttribute('data-target');
                if (targetId) {
                    const sub = document.getElementById(targetId);
                    if (sub) {
                        sub.classList.add('open');
                        const arrow = parentLi.querySelector('.arrow i');
                        if (arrow) arrow.style.transform = 'rotate(180deg)';
                    }
                }
            }
        });

    })();
</script>