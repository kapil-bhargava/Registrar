                        <i class="fas fa-list"></i> View All
                    </a>
                </li>
                <li>
                    <a asp-controller="University" asp-action="Campus">
                        <i class="fas fa-flag"></i> Campus Management
                    </a>
                </li>
                <li>
                    <a asp-controller="University" asp-action="Address">
                        <i class="fas fa-map-pin"></i> Address & Contact
                    </a>
                </li>
                <li>
                    <a asp-controller="University" asp-action="Accreditation">
                        <i class="fas fa-certificate"></i> Accreditation
                    </a>
                </li>
                <li>
                    <a asp-controller="University" asp-action="Branding">
