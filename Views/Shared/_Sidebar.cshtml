                <i class="fas fa-user-graduate"></i>
                Student Master
                <span class="arrow"><i class="fas fa-chevron-down"></i></span>
            </div>
            <ul class="submenu @(activeMenu == "StudentMaster" ? "open" : "")" id="subStudentMaster">
