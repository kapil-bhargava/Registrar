
@{
    // You can pass active menu from ViewData or Controller
    string activeMenu = ViewData["ActiveMenu"]?.ToString() ?? "Dashboard";
}
<link href="~/Content/css/sidebar.css" rel="stylesheet" />
<aside class="sidebar" id="sidebar">
    <!-- Logo -->
    <div class="logo">
        <i class="fas fa-graduation-cap"></i>
        <span>Registrar ERP</span>
    </div>

    <!-- Menu -->
    <ul class="menu-tree" id="menuTree">
        <!-- Dashboard -->
