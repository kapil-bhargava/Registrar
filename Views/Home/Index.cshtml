@{
    ViewBag.Title = "Home Page";
}

<main>
    <section class="row" aria-labelledby="erpRegistrarTitle">
        <h1 id="erpRegistrarTitle">ERP Registrar Portal blabla blabla   </h1>
        <p class="lead">The central hub for academic administration, student records management, and institutional compliance. Streamline operations with automated workflows and real-time data tracking.</p>
        <p><a href="#overview" class="btn btn-primary btn-md">Explore Dashboard &raquo;</a></p>
    </section>

    <div class="row">
        <section class="col-md-4" aria-labelledby="studentRecordsTitle">
            <h2 id="studentRecordsTitle">Student Records</h2>
            <p>
                Manage lifecycle tracking from enrollment to graduation. Securely handle transcripts, digital degrees, personal data, and academic history with full audit trails and privacy compliance.
            </p>
            <p><a class="btn btn-outline-dark" href="#records">Manage Records &raquo;</a></p>
        </section>

        <section class="col-md-4" aria-labelledby="curriculumTitle">
            <h2 id="curriculumTitle">Curriculum &amp; Scheduling</h2>
            <p>Define academic structures, course catalogs, and prerequisites. Utilize automated scheduling tools for conflict-free timetables, exam tracking, and classroom resource allocation.</p>
            <p><a class="btn btn-outline-dark" href="#curriculum">Configure Courses &raquo;</a></p>
        </section>

        <section class="col-md-4" aria-labelledby="regulationsTitle">
            <h2 id="regulationsTitle">Registration &amp; Compliance</h2>
            <p>Empower students with self-service course registration while enforcing academic prerequisites, capacity limits, and institutional policies effortlessly.</p>
            <p><a class="btn btn-outline-dark" href="#compliance">View Compliance &raquo;</a></p>
        </section>
    </div>
</main>